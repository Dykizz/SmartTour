@* GeofenceBanner: chỉ xử lý UI banner và các nút điều khiển audio.
   Việc khởi động service, phát audio, và dừng khi logout
   được quản lý bởi MainLayout.razor *@
@inject GeofenceAudioService GeofenceService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject LanguageService LanguageService
@implements IAsyncDisposable

@if (GeofenceService.BannerVisible && GeofenceService.CurrentPoi != null)
{
    <MudPaper Elevation="12" Class="geofence-banner animate-slide-down pa-3" @onclick="GoToDetails">
        <div class="d-flex align-center gap-2">
            <div class="@(GeofenceService.IsAudioPlaying ? "geofence-pulse-dot" : "geofence-pause-dot")"></div>

            <div class="flex-grow-1" style="min-width: 0;">
                <MudText Typo="Typo.caption" Style="font-weight: bold; color: white; display:block; opacity: 0.9;">
                    @(GeofenceService.IsAudioPlaying ? "🔊 Đang thuyết minh" : "📍 Bạn đang ở gần")
                </MudText>
                <MudText Typo="Typo.subtitle2"
                         Style="color: white; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display:block;">
                    @GeofenceService.BannerPoiName
                </MudText>
            </div>

            <div class="d-flex align-center gap-1" @onclick:stopPropagation="true">
                <MudIconButton Icon="@(GeofenceService.IsAudioPlaying ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                               Size="Size.Small"
                               Style="color: white; background: rgba(255,255,255,0.15); border-radius: 50%;"
                               OnClick="ToggleAudioAsync" />

                <MudIconButton Icon="@Icons.Material.Filled.Replay"
                               Size="Size.Small"
                               Style="color: white; background: rgba(255,255,255,0.15); border-radius: 50%;"
                               OnClick="ReplayAudio"
                               Title="Nghe lại" />

                <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos"
                               Size="Size.Small"
                               Style="color: white; background: rgba(255,255,255,0.25); border-radius: 50%;"
                               OnClick="GoToDetails" />

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               Style="color: white;"
                               OnClick="CloseBannerAsync" />
            </div>
        </div>
    </MudPaper>
}

<style>
    .geofence-banner {
        position: fixed;
        bottom: 75px;
        left: 12px;
        right: 12px;
        z-index: 1100;
        border-radius: 16px;
        background: rgba(14, 110, 184, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 0.5px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 4px 15px rgba(14, 110, 184, 0.15);
        cursor: pointer;
        transition: transform 0.2s;
    }

    .geofence-banner:active { transform: scale(0.98); }

    .geofence-pulse-dot {
        width: 14px; height: 14px;
        border-radius: 50%;
        background: #fff;
        flex-shrink: 0;
        animation: pulseDot 1.4s ease-in-out infinite;
    }

    .geofence-pause-dot {
        width: 14px; height: 14px;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        flex-shrink: 0;
    }

    @@keyframes pulseDot {
        0%, 100% { transform: scale(1);   opacity: 1; }
        50%       { transform: scale(1.5); opacity: 0.6; }
    }

    .animate-slide-down { animation: slideDown 0.4s ease-out; }

    @@keyframes slideDown {
        from { transform: translateY(20px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
</style>

@code {
    
    protected override void OnInitialized()
    {
        GeofenceService.BannerStateChanged += OnBannerStateChanged;
    }

    private void OnBannerStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleAudioAsync()
    {
        if (GeofenceService.IsAudioPlaying)
        {
            await JS.InvokeVoidAsync("audioHelper.pause");
            GeofenceService.SetAudioPlaying(false);
        }
        else
        {
            await JS.InvokeVoidAsync("audioHelper.resume");
            GeofenceService.SetAudioPlaying(true);
        }
    }

    private async Task ReplayAudio()
    {
        if (GeofenceService.CurrentPoi != null)
        {
            var audio = GeofenceService.CurrentPoi.AudioFiles
                .FirstOrDefault(a => a.LanguageCode == LanguageService.SelectedLanguage)
                ?? GeofenceService.CurrentPoi.AudioFiles.FirstOrDefault();

            if (audio != null)
            {
                await JS.InvokeVoidAsync("audioHelper.playAtTime", audio.FileUrl, 0);
                GeofenceService.SetAudioPlaying(true);
            }
        }
    }

    private void GoToDetails()
    {
        if (GeofenceService.CurrentPoi != null)
            NavigationManager.NavigateTo($"/poi-details/{GeofenceService.CurrentPoi.Id}");
    }

    private async Task CloseBannerAsync()
    {
        GeofenceService.CloseBanner();
        await JS.InvokeVoidAsync("audioHelper.stop");
    }

    public async ValueTask DisposeAsync()
    {
        GeofenceService.BannerStateChanged -= OnBannerStateChanged;
        await Task.CompletedTask;
    }
}
