@page "/profile"
@using System.Net.Http.Json
@using SmartTour.Mobile.Services
@using SmartTour.Shared.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject LanguageService LanguageService
@inject GeofenceAudioService GeofenceService
@inject OfflineSyncService SyncService
@inject IDialogService DialogService
@inject IJSRuntime JS
@attribute [Authorize]
@implements IDisposable

<MudLayout>
    <MudAppBar Elevation="0" Dense="true"
               Style="background:linear-gradient(135deg,#0e6eb8 0%,#1a9de8 100%); z-index:200;">
        <div class="appbar-icon-btn" @onclick="@(() => NavigationManager.NavigateTo("/"))">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="color:white; font-size:1.1rem;" />
        </div>
        <MudSpacer />
        <MudText Style="font-size:0.95rem; font-weight:600; color:white;">
            @LanguageService.T("Profile")
        </MudText>
        <MudSpacer />
        <div class="appbar-icon-btn" style="visibility:hidden;">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Style="color:white; font-size:1.1rem;" />
        </div>
    </MudAppBar>

    <MudMainContent Style="background:#f5f9ff; min-height:100vh; padding-bottom:80px;">
        @if (_userId <= 0)

        {
                    <!-- Guest Mode -->
                    <div class="pa-4 pt-6">
                        <MudPaper Elevation="0" Class="pa-8 rounded-xl d-flex flex-column align-center text-center gap-4"
                                  Style="background:white; border:1px dashed #0e6eb8;">
                            <div class="profile-avatar guest-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Style="font-size:2.5rem; color:white;" />
                            </div>
                            <div class="status-tag guest-tag">@LanguageService.T("ExperienceMode")</div>
                            <div>
                                <MudText Typo="Typo.h6" Style="font-weight:800; color:#0a3050;">@LanguageService.T("ExperienceGuestTitle")</MudText>
                                <MudText Typo="Typo.body2" Style="color:#888;">@LanguageService.T("ExperienceGuestHint")</MudText>
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       Style="border-radius:14px; height:50px; text-transform:none; font-weight:700; background:#0e6eb8;"
                                       OnClick="@(() => NavigationManager.NavigateTo("/login?returnUrl=/profile"))">
                                @LanguageService.T("LoginNow")
                            </MudButton>
                        </MudPaper>
                    </div>
        }

        else

        {
                    <!-- Profile Header -->
                    <div class="profile-header-bg">
                        <div class="d-flex flex-column align-center pt-6 pb-4">
                            <div class="profile-avatar-wrapper">
                                <MudAvatar Image="@(string.IsNullOrEmpty(_user.AvatarUrl) ? "https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?auto=format&fit=crop&q=80&w=200&h=200" : _user.AvatarUrl)"
                                           Style="width:90px; height:90px; border-radius:32px; border:2px solid rgba(255,255,255,0.4); box-shadow:0 12px 24px rgba(0,0,0,0.1);" />
                                <div class="status-tag">@LanguageService.T("Active")</div>
                            </div>
                            <MudText Style="font-weight:800; color:white; font-size:1.2rem; margin-top:12px;">@_userName</MudText>
                            <MudText Style="color:rgba(255,255,255,0.8); font-size:0.85rem;">@_userEmail</MudText>
                            <MudText Style="color:rgba(255,255,255,0.6); font-size:0.75rem; margin-top:4px;">
                                @LanguageService.T("JoinDate") @_memberYear
                            </MudText>
                        </div>
                    </div>

                    <div class="px-4" style="margin-top:-30px;">
                        <!-- Stats Row -->
                        <MudGrid Spacing="2">
                            <MudItem xs="6">
                                <div class="stat-card">
                                    <span class="stat-val">@_favorites.Count</span>
                                    <span class="stat-label">@LanguageService.T("Favorite")</span>
                                </div>
                            </MudItem>
                            <MudItem xs="6">
                                <div class="stat-card">
                                    <MudIcon Icon="@Icons.Material.Filled.Stars" Style="color:#fbc02d; font-size:1.2rem;" />
                                    <span class="stat-label">@LanguageService.T("Badges")</span>
                                </div>
                            </MudItem>
                        </MudGrid>

                        <!-- Favorites Library (Photo Grid) -->
                        <div class="mt-8">
                            <div class="d-flex justify-space-between align-center mb-4">
                                <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:#0a3050;">
                                    🔖 @LanguageService.T("FavoriteList")
                                </MudText>
                                <div class="see-all-link" @onclick="@(() => NavigationManager.NavigateTo("/favorites"))">
                                    @LanguageService.T("SeeAll") (@_favorites.Count)
                                </div>
                            </div>

                    @if (_loadingFavs)

                    {
                                        <div class="d-flex justify-center py-6">
                                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                                        </div>
                    }

                    else if (_favorites.Any())

                    {
                                        <MudGrid Spacing="2">
                            @foreach (var poi in _previewFavorites)

                            {

                                var thumb = poi.Images?.FirstOrDefault(i => i.IsThumbnail)?.ImageUrl

                                            ?? poi.Images?.FirstOrDefault()?.ImageUrl ?? "";
                                                        <MudItem xs="6">
                                                            <div class="fav-grid-item" @onclick="@(() => NavigationManager.NavigateTo($"/poi-details/{poi.Id}"))">
                                                                <div class="fav-img-wrap" style="@(string.IsNullOrEmpty(thumb) ? "background:#0e6eb8;" : $"background:url('{thumb}') center/cover no-repeat;")">
                                                                    <div class="fav-heart-btn" @onclick:stopPropagation="true" @onclick="@(() => RemoveFavorite(poi.Id))">
                                                                        <MudIcon Icon="@Icons.Material.Filled.Favorite" Style="color:#ff5252; font-size:1.1rem;" />
                                                                    </div>
                                                                </div>
                                                                <div class="fav-info">
                                                                    <MudText Typo="Typo.caption" Class="fav-name">@poi.Name</MudText>
                                                                    <div class="fav-cat">@(poi.Category?.Name ?? LanguageService.T("Place"))</div>
                                                                </div>
                                                            </div>
                                                        </MudItem>
                            }
                                        </MudGrid>
                    }

                    else

                    {
                                        <div class="empty-favs">
                                            <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Style="color:#dee8f5; font-size:3rem;" />
                                            <MudText Typo="Typo.body2" Style="color:#b0c4de; margin-top:8px;">@LanguageService.T("EmptyFavs")</MudText>
                                        </div>
                    }
                        </div>

                        <!-- Settings List -->
                        <div class="mt-8 mb-4">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:#0a3050; margin-bottom:12px;">⚙️ @LanguageService.T("AppSettings")</MudText>
                            <MudPaper Elevation="0" Class="rounded-xl overflow-hidden" Style="border: 1px solid #e1e9f5;">
                                
                                <!-- Offline Pack Download Button -->
                                <div class="setting-item" @onclick="DownloadOfflinePack" style="align-items:flex-start;">
                                    <div class="setting-icon" style="background:rgba(16,185,129,0.1); color:#10b981; margin-top:2px;">
                                        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Size="Size.Small" />
                                    </div>
                                    <div class="setting-text">
                                        <div style="font-weight:700;">Tải gói hình & âm thanh Offline</div>
                                        @if(_isScanning)
                                        {
                                            <div style="font-size:0.75rem; color:#0e6eb8; margin-top:4px; font-weight:600;">Đang quét dữ liệu...</div>
                                        }
                                        else if(_isDownloadingPack)
                                        {
                                            <div style="font-size:0.75rem; color:#888; margin-top:4px; font-weight:500;">@_downloadStatus (@_downloadPercent%)</div>
                                            <MudProgressLinear Color="Color.Success" Value="@_downloadPercent" Class="mt-2" Rounded="true" Size="Size.Small" />
                                        }
                                        else
                                        {
                                            <div style="font-size:0.75rem; color:#888; font-weight:500;">Tải đệm sẵn để nghe thuyết minh kể cả lúc rớt mạng</div>
                                            @if (!string.IsNullOrEmpty(_lastSyncTime))
                                            {
                                                <div style="font-size:0.7rem; color:#10b981; margin-top:4px; font-weight:600; display:flex; align-items:center;">
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size:0.8rem; margin-right:4px;" />
                                                    Đã đồng bộ lúc: @_lastSyncTime
                                                </div>
                                            }
                                        }
                                    </div>
                                    @if(!_isDownloadingPack && !_isScanning) { <MudIcon Icon="@Icons.Material.Filled.CloudSync" Size="Size.Small" Style="color:#cbd5e1; align-self:center;" /> }
                                </div>
                                <div class="setting-divider"></div>

                                <div class="setting-item" @onclick="@(() => NavigationManager.NavigateTo("/profile/edit"))">
                                    <div class="setting-icon blue">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountBox" Size="Size.Small" />
                                    </div>
                                    <div class="setting-text">@LanguageService.T("PersonalInfo")</div>
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color:#cbd5e1" />
                                </div>

                                <div class="setting-divider"></div>

                                <div class="setting-item" @onclick="Logout">
                                    <div class="setting-icon red">
                                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" />
                                    </div>
                                    <div class="setting-text" style="color:#ef4444;">@LanguageService.T("Logout")</div>
                                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color:#cbd5e1" />
                                </div>
                            </MudPaper>
                        </div>
                    </div>
        }
    </MudMainContent>

    <BottomNavigation Active="profile" />

    <!-- ── Mobile Download Confirmation Bottom Sheet (Custom CSS Native) ── -->
    <MudOverlay Visible="_downloadSheetOpen" DarkBackground="true" AutoClose="true" OnClosed="CloseSheet" ZIndex="9998" />
    
    <div class="custom-bottom-sheet @(_downloadSheetOpen ? "sheet-open" : "")">
        <div class="sheet-header">
            <div class="sheet-pill"></div>
        </div>
        <div class="sheet-body px-4 pb-4">
            <div class="d-flex align-center mb-4">
                <div style="background:rgba(14,110,184,0.1); width:48px; height:48px; border-radius:24px; display:flex; align-items:center; justify-content:center; margin-right:16px;">
                    <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Style="color:#0e6eb8; font-size:1.6rem;" />
                </div>
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight:800; color:#0a3050; line-height:1.2;">Gói Ngoại Tuyến</MudText>
                    <MudText Typo="Typo.caption" Style="color:#64748b;">Nghe lồng tiếng không cần mạng</MudText>
                </div>
            </div>
            
            <div style="background:#f8fafc; border-radius:12px; padding:12px; margin-bottom:16px; border:1px solid #e2e8f0;">
                <div class="d-flex align-center gap-3 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" Style="color:#64748b;" />
                    <MudText Typo="Typo.body2" Style="color:#334155; font-weight:600; font-size:0.85rem;">@_packInfo?.TotalPois Địa điểm Tour</MudText>
                </div>
                <div class="d-flex align-center gap-3 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Style="color:#64748b;" />
                    <MudText Typo="Typo.body2" Style="color:#334155; font-weight:600; font-size:0.85rem;">@_packInfo?.TotalImages Hình ảnh HD minh họa</MudText>
                </div>
                <div class="d-flex align-center gap-3 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Headset" Size="Size.Small" Style="color:#64748b;" />
                    <MudText Typo="Typo.body2" Style="color:#334155; font-weight:600; font-size:0.85rem;">@_packInfo?.TotalAudio File lồng tiếng MP3</MudText>
                </div>
                <div class="d-flex align-center justify-space-between mt-3 pt-3" style="border-top:1px dashed #cbd5e1;">
                    <MudText Typo="Typo.body2" Style="color:#64748b; font-size:0.85rem;">Tổng dung lượng</MudText>
                    <MudText Typo="Typo.subtitle2" Style="color:#0e6eb8; font-weight:800;">~@(_packInfo?.EstimatedMegabytes.ToString("F1")) MB</MudText>
                </div>
            </div>

            @if (_isCellularWarning)
            {
                <div style="background:rgba(239,68,68,0.1); border-radius:10px; padding:10px; margin-bottom:16px; display:flex; gap:10px; align-items:flex-start;">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Style="color:#ef4444; font-size:1.1rem;" />
                    <MudText Typo="Typo.caption" Style="color:#b91c1c; font-weight:600; font-size:0.75rem; line-height:1.3;">Đang dùng 4G/5G. Việc tải có thể ngốn dữ liệu đi động!</MudText>
                </div>
            }

            <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                       Style="border-radius:12px; height:48px; font-weight:700; font-size:0.95rem; margin-bottom:8px; background:#0e6eb8;"
                       OnClick="ConfirmDownload">
                Tải Ngay Sẵn Sàng
            </MudButton>
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Default"
                       Style="border-radius:12px; height:44px; font-weight:600; font-size:0.9rem; color:#64748b;"
                       OnClick="CloseSheet">
                Để Lúc Khác
            </MudButton>
        </div>
    </div>
</MudLayout>

<style>
    .appbar-icon-btn {
        width: 32px; height: 32px; border-radius: 10px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
    }

    .profile-header-bg {
        background: linear-gradient(135deg,#0e6eb8 0%,#1a9de8 100%);
        padding-bottom: 50px;
        border-bottom-left-radius: 40px;
        border-bottom-right-radius: 40px;
        box-shadow: 0 10px 30px rgba(14,110,184,0.15);
    }

    .profile-avatar-wrapper {
        position: relative;
    }

    .profile-avatar {
        width: 90px; height: 90px; border-radius: 32px;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        display: flex; align-items: center; justify-content: center;
        border: 2px solid rgba(255,255,255,0.4);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
    }
    .guest-avatar { background: rgba(14,110,184,0.1); border: 2px solid #0e6eb8; }

    .status-tag {
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        background: #10b981;
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 100px;
        box-shadow: 0 4px 8px rgba(16,185,129,0.3);
        white-space: nowrap;
        border: 2px solid white;
    }
    .guest-tag { background: #64748b; bottom: 0; position:relative; transform:none; left:0; margin-top:5px; }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 12px 6px;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 8px 20px rgba(14,110,184,0.06);
        border: 1px solid #edf4ff;
    }

    .stat-val { font-size: 1.1rem; font-weight: 800; color: #0a3050; }
    .stat-label { font-size: 0.65rem; color: #94a3b8; font-weight: 600; margin-top: 2px; }

    .see-all-link { color: #0e6eb8; font-size: 0.8rem; font-weight: 700; cursor: pointer; }

    .fav-grid-item {
        background: white; border-radius: 20px;
        overflow: hidden; box-shadow: 0 6px 16px rgba(14,110,184,0.05);
        border: 1px solid #f1f5f9; cursor: pointer;
    }

    .fav-img-wrap {
        height: 110px; width: 100%; position: relative;
    }

    .fav-heart-btn {
        position: absolute; top: 8px; right: 8px;
        width: 32px; height: 32px; border-radius: 10px;
        background: rgba(255,255,255,0.9);
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .fav-info { padding: 10px 12px; }
    .fav-name { font-weight: 700; color: #0a3050; font-size: 0.82rem !important; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .fav-cat { font-size: 0.65rem; color: #94a3b8; font-weight: 600; margin-top: 2px; }

    .empty-favs {
        height: 140px; display: flex; flex-direction: column; align-items: center; justify-content: center;
        background: white; border-radius: 24px; border: 1px dashed #e1e9f5;
    }

    .setting-item {
        display: flex; align-items: center; padding: 16px; background: white; cursor: pointer;
    }
    .setting-item:active { background: #f8fafc; }
    .setting-item.no-arrow { cursor: default; }
    .setting-item.no-arrow:active { background: white; }

    .setting-icon {
        width: 36px; height: 36px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        margin-right: 14px;
    }
    .setting-icon.blue { background: rgba(14,110,184,0.1); color: #0e6eb8; }
    .setting-icon.red { background: rgba(239,68,68,0.1); color: #ef4444; }

    .setting-text { flex: 1; font-size: 0.9rem; font-weight: 600; color: #334155; }
    .setting-divider { height: 1px; background: #f1f5f9; margin: 0 16px; }

    /* ── Custom Bottom Sheet Native ── */
    .custom-bottom-sheet {
        position: fixed;
        bottom: 0; left: 0; right: 0; width: 100%;
        background: white;
        border-radius: 28px 28px 0 0;
        z-index: 9999;
        transform: translateY(110%);
        transition: transform 0.35s cubic-bezier(0.3, 1, 0.3, 1);
        box-shadow: 0 -4px 30px rgba(0,0,0,0.15);
        padding-bottom: 20px;
    }
    .custom-bottom-sheet.sheet-open {
        transform: translateY(0);
    }
    
    .sheet-header {
        display: flex; justify-content: center; padding: 14px 0;
    }
    .sheet-pill {
        width: 44px; height: 5px; border-radius: 10px; background: #cbd5e1;
    }
    .sheet-body {
        max-height: 80vh; overflow-y: auto; overflow-x: hidden;
    }
</style>

@code {
    private UserDto _user = new();

    private string _userName = "Khách hành";

    private string _userEmail = "";

    private int _userId = 0;

    private int _memberYear = 2026;

    private List<Poi> _favorites = new();

    private bool _loadingFavs = false;



    private List<Poi> _previewFavorites => _favorites.Take(4).ToList();

    // Biến cho tính năng Tải gói Offline
    private bool _isScanning = false;
    private bool _isDownloadingPack = false;
    private string _downloadStatus = "";
    private int _downloadPercent = 0;
    
    private bool _downloadSheetOpen = false;
    private OfflineSyncService.OfflinePackInfo? _packInfo;
    private bool _isCellularWarning = false;
    private string _lastSyncTime = "";

    protected override async Task OnInitializedAsync()

    {
        _lastSyncTime = Microsoft.Maui.Storage.Preferences.Default.Get("LastOfflineSyncTime", "");

        try

        {

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();

            var fullName = authState.User.FindFirst("FullName")?.Value;

            _userName = !string.IsNullOrWhiteSpace(fullName) ? fullName : (authState.User.Identity?.Name ?? LanguageService.T("Guest"));

            var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            int.TryParse(idClaim, out _userId);

            if (_userId > 0)
            {
                // UI lướt ngay lập tức (Không chờ đợi ổ cứng/DB Cục bộ chạy xong)
                _ = LoadUserProfile();
                _ = LoadFavorites();
            }

            LanguageService.OnLanguageChanged += StateHasChanged;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LanguageService.T("SystemError")}: {ex.Message}", Severity.Error);
        }
    }

    public void Dispose()
    {
        LanguageService.OnLanguageChanged -= StateHasChanged;
    }



    private async Task LoadUserProfile()
    {
        try
        {
            await SyncService.GetUserProfileAsync(_userId, user => 
            {
                if (user != null && user.Id != 0)
                {
                    _user = user;
                    _userName = user.FullName;
                    _userEmail = user.Email;
                    _memberYear = user.CreatedAt.Year;
                    InvokeAsync(StateHasChanged);
                }
            });
        }
        catch (Exception) { }
    }

    private async Task LoadFavorites()
    {
        _loadingFavs = true;
        StateHasChanged();
        try
        {
            if (Microsoft.Maui.Networking.Connectivity.NetworkAccess == Microsoft.Maui.Networking.NetworkAccess.Internet)
            {
                // Có mạng: gọi thẳng API (luôn đúng)
                var result = await Http.GetFromJsonAsync<List<Poi>>("api/favorites");
                if (result != null)
                    _favorites = result;
            }
            else
            {
                // Offline: đọc từ SQLite local
                var localFavs = await SyncService.GetFavoritesAsync(_userId);
                if (localFavs.Any())
                    _favorites = localFavs;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải yêu thích: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingFavs = false;
            StateHasChanged(); // ← Render 1 lần duy nhất sau khi XONG, bao gồm cả tắt spinner
        }
    }


    private async Task RemoveFavorite(int poiId)
    {
        // 1. Optimistic UI: Ẩn ngay khỏi danh sách trên màn hình
        var poiToRemove = _favorites.FirstOrDefault(p => p.Id == poiId);
        if (poiToRemove == null) return;
        
        _favorites.Remove(poiToRemove);
        StateHasChanged();

        try
        {
            // Gọi ToggleFavoriteAsync (API thẳng nếu có mạng, Offline Queue nếu không)
            await SyncService.ToggleFavoriteAsync(poiId, _userId);
            Snackbar.Add("Đã xóa khỏi bộ sưu tập", Severity.Success);
        }
        catch (Exception ex)
        {
            // Rollback nếu thất bại
            _favorites.Add(poiToRemove);
            StateHasChanged();
            Snackbar.Add($"Lỗi thao tác: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadOfflinePack()
    {
        if (_isDownloadingPack || _isScanning) return;
        
        var access = Microsoft.Maui.Networking.Connectivity.Current.NetworkAccess;
        if (access != Microsoft.Maui.Networking.NetworkAccess.Internet)
        {
            Snackbar.Add("Mất kết nối Internet! Không thể quét dữ liệu.", Severity.Warning);
            return;
        }

        _isScanning = true;
        StateHasChanged();

        try
        {
            var p = new Progress<OfflineSyncService.SyncProgress>(prg => { });
            _packInfo = await SyncService.PrepareOfflinePackAsync(p);

            var profiles = Microsoft.Maui.Networking.Connectivity.Current.ConnectionProfiles;
            _isCellularWarning = profiles.Contains(Microsoft.Maui.Networking.ConnectionProfile.Cellular) && !profiles.Contains(Microsoft.Maui.Networking.ConnectionProfile.WiFi);

            _downloadSheetOpen = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Đo lường thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isScanning = false;
            StateHasChanged();
        }
    }

    private void CloseSheet()
    {
        _downloadSheetOpen = false;
    }

    private async Task ConfirmDownload()
    {
        _downloadSheetOpen = false;
        _isDownloadingPack = true;
        _downloadStatus = "Đang tải...";
        StateHasChanged();

        try
        {
            // Bước 2: Khách Bấm Đồng Ý Tải -> Kéo file Vật lý
            var p2 = new Progress<OfflineSyncService.SyncProgress>(prg =>
            {
                _downloadStatus = prg.CurrentStatus;
                _downloadPercent = prg.Percentage;
                InvokeAsync(StateHasChanged);
            });

            await SyncService.DownloadMediaPackAsync(_packInfo!, p2);
            
            _downloadStatus = "Hoàn tất! Đi du lịch Offline thôi!";
            _downloadPercent = 100;
            _lastSyncTime = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
            Microsoft.Maui.Storage.Preferences.Default.Set("LastOfflineSyncTime", _lastSyncTime);

            Snackbar.Add($"Tải thành công {_packInfo?.EstimatedMegabytes:F1}MB tài nguyên trọn gói!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Tải thất bại: {ex.Message}", Severity.Error);
            _downloadStatus = "Lỗi đường truyền";
        }
        finally
        {
            await Task.Delay(3000); 
            _isDownloadingPack = false;
            StateHasChanged();
        }
    }



    private async Task Logout()

    {

        try { await JS.InvokeVoidAsync("audioHelper.stop"); } catch { }

        await GeofenceService.HardResetAsync();

        var auth = (MobileAuthStateProvider)AuthStateProvider;

        auth.MarkUserAsLoggedOut();

        NavigationManager.NavigateTo("/login");

    }
}
