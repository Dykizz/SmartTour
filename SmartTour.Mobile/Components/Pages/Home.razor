@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using SmartTour.Mobile.Services
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject LanguageService LanguageService

@attribute [Authorize]

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Primary" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" />
        <MudSpacer />
        <MudText Typo="Typo.h6" Style="font-weight: bold;">@LanguageService.T("Home")</MudText>
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Direction="Direction.Left" OffsetX="true" Dense="true">
            @if (_languages.Any())
            {
                foreach (var lang in _languages)
                {
                    <MudMenuItem OnClick="@(() => ChangeLanguage(lang.Code))">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@(lang.Code == _selectedLanguage ? Icons.Material.Filled.Check : Icons.Material.Filled.Translate)" 
                                     Color="@(lang.Code == _selectedLanguage ? Color.Primary : Color.Default)"
                                     Size="Size.Small" Class="mr-2"/>
                            <MudText Typo="Typo.body2">@lang.Name</MudText>
                        </div>
                    </MudMenuItem>
                }
            }
            else
            {
                <MudMenuItem Disabled="true">Đang tải...</MudMenuItem>
            }
        </MudMenu>
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" Edge="Edge.End" />
    </MudAppBar>

    <MudMainContent Class="pa-4" Style="background-color: #f5f5f5; min-height: 100vh;">
        
    <MudText Typo="Typo.h5" Class="mb-1">@LanguageService.T("Hello"), <b>@_userName</b>! 👋</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">@LanguageService.T("SearchHint")</MudText>

        <!-- Categories -->
        <MudText Typo="Typo.subtitle1" Style="font-weight: bold;" Class="mb-3">@LanguageService.T("Categories")</MudText>
        <div class="d-flex gap-2 mb-6 overflow-auto no-scrollbar" style="padding: 4px 2px 8px 2px; -webkit-overflow-scrolling: touch;">
            @if (_loadingCategories)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            }
            else
            {
                <MudChip T="int" Color="Color.Primary" 
                         Variant="@(_selectedCategoryId == 0 ? Variant.Filled : Variant.Outlined)" 
                         Icon="@Icons.Material.Filled.Dashboard" 
                         OnClick="@(() => FilterByCategory(0))"
                         Style="min-width: fit-content; white-space: nowrap; margin: 0;">Tất cả</MudChip>
                
                @if (_categories.Any())
                {
                    var iconMap = new[] { Icons.Material.Filled.Nature, Icons.Material.Filled.Museum, Icons.Material.Filled.Restaurant, Icons.Material.Filled.Hotel, Icons.Material.Filled.LocalCafe };
                    var colorMap = new[] { Color.Primary, Color.Secondary, Color.Info, Color.Success, Color.Warning };
                    int idx = 0;
                    foreach (var cat in _categories)
                    {
                        var currentCatId = cat.Id;
                        <MudChip T="int" Value="@currentCatId" 
                                 Color="@colorMap[idx % colorMap.Length]" 
                                 Variant="@(_selectedCategoryId == currentCatId ? Variant.Filled : Variant.Outlined)" 
                                  Icon="@iconMap[idx % iconMap.Length]"
                                 OnClick="@(() => FilterByCategory(currentCatId))"
                                 Style="min-width: fit-content; white-space: nowrap; margin: 0;">@LanguageService.T(cat.Name)</MudChip>
                        idx++;
                    }
                }
            }
        </div>

        <style>
            .no-scrollbar::-webkit-scrollbar {
                display: none;
            }
            .no-scrollbar {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
        </style>

        <!-- Featured Section -->
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.subtitle1" Style="font-weight: bold;">@LanguageService.T("Featured")</MudText>
            <MudLink Typo="Typo.caption" Href="#">@LanguageService.T("SeeAll")</MudLink>
        </div>

        <!-- Location Filter -->
        <div class="d-flex align-center justify-space-between mb-4 mt-2 pa-2 rounded-lg" style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border: 1px dashed rgba(var(--mud-palette-primary-rgb), 0.2);">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation" Color="@(_locationActive ? Color.Primary : Color.Default)" Size="Size.Small" Class="mr-2" />
                <MudText Typo="Typo.caption" Style="font-weight: 500;">@LanguageService.T("FindAround")</MudText>
            </div>
            <div class="d-flex align-center gap-1">
                <MudSelect T="double?" Value="_selectedRadius" ValueChanged="OnRadiusChanged" Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Style="width: 110px; font-size: 0.8rem;">
                    <MudSelectItem T="double?" Value="@((double?)null)">@(_selectedLanguage == "en" ? "All" : "Tất cả")</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(500.0)">500 m</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(1000.0)">1.0 km</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(2000.0)">2.0 km</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(5000.0)">5.0 km</MudSelectItem>
                </MudSelect>
                @if (_locationActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" OnClick="DisableLocation" />
                }
            </div>
        </div>

        <MudGrid>
            @if (_loadingPois)
            {
                <MudItem xs="12" Class="d-flex justify-center pa-8">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </MudItem>
            }
            else if (_pois.Any())
            {
                foreach (var poi in _pois)
                {
                    <MudItem xs="@(poi.IsFeature ? 12 : 6)">
                        <MudCard Elevation="4" Style="border-radius: 16px; overflow: hidden; height: 100%;" Class="mud-ripple" @onclick="@(() => NavigationManager.NavigateTo($"/poi-details/{poi.Id}"))">
                            @{
                                var thumbnail = poi.Images.FirstOrDefault(i => i.IsThumbnail)?.ImageUrl 
                                               ?? poi.Images.FirstOrDefault()?.ImageUrl 
                                               ?? "https://via.placeholder.com/400x200?text=No+Image";
                            }
                            <MudCardMedia Image="@thumbnail" Height="@(poi.IsFeature ? 180 : 120)" />
                            <MudCardContent Class="@(poi.IsFeature ? "pa-4" : "pa-3")">
                                <div class="d-flex align-center justify-space-between mb-1">
                                    <MudText Typo="@(poi.IsFeature ? Typo.h6 : Typo.subtitle2)" Style="font-weight: bold;" Class="line-clamp-1">@poi.Name</MudText>
                                    @if (poi.IsFeature)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                                    }
                                </div>
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Error" Class="mr-1"/>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="line-clamp-1">@LanguageService.T(poi.Category?.Name ?? "Place")</MudText>
                                </div>
                                @if (poi.IsFeature)
                                {
                                    <MudRating SelectedValue="5" ReadOnly="true" Size="Size.Small" Class="mt-2" />
                                }
                            </MudCardContent>
                            <MudCardActions Class="pa-2">
                                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/poi-details/{poi.Id}"))">@LanguageService.T("Details")</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12" Class="pa-12 d-flex flex-column align-center justify-center animate-fade-in">
                    <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center text-center rounded-xl" Style="background: transparent; border: 2px dashed rgba(0,0,0,0.05);">
                        <div class="relative mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOff" Style="font-size: 4rem; opacity: 0.1;" />
                            <MudIcon Icon="@Icons.Material.Filled.Search" Style="position: absolute; bottom: 0; right: 0; font-size: 2rem;" Color="Color.Primary" />
                        </div>
                        <MudText Typo="Typo.h6" Class="mb-1" Style="font-weight: bold;">@LanguageService.T("NoResults")</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
                            @(_selectedLanguage == "en" 
                                ? (_selectedRadius.HasValue ? $"No places found within {DisplayRadius(_selectedRadius.Value)}." : "No places found in this category.")
                                : (_selectedRadius.HasValue ? $"Không có địa điểm nào trong bán kính {DisplayRadius(_selectedRadius.Value)}." : "Không tìm thấy địa điểm nào trong danh mục này."))
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" 
                                   OnClick="ResetFilters" Class="rounded-pill px-8 py-2">@LanguageService.T("SeeAll")</MudButton>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-8 mb-4" Color="Color.Secondary">
            @(_selectedLanguage == "en" ? "End of list" : "Hết danh sách")
        </MudText>
        
        <style>
            .line-clamp-1 {
                display: -webkit-box;
                -webkit-line-clamp: 1;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
        </style>
    </MudMainContent>

    <!-- Bottom Navigation Mock -->
    <MudPaper Elevation="8" Class="fixed-bottom py-2" Style="position: fixed; bottom: 0; width: 100%; border-top-left-radius: 20px; border-top-right-radius: 20px;">
        <div class="d-flex justify-space-around">
            <div class="d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.Home" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Primary">@LanguageService.T("Home")</MudText>
            </div>
            <div class="d-flex flex-column align-center" style="opacity: 0.5">
                <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Inherit" />
                <MudText Typo="Typo.caption">@LanguageService.T("Map")</MudText>
            </div>
            <div class="d-flex flex-column align-center" style="opacity: 0.5">
                <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" />
                <MudText Typo="Typo.caption">@LanguageService.T("Profile")</MudText>
            </div>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex flex-column align-center" style="opacity: 0.5">
                        <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="Logout" Size="Size.Small"/>
                        <MudText Typo="Typo.caption">@LanguageService.T("Logout")</MudText>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="d-flex flex-column align-center" style="opacity: 0.5">
                        <MudIconButton Icon="@Icons.Material.Filled.Login" Color="Color.Inherit" OnClick="NavigateToLogin" Size="Size.Small"/>
                        <MudText Typo="Typo.caption">@LanguageService.T("Login")</MudText>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </MudPaper>
</MudLayout>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; }
    private string _userName;
    private List<Category> _categories = new();
    private List<Poi> _pois = new();
    private bool _loadingCategories = true;
    private bool _loadingPois = true;
    private int _selectedCategoryId = 0; // 0 means "All"
    private List<Language> _languages = new();
    private string _selectedLanguage = "vi";
    
    // Remote Tracking
    private double? _userLat;
    private double? _userLng;
    private double? _selectedRadius;
    private bool _locationActive = false;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            if (AuthenticationStateTask == null)
            {
                _userName = "Guest";
            }
            else
            {
                var authState = await AuthenticationStateTask;
                _userName = authState.User.Identity?.Name ?? "Guest";
            }
            
            _selectedLanguage = LanguageService.SelectedLanguage;

            await Task.WhenAll(LoadCategories(), LoadPois(), LoadLanguages());
        }
        catch (Exception ex)
        {
            // Bắt lỗi tổng quát để tránh crash trang
            Snackbar.Add("Lỗi khởi tạo trang: " + ex.Message, Severity.Error);
        }
    }

    private async Task LoadCategories()
    {
        _loadingCategories = true;
        try
        {
            _categories = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải danh mục: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loadingCategories = false;
        }
    }

    private async Task LoadLanguages()
    {
        try
        {
            _languages = await Http.GetFromJsonAsync<List<Language>>("api/languages") ?? new();
            var defaultLang = _languages.FirstOrDefault(l => l.IsDefault)?.Code ?? "vi";
            _selectedLanguage = defaultLang;
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải ngôn ngữ: " + ex.Message, Severity.Warning);
        }
    }

    private void ChangeLanguage(string code)
    {
        _selectedLanguage = code;
        LanguageService.SetLanguage(code);
        Snackbar.Add($"Đã chuyển sang ngôn ngữ: {code.ToUpper()}", Severity.Info);
        // Có thể reload lại POI nếu API hỗ trợ trả về tên theo ngôn ngữ
    }

    private async Task LoadPois()
    {
        _loadingPois = true;
        try
        {
            var queryParams = new List<string>();
            if (_selectedCategoryId > 0) queryParams.Add($"categoryId={_selectedCategoryId}");
            
            if (_locationActive && _userLat.HasValue && _userLng.HasValue && _selectedRadius.HasValue)
            {
                queryParams.Add($"lat={_userLat}");
                queryParams.Add($"lng={_userLng}");
                queryParams.Add($"radius={_selectedRadius}");
            }

            string url = "api/pois";
            if (queryParams.Any()) url += "?" + string.Join("&", queryParams);

            _pois = await Http.GetFromJsonAsync<List<Poi>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải địa điểm: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loadingPois = false;
        }
    }

    private async Task FilterByCategory(int categoryId)
    {
        if (_selectedCategoryId == categoryId) return;
        _selectedCategoryId = categoryId;
        await LoadPois();
    }

    private async Task OnRadiusChanged(double? radius)
    {
        _selectedRadius = radius;
        if (radius.HasValue)
        {
            await GetCurrentLocation();
        }
        else
        {
            _locationActive = false;
            await LoadPois();
        }
    }

    private async Task GetCurrentLocation()
    {
        try
        {
            var request = new GeolocationRequest(GeolocationAccuracy.Medium, TimeSpan.FromSeconds(10));
            var location = await Geolocation.Default.GetLocationAsync(request);

            if (location != null)
            {
                _userLat = location.Latitude;
                _userLng = location.Longitude;
                _locationActive = true;
                await LoadPois();
            }
            else
            {
                Snackbar.Add("Không lấy được tọa độ hiện tại", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi định vị: Vui lòng bật GPS và cấp quyền.", Severity.Error);
            _selectedRadius = null;
            _locationActive = false;
        }
    }

    private async Task DisableLocation()
    {
        _locationActive = false;
        _selectedRadius = null;
        await LoadPois();
    }

    private async Task ResetFilters()
    {
        _selectedCategoryId = 0;
        _selectedRadius = null;
        _locationActive = false;
        await LoadPois();
    }

    private string DisplayRadius(double m) => m >= 1000 ? $"{m/1000:0.#} km" : $"{m} m";

    private void Logout()
    {
        var auth = (MobileAuthStateProvider)AuthStateProvider;
        auth.MarkUserAsLoggedOut();
        NavigationManager.NavigateTo("/login");
    }

    private void NavigateToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }
}
