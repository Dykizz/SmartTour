@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using SmartTour.Mobile.Services
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@implements IAsyncDisposable
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject LanguageService LanguageService
@inject GeofenceAudioService GeofenceService
@inject IJSRuntime JS
@attribute [Authorize]

<MudLayout>
    <!-- ── AppBar ── -->
    <MudAppBar Elevation="0" Dense="true"
               Style="background:linear-gradient(135deg,#0e6eb8 0%,#1a9de8 100%); z-index:200;">
        <div class="d-flex align-center gap-2">
            <div class="appbar-icon-btn">
                <MudIcon Icon="@Icons.Material.Filled.Menu"
                         Style="color:white; font-size:1.2rem;" />
            </div>
            <div>
                <MudText Style="font-size:0.7rem; color:rgba(255,255,255,0.75); line-height:1;">
                    Xin chào 👋
                </MudText>
                <MudText Style="font-size:0.95rem; font-weight:600; color:white; line-height:1.3;">
                    @_userName
                </MudText>
            </div>
        </div>
        <MudSpacer />
        <div class="d-flex gap-2">
            <MudMenu Icon="@Icons.Material.Filled.Language"
                     Style="color:white;"
                     Direction="Direction.Left" OffsetX="true" Dense="true">
                @foreach (var lang in _languages)
                {
                    <MudMenuItem OnClick="@(async () => await ChangeLanguage(lang.Code))">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@(lang.Code == _selectedLanguage
                                           ? Icons.Material.Filled.Check
                                           : Icons.Material.Filled.Translate)"
                                     Color="@(lang.Code == _selectedLanguage
                                             ? Color.Primary : Color.Default)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.body2">@lang.Name</MudText>
                        </div>
                    </MudMenuItem>
                }
            </MudMenu>
            <div class="appbar-icon-btn">
                <MudIcon Icon="@Icons.Material.Filled.Notifications"
                         Style="color:white; font-size:1.2rem;" />
            </div>
        </div>
    </MudAppBar>

    <MudMainContent Style="background:#f0f7ff; min-height:100vh; padding-bottom:80px;">

        <!-- ── Search Bar ── -->
        <div class="px-4 pt-3 pb-2">
            <MudPaper Elevation="2"
                      Class="d-flex align-center px-3 py-2 rounded-xl gap-2"
                      Style="border:0.5px solid rgba(14,110,184,0.15);">
                <MudIcon Icon="@Icons.Material.Filled.Search"
                         Style="color:#0e6eb8; font-size:1.1rem;" />
                <MudText Typo="Typo.body2" Style="color:#aaa; flex:1;">
                    Tìm địa điểm...
                </MudText>
                <div style="width:28px;height:28px;background:rgba(14,110,184,0.08);
                            border-radius:8px;display:flex;align-items:center;justify-content:center;">
                    <MudIcon Icon="@Icons.Material.Filled.Tune"
                             Style="color:#0e6eb8; font-size:1rem;" />
                </div>
            </MudPaper>
        </div>

        <!-- ── Categories ── -->
        <div class="px-4 pb-2">
            <MudText Typo="Typo.subtitle2"
                     Style="font-weight:600; color:#0a3050; margin-bottom:8px;">
                Danh mục
            </MudText>
            <div class="d-flex gap-2 overflow-auto no-scrollbar pb-1">
                <div class="@(_selectedCategoryId == 0 ? "cat-chip cat-chip-active" : "cat-chip cat-chip-inactive")"
                     @onclick="@(() => FilterByCategory(0))">
                    <MudIcon Icon="@Icons.Material.Filled.Dashboard"
                             Style="font-size:0.75rem;" />
                    Tất cả
                </div>
                @foreach (var cat in _categories)
                {
                    var catId   = cat.Id;
                    var catIcon = _categoryIcons[_categories.IndexOf(cat) % _categoryIcons.Length];
                    <div class="@(_selectedCategoryId == catId ? "cat-chip cat-chip-active" : "cat-chip cat-chip-inactive")"
                         @onclick="@(() => FilterByCategory(catId))">
                        <MudIcon Icon="@catIcon" Style="font-size:0.75rem;" />
                        @LanguageService.T(cat.Name)
                    </div>
                }
            </div>
        </div>

        <!-- ── Location Filter ── -->
        <div class="px-4 pb-2">
            <MudPaper Elevation="0"
                      Class="d-flex align-center px-3 py-2 rounded-xl gap-2"
                      Style="background:white; border:0.5px solid rgba(14,110,184,0.1);">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation"
                         Style="@($"color:{(_locationActive ? "#0e6eb8" : "#bbb")}; font-size:1rem;")" />
                <MudText Typo="Typo.caption"
                         Style="font-weight:500; color:#0a3050; flex:1;">
                    @LanguageService.T("FindAround")
                </MudText>
                <MudSelect T="double?" Value="_selectedRadius"
                           ValueChanged="OnRadiusChanged"
                           Dense="true" Margin="Margin.Dense"
                           Variant="Variant.Text"
                           Style="width:100px; font-size:0.75rem;">
                    <MudSelectItem T="double?" Value="@((double?)null)">Tất cả</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(500.0)">500 m</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(1000.0)">1.0 km</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(2000.0)">2.0 km</MudSelectItem>
                    <MudSelectItem T="double?" Value="@(5000.0)">5.0 km</MudSelectItem>
                </MudSelect>
                @if (_locationActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small" Color="Color.Error"
                                   OnClick="DisableLocation" />
                }
            </MudPaper>
        </div>

        <!-- ── Auto-play Toggle ── -->
        <div class="px-4 pb-3">
            <MudPaper Elevation="0"
                      Class="d-flex align-center px-3 py-2 rounded-xl gap-3"
                      Style="background:white; border:0.5px solid rgba(14,110,184,0.1);">
                <div class="autoplay-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.AutoMode"
                             Style="@($"color:{(GeofenceService.IsAutoPlayEnabled ? "#0e6eb8" : "#bbb")}; font-size:1.1rem;")" />
                </div>
                <div style="flex:1;">
                    <MudText Typo="Typo.body2"
                             Style="font-weight:600; color:#0a3050; line-height:1.2;">
                        @LanguageService.T("AutoPlayTitle")
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#aaa;">
                        @LanguageService.T("AutoPlayDesc")
                    </MudText>
                </div>
                <MudSwitch T="bool"
                           Value="GeofenceService.IsAutoPlayEnabled"
                           ValueChanged="@((v) => GeofenceService.ToggleAutoPlay(v))"
                           Color="Color.Primary" />
            </MudPaper>
        </div>

        <!-- ── Featured POIs ── -->
        <div class="px-4">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.subtitle2"
                         Style="font-weight:600; color:#0a3050;">
                    @LanguageService.T("Featured")
                </MudText>
                <MudLink Typo="Typo.caption" Style="color:#0e6eb8;" Href="#">
                    @LanguageService.T("SeeAll") →
                </MudLink>
            </div>

            @if (_loadingPois && _pois.Count == 0)
            {
                <div class="d-flex justify-center py-8">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </div>
            }
            else if (_pois.Any())
            {
                @if (_featuredPoi != null)
                {
                    <MudPaper Elevation="3" Class="rounded-xl overflow-hidden mb-3"
                              Style="cursor:pointer; border:0.5px solid rgba(14,110,184,0.1);"
                              @onclick="@(() => NavigationManager.NavigateTo($"/poi-details/{_featuredPoi.Id}"))">
                        <div class="featured-img-wrap"
                             style="@(string.IsNullOrEmpty(GetThumb(_featuredPoi))
                                 ? "background:linear-gradient(135deg,#0e6eb8,#1a9de8);"
                                 : $"background:url('{GetThumb(_featuredPoi)}') center/cover no-repeat;")">
                            <div class="featured-overlay">
                                <div>
                                    <MudText Style="font-size:1rem; font-weight:700; color:white;">
                                        @_featuredPoi.Name
                                    </MudText>
                                    <div class="d-flex align-center gap-1 mt-1">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn"
                                                 Style="font-size:0.75rem; color:rgba(255,255,255,0.8);" />
                                        <MudText Typo="Typo.caption"
                                                 Style="color:rgba(255,255,255,0.8);">
                                            @(_featuredPoi.Category?.Name ?? "Địa điểm")
                                        </MudText>
                                    </div>
                                </div>
                            </div>
                            <div class="featured-badge">⭐ Nổi bật</div>
                        </div>
                        <div class="d-flex align-center justify-space-between px-3 py-2">
                            <MudText Typo="Typo.caption" Style="color:#888;">
                                Đang mở cửa
                            </MudText>
                            <div class="detail-chip">Chi tiết</div>
                        </div>
                    </MudPaper>
                }

                <MudGrid Spacing="2">
                    @foreach (var poi in _restPois)
                    {
                        <MudItem xs="6">
                            <MudPaper Elevation="2" Class="rounded-xl overflow-hidden"
                                      Style="cursor:pointer; border:0.5px solid rgba(14,110,184,0.08);"
                                      @onclick="@(() => NavigationManager.NavigateTo($"/poi-details/{poi.Id}"))">
                                <div class="grid-img-wrap"
                                     style="@(string.IsNullOrEmpty(GetThumb(poi))
                                         ? "background:linear-gradient(135deg,#0e6eb8,#1a9de8);"
                                         : $"background:url('{GetThumb(poi)}') center/cover no-repeat;")">
                                    <div class="grid-overlay">
                                        <MudText Style="font-size:0.8rem; font-weight:600; color:white;">
                                            @poi.Name
                                        </MudText>
                                    </div>
                                </div>
                                <div class="px-2 py-2">
                                    <div class="d-flex align-center gap-1 mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn"
                                                 Style="font-size:0.7rem; color:#0e6eb8;" />
                                        <MudText Typo="Typo.caption" Style="color:#888;">
                                            @(poi.Category?.Name ?? "Địa điểm")
                                        </MudText>
                                    </div>
                                    <div class="detail-chip-sm">Chi tiết</div>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>

                @if (_hasMore)
                {
                    <div class="d-flex justify-center mt-4">
                        <MudButton Variant="Variant.Outlined"
                                   Style="color:#0e6eb8; border-color:#0e6eb8; border-radius:24px;"
                                   FullWidth="true" OnClick="LoadMore"
                                   Disabled="_loadingPois">
                            @if (_loadingPois)
                            {
                                <MudProgressCircular Size="Size.Small"
                                                     Indeterminate="true" Class="mr-2" />
                            }
                            @LanguageService.T("SeeAll")
                        </MudButton>
                    </div>
                }
            }
            else
            {
                <div class="d-flex flex-column align-center py-10 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOff"
                             Style="font-size:3.5rem; color:rgba(14,110,184,0.15);" />
                    <MudText Typo="Typo.subtitle1" Class="mt-3 mb-1"
                             Style="font-weight:600; color:#0a3050;">
                        Không tìm thấy địa điểm
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Style="background:#0e6eb8; color:white; border-radius:24px; margin-top:12px;"
                               OnClick="ResetFilters">
                        Xem tất cả
                    </MudButton>
                </div>
            }
        </div>

        <!-- ── Audio Banner ── -->
        @if (GeofenceService.BannerVisible && GeofenceService.CurrentPoi != null)
        {
            <div class="audio-banner mx-4 mt-4">
                <div class="d-flex align-center gap-3">
                    <div class="audio-icon-wrap">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn"
                                 Style="color:white; font-size:1rem;" />
                    </div>
                    <div style="flex:1;">
                        <MudText Typo="Typo.caption"
                                 Style="color:rgba(255,255,255,0.75);">
                            📍 Bạn đang ở gần
                        </MudText>
                        <MudText Style="font-size:0.9rem; font-weight:600; color:white;">
                            @GeofenceService.CurrentPoi.Name
                        </MudText>
                    </div>
                    <div class="d-flex gap-2">
                        @if (GeofenceService.IsAudioPlaying)
                        {
                            <div class="audio-ctrl-btn" @onclick="PauseAudio">
                                <MudIcon Icon="@Icons.Material.Filled.Pause"
                                         Style="color:white; font-size:1rem;" />
                            </div>
                        }
                        else
                        {
                            <div class="audio-ctrl-btn" @onclick="ResumeAudio">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow"
                                         Style="color:white; font-size:1rem;" />
                            </div>
                        }
                        <div class="audio-ctrl-btn" @onclick="ReplayAudio">
                            <MudIcon Icon="@Icons.Material.Filled.Replay"
                                     Style="color:white; font-size:1rem;" />
                        </div>
                        <div class="audio-ctrl-btn"
                             @onclick="@(() => GeofenceService.CloseBanner())">
                            <MudIcon Icon="@Icons.Material.Filled.Close"
                                     Style="color:white; font-size:1rem;" />
                        </div>
                    </div>
                </div>
            </div>
        }

        <MudText Typo="Typo.caption" Align="Align.Center"
                 Class="mt-6 mb-2 d-block"
                 Style="@($"color:#bbb; {(!_hasMore ? "" : "display:none!important")}")">
            @LanguageService.T("EndList")
        </MudText>

    </MudMainContent>

    <audio id="geofence-audio-player" hidden></audio>

    <!-- ── Bottom Navigation ── -->
    <MudPaper Elevation="8" Class="py-2"
              Style="position:fixed; bottom:0; width:100%;
                     border-top-left-radius:20px; border-top-right-radius:20px;
                     background:rgba(255,255,255,0.92);
                     backdrop-filter:blur(16px);
                     border-top:0.5px solid rgba(14,110,184,0.12);
                     z-index:999;">
        <div class="d-flex justify-space-around">
            <div class="d-flex flex-column align-center" style="min-width:60px;">
                <div class="nav-icon-active">
                    <MudIcon Icon="@Icons.Material.Filled.Home"
                             Style="color:#0e6eb8; font-size:1.2rem;" />
                </div>
                <MudText Typo="Typo.caption"
                         Style="color:#0e6eb8; font-weight:600; font-size:0.65rem;">
                    @LanguageService.T("Home")
                </MudText>
            </div>
            <div class="d-flex flex-column align-center nav-item"
                 style="min-width:60px;"
                 @onclick="@(() => NavigationManager.NavigateTo("/map"))">
                <MudIcon Icon="@Icons.Material.Filled.Map"
                         Style="color:#bbb; font-size:1.3rem;" />
                <MudText Typo="Typo.caption" Style="color:#bbb; font-size:0.65rem;">
                    @LanguageService.T("Map")
                </MudText>
            </div>
            <div class="d-flex flex-column align-center nav-item"
                 style="min-width:60px;"
                 @onclick="@(() => NavigationManager.NavigateTo("/profile"))">
                <MudIcon Icon="@Icons.Material.Filled.Person"
                         Style="color:#bbb; font-size:1.3rem;" />
                <MudText Typo="Typo.caption" Style="color:#bbb; font-size:0.65rem;">
                    @LanguageService.T("Profile")
                </MudText>
            </div>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex flex-column align-center nav-item"
                         style="min-width:60px;" @onclick="Logout">
                        <MudIcon Icon="@Icons.Material.Filled.Logout"
                                 Style="color:#bbb; font-size:1.3rem;" />
                        <MudText Typo="Typo.caption" Style="color:#bbb; font-size:0.65rem;">
                            @LanguageService.T("Logout")
                        </MudText>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="d-flex flex-column align-center nav-item"
                         style="min-width:60px;" @onclick="NavigateToLogin">
                        <MudIcon Icon="@Icons.Material.Filled.Login"
                                 Style="color:#bbb; font-size:1.3rem;" />
                        <MudText Typo="Typo.caption" Style="color:#bbb; font-size:0.65rem;">
                            @LanguageService.T("Login")
                        </MudText>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </MudPaper>
</MudLayout>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    .appbar-icon-btn {
        width: 32px; height: 32px; border-radius: 10px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
    }

    .cat-chip {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 6px 14px; border-radius: 20px;
        font-size: 0.78rem; font-weight: 500;
        white-space: nowrap; cursor: pointer; transition: all 0.2s;
    }
    .cat-chip-active  { background: #0e6eb8; color: white; }
    .cat-chip-inactive {
        background: rgba(14,110,184,0.08); color: #0e6eb8;
        border: 1px solid rgba(14,110,184,0.2);
    }

    .autoplay-icon-wrap {
        width: 36px; height: 36px; border-radius: 10px;
        background: rgba(14,110,184,0.08);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .featured-img-wrap { height: 160px; position: relative; }
    .featured-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
        display: flex; align-items: flex-end; padding: 14px;
    }
    .featured-badge {
        background: rgba(255,255,255,0.2); backdrop-filter: blur(4px);
        color: white; font-size: 0.7rem; padding: 3px 10px; border-radius: 8px;
        position: absolute; top: 10px; right: 10px;
    }
    .detail-chip {
        background: rgba(14,110,184,0.08); color: #0e6eb8;
        font-size: 0.75rem; font-weight: 500;
        padding: 4px 14px; border-radius: 10px; display: inline-block;
    }

    .grid-img-wrap { height: 90px; position: relative; }
    .grid-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
        display: flex; align-items: flex-end; padding: 8px;
    }
    .detail-chip-sm {
        background: #0e6eb8; color: white;
        font-size: 0.7rem; font-weight: 500;
        padding: 4px 12px; border-radius: 8px;
        display: inline-block; text-align: center; width: 100%;
    }

    .audio-banner {
        background: linear-gradient(135deg,#0e6eb8,#1a9de8);
        border-radius: 16px; padding: 12px 14px;
        animation: slideUp 0.3s ease-out;
    }
    .audio-icon-wrap {
        width: 38px; height: 38px; border-radius: 12px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .audio-ctrl-btn {
        width: 30px; height: 30px; border-radius: 8px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center; cursor: pointer;
    }
    .audio-ctrl-btn:active { background: rgba(255,255,255,0.35); }

    .nav-item { cursor: pointer; transition: opacity 0.2s; }
    .nav-item:active { opacity: 0.6; }
    .nav-icon-active {
        width: 36px; height: 36px; border-radius: 10px;
        background: rgba(14,110,184,0.1);
        display: flex; align-items: center; justify-content: center;
    }

    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; }

    private string         _userName          = "Guest";
    private List<Category> _categories        = new();
    private List<Poi>      _pois              = new();
    private List<Language> _languages         = new();
    private string         _selectedLanguage  = "vi";
    private bool           _loadingPois       = true;
    private int            _selectedCategoryId = 0;
    private int            _currentPage       = 1;
    private const int      _pageSize          = 6;
    private bool           _hasMore           = false;
    private double?        _userLat;
    private double?        _userLng;
    private double?        _selectedRadius;
    private bool           _locationActive    = false;
    private DotNetObjectReference<GeofenceAudioService>? _dotNetRef;

    private readonly string[] _categoryIcons =
    {
        Icons.Material.Filled.AccountBalance,
        Icons.Material.Filled.Restaurant,
        Icons.Material.Filled.Hotel,
        Icons.Material.Filled.Nature,
        Icons.Material.Filled.LocalCafe
    };

    // ── Computed ─────────────────────────────────────────────────────────

    private Poi? _featuredPoi =>
        _pois.FirstOrDefault(p => p.IsFeature) ?? _pois.FirstOrDefault();

    private List<Poi> _restPois =>
        _featuredPoi == null
            ? _pois
            : _pois.Where(p => p.Id != _featuredPoi.Id).ToList();

    private string GetThumb(Poi poi) =>
        poi.Images?.FirstOrDefault(x => x.IsThumbnail)?.ImageUrl
        ?? poi.Images?.FirstOrDefault()?.ImageUrl
        ?? "";

    // ── Lifecycle ────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateTask;
            _userName         = authState.User.Identity?.Name ?? "Guest";
            _selectedLanguage = LanguageService.SelectedLanguage;

            GeofenceService.AudioTriggered     += OnGeofenceAudioTriggered;
            GeofenceService.BannerStateChanged += OnBannerStateChanged;

            await Task.WhenAll(LoadCategories(), RefreshList(), LoadLanguages());

            _dotNetRef = DotNetObjectReference.Create(GeofenceService);
            await JS.InvokeVoidAsync("audioHelper.setDotNetReference", _dotNetRef);
            await GeofenceService.StartAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi khởi tạo: " + ex.Message, Severity.Error);
        }
    }

    // ── Audio ─────────────────────────────────────────────────────────────

    private async Task OnGeofenceAudioTriggered(PoiGeofenceDto poi, PoiAudioFile audio)
        => await JS.InvokeVoidAsync("audioHelper.play", audio.FileUrl);

    private void OnBannerStateChanged() => InvokeAsync(StateHasChanged);

    private async Task PauseAudio()
    {
        await JS.InvokeVoidAsync("audioHelper.pause");
        GeofenceService.SetAudioPlaying(false);
    }

    private async Task ResumeAudio()
    {
        await JS.InvokeVoidAsync("audioHelper.resume");
        GeofenceService.SetAudioPlaying(true);
    }

    private async Task ReplayAudio()
    {
        if (GeofenceService.CurrentPoi != null)
            await GeofenceService.PlayManualAsync(
                GeofenceService.CurrentPoi, LanguageService.SelectedLanguage);
    }

    // ── Data ─────────────────────────────────────────────────────────────

    private async Task LoadCategories()
    {
        try
        {
            _categories = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải danh mục: " + ex.Message, Severity.Error);
        }
    }

    private async Task LoadLanguages()
    {
        try { _languages = await Http.GetFromJsonAsync<List<Language>>("api/languages") ?? new(); }
        catch { }
    }

    private async Task RefreshList()
    {
        _currentPage = 1;
        _pois.Clear();
        await LoadPois();
    }

    private async Task LoadPois()
    {
        if (_loadingPois && _currentPage > 1) return;
        _loadingPois = true;
        try
        {
            var q = new List<string>
            {
                $"pageNumber={_currentPage}",
                $"pageSize={_pageSize}"
            };
            if (_selectedCategoryId > 0)
                q.Add($"categoryId={_selectedCategoryId}");
            if (_locationActive && _userLat.HasValue && _userLng.HasValue && _selectedRadius.HasValue)
            {
                q.Add($"lat={_userLat}");
                q.Add($"lng={_userLng}");
                q.Add($"radius={_selectedRadius}");
            }
            var resp = await Http.GetFromJsonAsync<PagedResponse<Poi>>(
                $"api/pois?{string.Join("&", q)}");
            if (resp != null)
            {
                if (_currentPage == 1) _pois = resp.Items.ToList();
                else _pois.AddRange(resp.Items);
                _hasMore = _pois.Count < resp.TotalCount;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải địa điểm: " + ex.Message, Severity.Error);
        }
        finally { _loadingPois = false; }
    }

    private async Task LoadMore()
    {
        if (!_hasMore || _loadingPois) return;
        _currentPage++;
        await LoadPois();
    }

    private async Task FilterByCategory(int id)
    {
        if (_selectedCategoryId == id) return;
        _selectedCategoryId = id;
        await RefreshList();
    }

    private async Task OnRadiusChanged(double? radius)
    {
        _selectedRadius = radius;
        if (radius.HasValue) await GetCurrentLocation();
        else { _locationActive = false; await RefreshList(); }
    }

    private async Task GetCurrentLocation()
    {
        try
        {
            var loc = await Geolocation.Default.GetLocationAsync(
                new GeolocationRequest(GeolocationAccuracy.Medium, TimeSpan.FromSeconds(10)));
            if (loc != null)
            {
                _userLat = loc.Latitude;
                _userLng = loc.Longitude;
                _locationActive = true;
                await RefreshList();
            }
        }
        catch { _selectedRadius = null; _locationActive = false; }
    }

    private async Task DisableLocation()
    {
        _locationActive = false;
        _selectedRadius = null;
        await RefreshList();
    }

    private async Task ResetFilters()
    {
        _selectedCategoryId = 0;
        _selectedRadius     = null;
        _locationActive     = false;
        await RefreshList();
    }

    private async Task ChangeLanguage(string code)
    {
        _selectedLanguage = code;
        LanguageService.SetLanguage(code);
        if (GeofenceService.BannerVisible && GeofenceService.CurrentPoi != null)
        {
            var audio = GeofenceService.CurrentPoi.AudioFiles
                .FirstOrDefault(a => a.LanguageCode == code)
                ?? GeofenceService.CurrentPoi.AudioFiles.FirstOrDefault();
            if (audio != null)
            {
                var t = 0.0;
                try { t = await JS.InvokeAsync<double>("audioHelper.getCurrentTime"); } catch { }
                await JS.InvokeVoidAsync("audioHelper.playAtTime", audio.FileUrl, t < 10 ? 0 : t);
                GeofenceService.SetAudioPlaying(true);
                return;
            }
        }
        Snackbar.Add($"Đã chuyển: {code.ToUpper()}", Severity.Info);
    }

    private void Logout()
    {
        var auth = (MobileAuthStateProvider)AuthStateProvider;
        auth.MarkUserAsLoggedOut();
        NavigationManager.NavigateTo("/login");
    }

    private void NavigateToLogin() => NavigationManager.NavigateTo("/login");

    public async ValueTask DisposeAsync()
    {
        GeofenceService.AudioTriggered     -= OnGeofenceAudioTriggered;
        GeofenceService.BannerStateChanged -= OnBannerStateChanged;
        await GeofenceService.StopAsync();
        _dotNetRef?.Dispose();
    }
}