@page "/poi-details/{Id:int}"
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.Devices
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject LanguageService LanguageService
@inject IJSRuntime JS

<div class="poi-detail-container">
    @if (_loading)
    {
        <div class="d-flex justify-center align-center" style="height: 100vh;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (_poi == null)
    {
        <div class="d-flex flex-column justify-center align-center" style="height: 100vh;">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Style="font-size: 5rem;" />
            <MudText Typo="Typo.h5" Class="mt-4">Không tìm thấy địa điểm</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack" Class="mt-4">Quay lại</MudButton>
        </div>
    }
    else
    {
        <!-- Hero Image Section -->
        <div class="hero-section">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" 
                           Color="Color.Inherit" 
                           OnClick="GoBack" 
                           Class="back-button" />
            
            <MudCarousel Class="mud-width-full hero-carousel" 
                         Style="height: 350px;" 
                         ShowArrows="true" 
                         ShowBullets="true" 
                         AutoCycle="true" 
                         TData="string">
                @if (_poi.Images.Any())
                {
                    foreach (var img in _poi.Images.OrderByDescending(i => i.IsThumbnail).ThenBy(i => i.SortOrder))
                    {
                        <MudCarouselItem Transition="Transition.Fade">
                            <div class="d-flex" style="height:100%">
                                <MudImage Src="@img.ImageUrl" Alt="@_poi.Name" ObjectFit="ObjectFit.Cover" Class="mx-auto my-auto mud-width-full" />
                            </div>
                        </MudCarouselItem>
                    }
                }
                else
                {
                    <MudCarouselItem Transition="Transition.Fade">
                        <div class="d-flex" style="height:100%">
                            <MudImage Src="https://via.placeholder.com/800x400?text=No+Image" Alt="No Image" ObjectFit="ObjectFit.Cover" Class="mx-auto my-auto mud-width-full" />
                        </div>
                    </MudCarouselItem>
                }
            </MudCarousel>
            
            <div class="hero-overlay">
                <MudText Typo="Typo.h4" Class="poi-title">@_poi.Name</MudText>
                <div class="d-flex align-center gap-2 mt-1">
                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Category">@(_poi.Category?.Name ?? LanguageService.T("Place"))</MudChip>
                    <div class="d-flex align-center rating-badge">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Style="color: white; font-weight: bold; margin-left: 2px;">4.8</MudText>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-section pa-4">
            <!-- Action Quick Buttons -->
            <div class="d-flex justify-space-around mb-8 action-bar">
                <div class="action-item" @onclick="NavigateToMap">
                    <div class="icon-circle primary">
                        <MudIcon Icon="@Icons.Material.Filled.Directions" />
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">@(LanguageService.SelectedLanguage == "en" ? "Direction" : "Dẫn đường")</MudText>
                </div>
                <div class="action-item" @onclick="StartVoiceGuide">
                    <div class="icon-circle secondary">
                        <MudIcon Icon="@Icons.Material.Filled.Headset" />
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">@(LanguageService.SelectedLanguage == "en" ? "Audio" : "Thuyết minh")</MudText>
                </div>
                <div class="action-item">
                    <div class="icon-circle success">
                        <MudIcon Icon="@Icons.Material.Filled.Share" />
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">@(LanguageService.SelectedLanguage == "en" ? "Share" : "Chia sẻ")</MudText>
                </div>
                <div class="action-item">
                    <div class="icon-circle info">
                        <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" />
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">@(LanguageService.SelectedLanguage == "en" ? "Favorite" : "Yêu thích")</MudText>
                </div>
            </div>

            <!-- Description Section -->
            <div class="detail-section mb-6">
                <div class="d-flex align-center mb-3">
                    <div class="section-indicator mr-2"></div>
                    <MudText Typo="Typo.h6" Style="font-weight: bold;">@LanguageService.T("Introduction")</MudText>
                </div>
                <MudText Typo="Typo.body1" Class="description-text">
                    @(_poi.Contents.FirstOrDefault(c => c.LanguageCode == LanguageService.SelectedLanguage)?.Description 
                              ?? _poi.Contents.FirstOrDefault(c => c.LanguageCode == "vi")?.Description 
                              ?? _poi.Contents.FirstOrDefault()?.Description 
                              ?? LanguageService.T("Updating"))
                </MudText>
            </div>

            <MudDivider Class="my-6" Style="opacity: 0.5" />

            <!-- Working Hours Section -->
            @if (_poi.OperatingHours.Any())
            {
                <div class="detail-section mb-6">
                    <div class="d-flex align-center mb-4">
                        <div class="section-indicator mr-2"></div>
                        <MudText Typo="Typo.h6" Style="font-weight: bold;">@LanguageService.T("OpeningHours")</MudText>
                    </div>
                    
                    <div class="hours-container pa-3 rounded-lg">
                        @foreach (var hour in _poi.OperatingHours.OrderBy(h => h.DayOfWeek))
                        {
                            <div class="d-flex justify-space-between py-2 align-center @(IsToday(hour.DayOfWeek) ? "current-day-row pa-2 rounded" : "")">
                                <MudText Typo="Typo.body2" Style="@(IsToday(hour.DayOfWeek) ? "font-weight: bold; color: var(--mud-palette-primary);" : "color: #666;")">
                                    @GetVietnameseDay(hour.DayOfWeek)
                                </MudText>
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="Color.Default" Class="mr-1" Style="font-size: 0.9rem;" />
                                    <MudText Typo="Typo.body2" Style="@(IsToday(hour.DayOfWeek) ? "font-weight: bold;" : "")">
                                        @hour.OpenTime?.ToString(@"hh\:mm") - @hour.CloseTime?.ToString(@"hh\:mm")
                                    </MudText>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <MudDivider Class="my-6" Style="opacity: 0.5" />
            }

            <!-- Location Section -->
            <div class="detail-section mb-6">
                <div class="d-flex align-center mb-4">
                    <div class="section-indicator mr-2"></div>
                    <MudText Typo="Typo.h6" Style="font-weight: bold;">@LanguageService.T("Location")</MudText>
                </div>
                <div class="location-card pa-4 rounded-xl d-flex align-center gap-3" @onclick="NavigateToMap">
                    <div class="location-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Error" />
                    </div>
                    <div class="flex-grow-1">
                        <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">@LanguageService.T("ViewOnMap")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@LanguageService.T("Coordinates"): @_poi.Latitude, @_poi.Longitude</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                </div>
            </div>

            <!-- Audio Player Overlay -->
            @if (_showAudioPlayer && _currentAudio != null)
            {
                <MudPaper Elevation="8" Class="audio-player-card pa-4 animate-slide-up">
                    <div class="d-flex align-center justify-space-between mb-2">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.GraphicEq" Color="Color.Primary" Class="mr-2" />
                            <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">@(LanguageService.SelectedLanguage == "en" ? "Audio Guide" : "Thuyết minh tự động")</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _showAudioPlayer = false" />
                    </div>
                    <div class="d-flex align-center gap-4 mt-2">
                        <div class="play-btn-wrapper">
                            <MudIconButton Icon="@(_isPlaying ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)" 
                                           Color="Color.Primary" 
                                           Variant="Variant.Filled" 
                                           OnClick="ToggleAudio"
                                           Style="width: 50px; height: 50px;" />
                        </div>
                        <div class="flex-grow-1">
                            <MudProgressLinear Color="Color.Primary" Value="@_audioProgress" Class="rounded-pill" Style="height: 6px;" />
                            <div class="d-flex justify-space-between mt-1">
                                <MudText Typo="Typo.caption" Style="font-weight: 500;">@_currentTime</MudText>
                                <MudText Typo="Typo.caption" Style="color: #999;">@_duration</MudText>
                            </div>
                        </div>
                    </div>
                    <audio id="poi-audio-player" src="@_currentAudio.FileUrl" hidden></audio>
                </MudPaper>
            }

            <div style="height: 100px;"></div> <!-- Spacer for scrolling -->
        </div>

        <!-- Sticky Footer CTA -->
        <div class="sticky-footer">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       FullWidth="true" 
                       Size="Size.Large" 
                       StartIcon="@Icons.Material.Filled.Map"
                       OnClick="NavigateToMap"
                       Class="rounded-pill py-3 shadow-lg">
                @LanguageService.T("StartJourney")
            </MudButton>
        </div>
    }
</div>

<style>
    .poi-detail-container {
        background-color: #f8f9fa;
        min-height: 100vh;
        position: relative;
    }

    .hero-section {
        position: relative;
        height: 350px;
        overflow: hidden;
    }

    .back-button {
        position: absolute;
        top: 40px;
        left: 20px;
        z-index: 100;
        background-color: rgba(255,255,255,0.3);
        backdrop-filter: blur(5px);
        color: white;
    }

    .hero-carousel img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 40px 20px 20px 20px;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        color: white;
    }

    .poi-title {
        font-weight: 800;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .rating-badge {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(5px);
        padding: 2px 8px;
        border-radius: 12px;
    }

    .content-section {
        border-top-left-radius: 30px;
        border-top-right-radius: 30px;
        margin-top: -30px;
        background: white;
        position: relative;
        z-index: 10;
        box-shadow: 0 -10px 20px rgba(0,0,0,0.05);
    }

    .action-bar {
        text-align: center;
    }

    .action-item {
        cursor: pointer;
        transition: transform 0.2s;
    }

    .action-item:active {
        transform: scale(0.9);
    }

    .icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 5px auto;
        color: white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .icon-circle.primary { background: linear-gradient(135deg, #594AE2, #7D70F1); }
    .icon-circle.secondary { background: linear-gradient(135deg, #FF4081, #FF80AB); }
    .icon-circle.success { background: linear-gradient(135deg, #4CAF50, #81C784); }
    .icon-circle.info { background: linear-gradient(135deg, #2196F3, #64B5F6); }

    .description-text {
        color: #555;
        line-height: 1.6;
        text-align: justify;
    }

    .section-indicator {
        width: 4px;
        height: 20px;
        background-color: var(--mud-palette-primary);
        border-radius: 2px;
    }

    .hours-container {
        background-color: #fcfcfc;
        border: 1px solid #f0f0f0;
    }

    .current-day-row {
        background-color: rgba(var(--mud-palette-primary-rgb), 0.08);
    }

    .location-card {
        background: #f8f9fa;
        border: 1px solid #eee;
        cursor: pointer;
        transition: all 0.2s;
    }

    .location-card:active {
        transform: scale(0.98);
        background: #f0f0f0;
    }

    .location-icon-box {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .audio-player-card {
        position: fixed;
        bottom: 100px;
        left: 20px;
        right: 20px;
        z-index: 1000;
        border-radius: 20px;
        background: rgba(255,255,255,0.98);
        backdrop-filter: blur(15px);
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.1);
    }

    .play-btn-wrapper .mud-button-root {
        box-shadow: 0 4px 15px rgba(var(--mud-palette-primary-rgb), 0.4);
    }

    .animate-slide-up {
        animation: slideUp 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .fw-bold { font-weight: bold; }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private Poi? _poi;
    private bool _loading = true;
    private bool _showAudioPlayer = false;
    private bool _isPlaying = false;
    private double _audioProgress = 0;
    private string _currentTime = "0:00";
    private string _duration = "0:00";
    private PoiAudioFile? _currentAudio;

    protected override async Task OnInitializedAsync()
    {
        await LoadPoi();
    }

    private async Task LoadPoi()
    {
        _loading = true;
        try
        {
            _poi = await Http.GetFromJsonAsync<Poi>($"api/pois/{Id}");
            if (_poi != null)
            {
                _currentAudio = _poi.AudioFiles.FirstOrDefault(a => a.LanguageCode == LanguageService.SelectedLanguage) 
                                ?? _poi.AudioFiles.FirstOrDefault(a => a.LanguageCode == "vi")
                                ?? _poi.AudioFiles.FirstOrDefault();
                if (_currentAudio != null)
                {
                    _duration = FormatTime(_currentAudio.DurationSeconds);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Không thể tải thông tin địa điểm: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private void NavigateToMap()
    {
        if (_poi == null) return;
        
        // Mở app bản đồ (Google Maps hoặc Apple Maps)
        var uri = $"https://www.google.com/maps/dir/?api=1&destination={_poi.Latitude},{_poi.Longitude}";
        Launcher.Default.OpenAsync(new Uri(uri));
    }

    private void StartVoiceGuide()
    {
        if (_currentAudio == null)
        {
            Snackbar.Add("Địa điểm này chưa có thuyết minh âm thanh.", Severity.Info);
            return;
        }
        _showAudioPlayer = true;
        // Logic phát âm thanh thực tế sẽ cần JSInterop để điều khiển thẻ <audio>
        // Hoặc sử dụng MAUI MediaElement (nhưng đây là Blazor view)
    }

    private async Task ToggleAudio()
    {
        _isPlaying = !_isPlaying;
        try 
        {
            if (_isPlaying)
            {
                await JS.InvokeVoidAsync("audioHelper.playById", "poi-audio-player");
                SimulateProgress();
            }
            else
            {
                await JS.InvokeVoidAsync("audioHelper.pauseById", "poi-audio-player");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi phát âm thanh: " + ex.Message, Severity.Error);
            _isPlaying = false;
        }
    }

    private async void SimulateProgress()
    {
        while (_isPlaying && _audioProgress < 100)
        {
            _audioProgress += 1;
            StateHasChanged();
            await Task.Delay(1000);
        }
        if (_audioProgress >= 100)
        {
            _isPlaying = false;
            _audioProgress = 0;
            StateHasChanged();
        }
    }

    private string FormatTime(double seconds)
    {
        var t = TimeSpan.FromSeconds(seconds);
        return $"{(int)t.TotalMinutes}:{t.Seconds:D2}";
    }

    private bool IsToday(DayOfWeek day) => DateTime.Today.DayOfWeek == day;

    private string GetVietnameseDay(DayOfWeek day)
    {
        if (LanguageService.SelectedLanguage == "en") return day.ToString();

        return day switch
        {
            DayOfWeek.Monday => "Thứ 2",
            DayOfWeek.Tuesday => "Thứ 3",
            DayOfWeek.Wednesday => "Thứ 4",
            DayOfWeek.Thursday => "Thứ 5",
            DayOfWeek.Friday => "Thứ 6",
            DayOfWeek.Saturday => "Thứ 7",
            DayOfWeek.Sunday => "Chủ Nhật",
            _ => day.ToString()
        };
    }
}
