@page "/poi-details/{Id:int}"
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.Devices
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject LanguageService LanguageService
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject SmartTour.Mobile.Services.OfflineSyncService SyncService
@inject SmartTour.Mobile.Services.MediaCacheService MediaCache
@inject SmartTour.Mobile.Services.GeofenceAudioService GeofenceService
@implements IDisposable

<div class="poi-detail-container">
    @if (_loading)
    {
            <div class="d-flex justify-center align-center" style="height: 100vh;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </div>
    }
    else if (_poi == null)
    {
            <div class="d-flex flex-column justify-center align-center" style="height: 100vh;">
                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Style="font-size: 5rem;" />
                <MudText Typo="Typo.h5" Class="mt-4">@LanguageService.T("NoResults")</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack" Class="mt-4">@LanguageService.T("SeeAll")</MudButton>
            </div>
    }
    else
    {
            <!-- Hero Image Section -->
            <div class="hero-section">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" 
                               OnClick="GoBack" 
                               Class="back-button glass-btn" />

                <MudCarousel Class="mud-width-full hero-carousel" 
                             Style="height: 350px;" 
                             ShowArrows="true" 
                             ShowBullets="true" 
                             AutoCycle="true" 
                             TData="string">
                @if (_poi.Images.Any())
                {
                    foreach (var img in _poi.Images.OrderByDescending(i => i.IsThumbnail).ThenBy(i => i.SortOrder))
                    {
                                    <MudCarouselItem Transition="Transition.Fade">
                                        <div class="d-flex" style="height:100%">
                                            <MudImage Src="@img.ImageUrl" Alt="@_poi.Name" ObjectFit="ObjectFit.Cover" Class="mx-auto my-auto mud-width-full" />
                                        </div>
                                    </MudCarouselItem>
                    }
                }
                else
                {
                            <MudCarouselItem Transition="Transition.Fade">
                                <div class="d-flex" style="height:100%">
                                    <MudImage Src="https://via.placeholder.com/800x400?text=No+Image" Alt="No Image" ObjectFit="ObjectFit.Cover" Class="mx-auto my-auto mud-width-full" />
                                </div>
                            </MudCarouselItem>
                }
                </MudCarousel>

                <div class="hero-overlay">
                    <MudText Typo="Typo.h4" Class="poi-title">@_poi.Name</MudText>
                    <div class="d-flex align-center gap-2 mt-1">
                        <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Category">@GetCategoryName(_poi)</MudChip>
                    </div>
                </div>
            </div>

            <div class="content-section pa-4">
                <!-- Action Quick Buttons -->
                 <div class="d-flex justify-space-around mb-8 action-bar">
                    <div class="action-item" @onclick="NavigateToMap">
                        <div class="icon-circle primary">
                            <MudIcon Icon="@Icons.Material.Filled.Directions" />
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-1">@LanguageService.T("Direction")</MudText>
                    </div>
                    <div class="action-item" @onclick="StartVoiceGuide">
                        <div class="icon-circle secondary">
                            <MudIcon Icon="@Icons.Material.Filled.Headset" />
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-1">@LanguageService.T("Audio")</MudText>
                    </div>
                    <div class="action-item">
                        <div class="icon-circle success">
                            <MudIcon Icon="@Icons.Material.Filled.Share" />
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-1">@LanguageService.T("Share")</MudText>
                    </div>
                    <div class="action-item" @onclick="ToggleFavorite">
                        <div class="icon-circle @(_isFavorite ? "favorite-active" : "info")">
                            <MudIcon Icon="@(_isFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Filled.FavoriteBorder)" />
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-1">@LanguageService.T("Favorite")</MudText>
                    </div>
                </div>

                <!-- Description Section -->
                <div class="detail-section mb-6">
                    <div class="d-flex align-center mb-3">
                        <div class="section-indicator mr-2"></div>
                        <MudText Typo="Typo.h6" Style="font-weight: bold;">@LanguageService.T("Introduction")</MudText>
                    </div>
                    <MudText Typo="Typo.body1" Class="description-text">
                    @(_poi.Contents.FirstOrDefault(c => c.LanguageCode == LanguageService.SelectedLanguage)?.Description
                                  ?? _poi.Contents.FirstOrDefault(c => c.LanguageCode == "vi")?.Description
                                  ?? _poi.Contents.FirstOrDefault()?.Description
                                  ?? LanguageService.T("Updating"))
                    </MudText>
                </div>

                <MudDivider Class="my-6" Style="opacity: 0.5" />

                <!-- Working Hours Section -->
            @if (_poi.OperatingHours.Any())
            {
                <div class="detail-section mb-6">
                    <div class="d-flex align-center mb-4">
                        <div class="section-indicator mr-2"></div>
                        <MudText Typo="Typo.h6" Style="font-weight: bold;">@LanguageService.T("OpeningHours")</MudText>
                    </div>

                    <div class="hours-container pa-3 rounded-lg">
                        @foreach (var hour in _poi.OperatingHours.OrderBy(h => h.DayOfWeek))
                        {
                            <div class="d-flex justify-space-between py-2 align-center @(IsToday(hour.DayOfWeek) ? "current-day-row pa-2 rounded" : "")">
                                <div class="d-flex align-center">
                                    @if (IsToday(hour.DayOfWeek))
                                    {
                                        <div class="pulse-dot"></div>
                                    }
                                    <MudText Typo="Typo.body2" Style="@(IsToday(hour.DayOfWeek) ? "font-weight: bold; color: #4CAF50;" : "color: #666;")">
                                        @GetTranslatedDay(hour.DayOfWeek)
                                        @(IsToday(hour.DayOfWeek) ? " - " + LanguageService.T("Open") : "")
                                    </MudText>
                                </div>
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="@(IsToday(hour.DayOfWeek) ? Color.Success : Color.Default)" Class="mr-1" Style="font-size: 0.9rem;" />
                                    <MudText Typo="Typo.body2" Style="@(IsToday(hour.DayOfWeek) ? "font-weight: bold; color: #4CAF50;" : "")">
                                        @hour.OpenTime?.ToString(@"hh\:mm") - @hour.CloseTime?.ToString(@"hh\:mm")
                                    </MudText>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <MudDivider Class="my-6" Style="opacity: 0.5" />
            }

            <!-- Audio Player Overlay -->
            @if (_showAudioPlayer && _currentAudio != null)
            {
                <MudPaper Elevation="12" Class="audio-player-card animate-slide-up pa-3">
                    <div class="d-flex align-center gap-2">
                        <div class="@(_isPlaying ? "geofence-pulse-dot" : "geofence-pause-dot")"></div>

                        <div class="flex-grow-1" style="min-width: 0;">
                            <MudText Typo="Typo.caption" Style="font-weight: bold; color: white; display:block; opacity: 0.9;">
                                @(_isPlaying ? LanguageService.T("BannerPlaying") : LanguageService.T("Audio"))
                            </MudText>
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.subtitle2" Style="color: white; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @_poi.Name
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.8); font-size: 0.7rem; margin-left: 8px;">
                                    @_currentTime / @_duration
                                </MudText>
                            </div>
                            <MudProgressLinear Color="Color.Inherit" Value="@_audioProgress" Class="rounded-pill mt-1" Style="height: 3px; color: rgba(255,255,255,0.7);" />
                        </div>

                        <div class="d-flex align-center gap-1" @onclick:stopPropagation="true">
                            <MudIconButton Icon="@(_isPlaying ? Icons.Material.Filled.Pause : Icons.Material.Filled.PlayArrow)"
                                           Size="Size.Small"
                                           Style="color: white; background: rgba(255,255,255,0.15); border-radius: 50%;"
                                           OnClick="ToggleAudio" />

                            <MudIconButton Icon="@Icons.Material.Filled.Replay"
                                           Size="Size.Small"
                                           Style="color: white; background: rgba(255,255,255,0.15); border-radius: 50%;"
                                           OnClick="ReplayAudio"
                                           Title="@LanguageService.T("Replay")" />

                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Style="color: white;"
                                           OnClick="CloseAudioPlayer" />
                        </div>
                    </div>
                    <audio id="poi-audio-player" src="@_currentAudio.FileUrl" @onended="OnAudioEnded" hidden></audio>
                </MudPaper>
            }

                <div style="height: 100px;"></div> <!-- Spacer for scrolling -->
            </div>
    }
</div>

<style>
    .poi-detail-container {
        background-color: #f8f9fa;
        min-height: 100vh;
        position: relative;
    }

    .hero-section {
        position: sticky;
        top: 0;
        height: 350px;
        z-index: 1;
    }

    .glass-btn {
        position: fixed;
        top: 50px;
        z-index: 1000;
        background-color: rgba(255,255,255,0.7) !important;
        backdrop-filter: blur(10px);
        color: #333 !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
    }

    .back-button { left: 20px; }

    .hero-carousel img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 40px 20px 20px 20px;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        color: white;
    }

    .poi-title {
        font-weight: 800;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .rating-badge {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(5px);
        padding: 2px 8px;
        border-radius: 12px;
    }

    .content-section {
        border-top-left-radius: 30px;
        border-top-right-radius: 30px;
        margin-top: -30px;
        background: white;
        position: relative;
        z-index: 10;
        box-shadow: 0 -15px 40px rgba(89, 74, 226, 0.12);
        min-height: 100vh;
    }

    .action-bar {
        text-align: center;
    }

    .action-item {
        cursor: pointer;
        transition: transform 0.2s;
    }

    .action-item:active {
        transform: scale(0.9);
    }

    .icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 6px auto;
        color: white;
        box-shadow: 0 8px 15px rgba(0,0,0,0.15);
    }

    .icon-circle.primary { background: linear-gradient(135deg, #594AE2, #7D70F1); }
    .icon-circle.secondary { background: linear-gradient(135deg, #FF4081, #FF80AB); }
    .icon-circle.success { background: linear-gradient(135deg, #4CAF50, #81C784); }
    .icon-circle.info { background: linear-gradient(135deg, #2196F3, #64B5F6); }
    .icon-circle.favorite-active { background: linear-gradient(135deg, #ff4d4d, #f92c2c); box-shadow: 0 4px 15px rgba(255, 77, 77, 0.4); }

    .description-text {
        color: #444;
        line-height: 1.7;
        text-align: justify;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        letter-spacing: 0.2px;
    }

    .section-indicator {
        width: 4px;
        height: 20px;
        background-color: var(--mud-palette-primary);
        border-radius: 2px;
    }

    .hours-container {
        background-color: #fcfcfc;
        border: 1px solid #f0f0f0;
    }

    .current-day-row {
        background-color: rgba(76, 175, 80, 0.08); /* Light green */
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background-color: #4CAF50;
        border-radius: 50%;
        box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7);
        animation: pulse 1.5s infinite;
        margin-right: 8px;
    }

    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(76, 175, 80, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(76, 175, 80, 0); }
    }

    .audio-player-card {
        position: fixed;
        bottom: 75px;
        left: 12px;
        right: 12px;
        z-index: 1100;
        border-radius: 16px;
        background: rgba(14, 110, 184, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 0.5px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 4px 15px rgba(14, 110, 184, 0.15);
    }

    .geofence-pulse-dot {
        width: 14px; height: 14px;
        border-radius: 50%;
        background: #fff;
        flex-shrink: 0;
        animation: pulseDot 1.4s ease-in-out infinite;
    }

    .geofence-pause-dot {
        width: 14px; height: 14px;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        flex-shrink: 0;
    }

    @@keyframes pulseDot {
        0%, 100% { transform: scale(1);   opacity: 1; }
        50%       { transform: scale(1.5); opacity: 0.6; }
    }



    .animate-slide-up {
        animation: slideUp 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .fw-bold { font-weight: bold; }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private Poi? _poi;
    private bool _loading = true;
    private bool _showAudioPlayer = false;
    private bool _isPlaying = false;
    private double _audioProgress = 0;
    private string _currentTime = "0:00";
    private string _duration = "0:00";
    private PoiAudioFile? _currentAudio;
    private bool _isFavorite = false;
    private int _userId = 0;
    private List<Category> _categories = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        int.TryParse(idClaim, out _userId);

        await LoadPoi();
        _ = LoadCategories();
        await CheckFavoriteStatus();
        LanguageService.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LanguageService.OnLanguageChanged -= StateHasChanged;
    }

    private async Task CheckFavoriteStatus()
    {
        if (_userId <= 0) return;
        try
        {
            _isFavorite = await SyncService.CheckFavoriteAsync(Id, _userId);
            StateHasChanged();
        }
        catch { }
    }

    private async Task LoadPoi()
    {
        _loading = true;
        try
        {
            var poi = await SyncService.GetPoiByIdAsync(Id, updatedPoi =>
            {
                if (updatedPoi != null && updatedPoi.Id != 0)
                {
                    _poi = updatedPoi;
                    PrepareAudioAndMedia();
                    InvokeAsync(StateHasChanged);
                }
            });

            // Gán ngay dữ liệu local (nếu có) để hiện nhanh
            if (poi != null && poi.Id != 0 && _poi == null)
            {
                _poi = poi;
                PrepareAudioAndMedia();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(LanguageService.T("LoadPoiError") + ": " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged(); // ← Đảm bảo spinner TẮT dù data đến từ callback hay local
        }
    }

    private async void PrepareAudioAndMedia()
    {
        if (_poi == null) return;
        
        _currentAudio = _poi.AudioFiles.FirstOrDefault(a => a.LanguageCode == LanguageService.SelectedLanguage)
                        ?? _poi.AudioFiles.FirstOrDefault(a => a.LanguageCode == "vi")
                        ?? _poi.AudioFiles.FirstOrDefault();
                        
        if (_currentAudio != null)
            _duration = FormatTime(_currentAudio.DurationSeconds);

        // THUẬT TOÁN ĐỈNH CAO: Bơm đường dẫn Base64 Tĩnh vào Thuộc tính URL khi đứt mạng 
        // Thay vì để trình duyệt Webview cố load HTTPS rồi lăn đùng ra chết
        try 
        {
            foreach (var img in _poi.Images)
            {
                if (!string.IsNullOrEmpty(img.ImageUrl) && img.ImageUrl.StartsWith("http"))
                    img.ImageUrl = await MediaCache.GetLocalMediaDataUriAsync(img.ImageUrl);
            }

            if (_currentAudio != null && !string.IsNullOrEmpty(_currentAudio.FileUrl) && _currentAudio.FileUrl.StartsWith("http"))
            {
                _currentAudio.FileUrl = await MediaCache.GetLocalMediaDataUriAsync(_currentAudio.FileUrl);
                
                // Nếu đang phát âm thanh mà đổi sang Base64, cần nạp lại audio Player
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private async Task NavigateToMap()
    {
        if (_poi == null) return;

        try
        {
            // Mở app bản đồ mặc định của thiết bị (Google Maps / Apple Maps)
            var location = new Location(_poi.Latitude, _poi.Longitude);
            var options = new MapLaunchOptions 
            { 
                Name = _poi.Name, 
                NavigationMode = NavigationMode.Driving 
            };
            await Map.Default.OpenAsync(location, options);
        }
        catch (Exception)
        {
            // Dự phòng (Fallback) nếu máy ảo/thiết bị không có sẵn ứng dụng Bản đồ
            try
            {
                var uri = $"https://www.google.com/maps/dir/?api=1&destination={_poi.Latitude},{_poi.Longitude}";
                await Launcher.Default.OpenAsync(new Uri(uri));
            }
            catch
            {
                await JS.InvokeVoidAsync("open", $"https://www.google.com/maps/dir/?api=1&destination={_poi.Latitude},{_poi.Longitude}", "_blank");
            }
        }
    }

    private async Task ToggleFavorite()
    {
        if (_userId <= 0)
        {
            Snackbar.Add(LanguageService.T("LoginToSave"), Severity.Info, config =>
            {
                config.Action = LanguageService.T("LoginNow");
                config.ActionColor = Color.Primary;
                config.OnClick = snackbar =>
                {
                    NavigationManager.NavigateTo($"/login?returnUrl=/poi-details/{Id}");
                    return Task.CompletedTask;
                };
            });
            return;
        }

        // Optimistic UI: Đổi màu tim ngay lập tức
        _isFavorite = !_isFavorite;
        StateHasChanged();

        try
        {
            // Gọi API thẳng (có mạng) hoặc Queue Offline, nhận về trạng thái thực tế từ Server
            bool actualState = await SyncService.ToggleFavoriteAsync(Id, _userId);
            _isFavorite = actualState; // Cập nhật lại đúng theo Server
            StateHasChanged();
            Snackbar.Add(actualState ? "Đã thêm vào quán yêu thích" : "Đã gỡ quán yêu thích", Severity.Success);
        }
        catch (Exception ex)
        {
            // Rollback nếu thâᴷt bại hoàn toàn
            _isFavorite = !_isFavorite;
            StateHasChanged();
            Snackbar.Add(LanguageService.T("SavePoiError") + ": " + ex.Message, Severity.Error);
        }
    }

    private async Task StartVoiceGuide()
    {
        if (_currentAudio == null)
        {
            Snackbar.Add(LanguageService.T("Updating"), Severity.Info);
            return;
        }
        _showAudioPlayer = true;
        StateHasChanged();
        await Task.Delay(50); // Chờ component render DOM (<audio>) rồi mới gọi JS
        
        if (!_isPlaying)
        {
            await ToggleAudio();
        }
    }

    private async Task OnAudioEnded()
    {
        _isPlaying = false;
        _audioProgress = 100;
        StateHasChanged();
        
        await Task.Delay(1000); 
        _audioProgress = 0;
        StateHasChanged();
    }

    private async Task CloseAudioPlayer()
    {
        if (_isPlaying)
        {
            try
            {
                await JS.InvokeVoidAsync("audioHelper.pauseById", "poi-audio-player");
            }
            catch { }
        }
        _isPlaying = false;
        _showAudioPlayer = false;
        _audioProgress = 0;
        StateHasChanged();
    }

    private async Task ToggleAudio()
    {
        _isPlaying = !_isPlaying;
        try
        {
            if (_isPlaying)
            {
                if (GeofenceService.IsAudioPlaying)
                {
                    await JS.InvokeVoidAsync("audioHelper.pause");
                    GeofenceService.SetAudioPlaying(false);
                }

                await JS.InvokeVoidAsync("audioHelper.playById", "poi-audio-player");
                SimulateProgress();
            }
            else
            {
                await JS.InvokeVoidAsync("audioHelper.pauseById", "poi-audio-player");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(LanguageService.T("AudioPlayError") + ": " + ex.Message, Severity.Error);
            _isPlaying = false;
        }
    }

    private async Task ReplayAudio()
    {
        try
        {
            // Đặt lại thời gian thẻ audio về 0
            await JS.InvokeVoidAsync("eval", "var audioEl = document.getElementById('poi-audio-player'); if(audioEl) { audioEl.currentTime = 0; }");
            
            _isPlaying = true;
            _audioProgress = 0;
            StateHasChanged();

            await JS.InvokeVoidAsync("audioHelper.playById", "poi-audio-player");
            SimulateProgress();
        }
        catch (Exception ex)
        {
            Snackbar.Add(LanguageService.T("AudioPlayError") + ": " + ex.Message, Severity.Error);
            _isPlaying = false;
        }
    }

    private async void SimulateProgress()
    {
        double duration = _currentAudio?.DurationSeconds ?? 100;
        if (duration <= 0) duration = 100;
        
        double delayMs = 500;
        double increment = 100.0 / (duration / (delayMs / 1000.0));

        while (_isPlaying && _audioProgress < 100)
        {
            _audioProgress += increment;
            if (_audioProgress > 99) _audioProgress = 99; // Dừng lại ở 99%, đợi trigger OnAudioEnded chốt hạ
            StateHasChanged();
            await Task.Delay((int)delayMs);
        }
    }

    private string FormatTime(double seconds)
    {
        var t = TimeSpan.FromSeconds(seconds);
        return $"{(int)t.TotalMinutes}:{t.Seconds:D2}";
    }

    private bool IsToday(DayOfWeek day) => DateTime.Today.DayOfWeek == day;

    private string GetTranslatedDay(DayOfWeek day)
    {
        return LanguageService.T(day.ToString());
    }
    private async Task LoadCategories()
    {
        try 
        { 
            _categories = await SyncService.GetCategoriesAsync(updated => 
            {
                _categories = updated;
                InvokeAsync(StateHasChanged);
            });
        }
        catch { }
    }

    private string GetCategoryName(Poi? poi)
    {
        if (poi == null) return LanguageService.T("Place");
        if (poi.Category != null && !string.IsNullOrEmpty(poi.Category.Name))
            return LanguageService.T(poi.Category.Name);
            
        var cat = _categories.FirstOrDefault(c => c.Id == poi.CategoryId);
        return cat != null ? LanguageService.T(cat.Name) : LanguageService.T("Place");
    }
}
