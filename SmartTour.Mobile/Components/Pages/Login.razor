@page "/login"
@using SmartTour.Mobile.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject LanguageService LanguageService

<div style="height:100vh; background:linear-gradient(160deg,#0a3050 0%,#0e6eb8 50%,#1a9de8 100%); position:relative; overflow:hidden;">

    <!-- Background decorative circles -->
    <div style="position:absolute; top:-80px; right:-60px; width:260px; height:260px; border-radius:50%; background:rgba(255,255,255,0.05);"></div>
    <div style="position:absolute; bottom:-100px; left:-80px; width:320px; height:320px; border-radius:50%; background:rgba(255,255,255,0.04);"></div>
    <div style="position:absolute; top:40%; left:-40px; width:120px; height:120px; border-radius:50%; background:rgba(255,255,255,0.03);"></div>

    <div class="d-flex flex-column align-center justify-center" style="height:100%; padding:24px; position:relative; z-index:1;">

        <!-- Logo + Title -->
        <div class="d-flex flex-column align-center mb-10">
            <div style="width:80px; height:80px; border-radius:24px; background:rgba(255,255,255,0.15); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:20px; box-shadow:0 8px 32px rgba(0,0,0,0.15);">
                <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Style="color:white; font-size:2.5rem;" />
            </div>
            <MudText Style="font-size:2rem; font-weight:800; color:white; letter-spacing:-0.5px; margin-bottom:6px;">
                SmartTour
            </MudText>
            <MudText Style="font-size:0.9rem; color:rgba(255,255,255,0.7); text-align:center; max-width:240px; line-height:1.5;">
                @LanguageService.T("Slogan")
            </MudText>
        </div>

        <!-- Login Card -->
        <div style="width:100%; max-width:360px; background:rgba(255,255,255,0.12); backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,0.2); border-radius:28px; padding:32px 28px; box-shadow:0 20px 60px rgba(0,0,0,0.2);">

            <MudText Style="font-size:1.1rem; font-weight:700; color:white; margin-bottom:6px; text-align:center;">
                @LanguageService.T("WelcomeTitle")
            </MudText>
            <MudText Style="font-size:0.82rem; color:rgba(255,255,255,0.6); text-align:center; margin-bottom:28px;">
                @LanguageService.T("LoginSubtitle")
            </MudText>

            <!-- Google Login Button -->
            <button class="google-btn" @onclick="LoginGoogle" disabled="@_loading">
                @if (_loading)

                {
                        <div style="display:flex; align-items:center; justify-content:center; gap:10px;">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color:#4285F4;" />
                            <span>@LanguageService.T("Processing")</span>
                        </div>
                }

                else

                {
                        <div style="display:flex; align-items:center; justify-content:center; gap:12px;">
                            <svg width="20" height="20" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M43.611 20.083H42V20H24V28H35.303C33.654 32.657 29.223 36 24 36C17.373 36 12 30.627 12 24C12 17.373 17.373 12 24 12C27.059 12 29.842 13.154 31.961 15.039L37.618 9.382C34.046 6.053 29.268 4 24 4C12.955 4 4 12.955 4 24C4 35.045 12.955 44 24 44C35.045 44 44 35.045 44 24C44 22.659 43.862 21.35 43.611 20.083Z" fill="#FFC107"/>
                                <path d="M6.306 14.691L12.877 19.51C14.655 15.108 18.961 12 24 12C27.059 12 29.842 13.154 31.961 15.039L37.618 9.382C34.046 6.053 29.268 4 24 4C16.318 4 9.656 8.337 6.306 14.691Z" fill="#FF3D00"/>
                                <path d="M24 44C29.166 44 33.86 42.023 37.409 38.808L31.219 33.57C29.211 35.091 26.715 36 24 36C18.798 36 14.381 32.683 12.717 28.054L6.195 33.079C9.505 39.556 16.227 44 24 44Z" fill="#4CAF50"/>
                                <path d="M43.611 20.083H42V20H24V28H35.303C34.511 30.237 33.072 32.166 31.217 33.571C31.218 33.57 31.219 33.57 31.22 33.569L37.41 38.807C36.971 39.205 44 34 44 24C44 22.659 43.862 21.35 43.611 20.083Z" fill="#1976D2"/>
                            </svg>
                            <span>@LanguageService.T("LoginWithGoogle")</span>
                        </div>
                }
            </button>

            <!-- Divider -->
            <div style="display:flex; align-items:center; margin:20px 0; gap:12px;">
                <div style="flex:1; height:1px; background:rgba(255,255,255,0.2);"></div>
                <MudText Style="font-size:0.75rem; color:rgba(255,255,255,0.5);">@LanguageService.T("Or")</MudText>
                <div style="flex:1; height:1px; background:rgba(255,255,255,0.2);"></div>
            </div>

            <!-- Guest Button -->
            <button class="guest-btn" @onclick="ExploreGuest">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Style="font-size:1.1rem; margin-right:8px;" />
                @LanguageService.T("ExploreAsGuest")
            </button>

            <MudText Style="font-size:0.72rem; color:rgba(255,255,255,0.4); text-align:center; margin-top:16px; line-height:1.5;">
                @LanguageService.T("GuestModeHint")
            </MudText>
        </div>

        <MudText Style="font-size:0.72rem; color:rgba(255,255,255,0.35); margin-top:32px; text-align:center;">
            © 2026 SmartTour Tech · @LanguageService.T("Version") 1.0
        </MudText>

    </div>
</div>

<style>
    .google-btn {
        width: 100%;
        padding: 14px 20px;
        border-radius: 14px;
        background: white;
        border: none;
        color: #333;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    }
    .google-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }
    .google-btn:active:not(:disabled) {
        transform: scale(0.98);
    }
    .google-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .guest-btn {
        width: 100%;
        padding: 13px 20px;
        border-radius: 14px;
        background: rgba(255,255,255,0.12);
        border: 1.5px solid rgba(255,255,255,0.25);
        color: white;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .guest-btn:hover {
        background: rgba(255,255,255,0.18);
        border-color: rgba(255,255,255,0.4);
    }
    .guest-btn:active {
        transform: scale(0.98);
    }
</style>

@code {
    [Parameter]

    [SupplyParameterFromQuery]

    public string? ReturnUrl { get; set; }



    private bool _loading = false;



    private async Task LoginGoogle()

    {

        _loading = true;

        try

        {

            string hostIp = "192.168.31.141";
            string webUrl = $"http://{hostIp}:5139";
#if ANDROID
            if (Microsoft.Maui.Devices.DeviceInfo.DeviceType == Microsoft.Maui.Devices.DeviceType.Virtual)
            {
                webUrl = "http://localhost:5139"; // Máy ảo dùng adb reverse
            }
#endif
            var authUrl = new Uri($"{webUrl}/account/login-google?returnUrl=smarttour://callback");

            var callbackUrl = new Uri("smarttour://callback");



            var result = await WebAuthenticator.Default.AuthenticateAsync(authUrl, callbackUrl);



            await InvokeAsync(() =>
            {

                if (result != null && result.Properties.TryGetValue("email", out var email))

                {

                    result.Properties.TryGetValue("userId", out var userId);
                    result.Properties.TryGetValue("name", out var fullName);

                    var auth = (MobileAuthStateProvider)AuthStateProvider;

                    auth.MarkUserAsAuthenticated(email, userId ?? "", fullName ?? "");

                    NavigationManager.NavigateTo(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl);

                }

                else

                {

                    string error = result?.Properties.ContainsKey("error") == true ? result.Properties["error"] : LanguageService.T("EmailMissing");
                    Snackbar.Add($"{LanguageService.T("LoginFailed")}: {error}", Severity.Error);

                    StateHasChanged();

                }

            });

        }

        catch (TaskCanceledException)

        {

            await InvokeAsync(() =>
            {

                try { Snackbar.Add(LanguageService.T("LoginCancelled"), Severity.Info); } catch { }

            });

        }

        catch (Exception ex)

        {

            await InvokeAsync(() =>
            {

                try { Snackbar.Add($"{LanguageService.T("GoogleLoginError")}: {ex.Message}", Severity.Error); } catch { }

            });

        }

        finally { _loading = false; }

    }



    private void ExploreGuest()

    {

        var auth = (MobileAuthStateProvider)AuthStateProvider;

        auth.MarkUserAsAuthenticated("Guest", "0");

        NavigationManager.NavigateTo(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl);

    }
}
