@page "/map"
@using SmartTour.Mobile.Services
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@inject IJSRuntime JS
@inject GeofenceAudioService GeofenceService
@inject NavigationManager NavigationManager
@inject LanguageService LanguageService
@inject HttpClient Http
@implements IDisposable
@attribute [Authorize]

<MudLayout>
    <!-- ── AppBar ── -->
    <MudAppBar Elevation="0" Dense="true"
               Style="background:linear-gradient(135deg,#0e6eb8 0%,#1a9de8 100%); z-index:200;">
        <div class="map-icon-btn" @onclick="@(() => NavigationManager.NavigateTo("/"))">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack"
                     Style="color:white; font-size:1.1rem;" />
        </div>
        <MudSpacer />
        <MudText Style="font-size:0.95rem; font-weight:600; color:white;">
            🗺️ @LanguageService.T("Map")
        </MudText>
        <MudSpacer />
        <div class="map-icon-btn me-2" @onclick="ToggleSearch">
            <MudIcon Icon="@Icons.Material.Filled.Search"
                     Style="color:white; font-size:1.1rem;" />
        </div>
        <div class="map-icon-btn" @onclick="CenterOnUser">
            <MudIcon Icon="@Icons.Material.Filled.MyLocation"
                     Style="color:white; font-size:1.1rem;" />
        </div>
    </MudAppBar>

    <MudMainContent Class="pa-0">
        @if (_isSearching)
        {
            <!-- ── Invisible Backdrop to click outside to close ── -->
            <div style="position:fixed; inset:0; z-index:145;" @onclick="() => _isSearching = false"></div>

            <!-- ── Search Bar — slides down below AppBar ── -->
            <div class="px-4 pt-3 pb-2"
                 style="position:absolute; top:48px; left:0; right:0; z-index:150; animation: slideDown 0.25s ease-out;">
                <div class="search-bar-container">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
                    <input type="text"
                           class="search-input"
                           placeholder="@LanguageService.T("SearchHint")"
                           @bind="_searchQuery"
                           @bind:event="oninput"
                           @onkeyup="FilterPois"
                           autoFocus />
                    @if (!string.IsNullOrEmpty(_searchQuery))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="() => { _searchQuery = string.Empty; FilterPois(); }" Class="mr-1" />
                    }
                    <div class="filter-action">
                        <MudIconButton Icon="@Icons.Material.Filled.Tune" Size="Size.Small"
                                       Class="filter-icon-btn" OnClick="() => { _isSearching = false; _filterOpen = true; }" />
                    </div>
                </div>
            </div>
        }

        <div class="map-wrapper">
            <div id="map" style="width:100%; height:100%;"></div>

            <!-- Loading -->
            @if (!_mapInitialized && !_mapError)
            {
                <div class="map-overlay">
                    <div class="map-loading-card">
                        <div class="map-loading-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Map"
                                     Style="color:#0e6eb8; font-size:2rem;" />
                        </div>
                        <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1"
                                 Style="font-weight:600; color:#0a3050;">
                            @LanguageService.T("LoadingMap")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mb-3"
                                 Style="color:#aaa;">
                            @LanguageService.T("WaitMoment")
                        </MudText>
                        <MudProgressLinear Color="Color.Primary"
                                           Indeterminate="true" Rounded="true"
                                           Size="Size.Small"
                                           Style="width:140px;" />
                    </div>
                </div>
            }

            <!-- Error -->
            @if (_mapError)
            {
                <div class="map-overlay" style="background:#f0f7ff;">
                    <div class="map-error-card">
                        <div class="map-error-icon">
                            <MudIcon Icon="@Icons.Material.Filled.WifiOff"
                                     Style="color:#dc5028; font-size:2rem;" />
                        </div>
                        <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1"
                                 Style="font-weight:600; color:#7a2010;">
                            @LanguageService.T("MapLoadError")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mb-3"
                                 Style="color:#aaa; text-align:center; max-width:200px;">
                            @_errorMessage
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Style="background:linear-gradient(135deg,#0e6eb8,#1a9de8);
                                          color:white; border-radius:20px; padding:6px 28px;"
                                   OnClick="InitializeMap">
                            @LanguageService.T("Retry")
                        </MudButton>
                    </div>
                </div>
            }

            @* Legacy POI Card - hidden in favor of Mapbox Popups *@
            @if (_selectedPoi != null)
            {
                <div class="poi-card-wrapper">
                    <div class="d-flex align-center gap-3 mb-3">
                        <div class="poi-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Place"
                                     Style="color:white; font-size:1.2rem;" />
                        </div>
                        <div style="flex:1; overflow:hidden;">
                            <MudText Style="font-weight:600; font-size:0.95rem;
                                           color:#0a3050; white-space:nowrap;
                                           overflow:hidden; text-overflow:ellipsis;">
                                @_selectedPoi.Name
                            </MudText>
                            <div class="d-flex align-center gap-2 mt-1">
                                <span class="poi-category-tag">
                                    @(LanguageService.T(_selectedPoi.CategoryName ?? "Place"))
                                </span>
                                <MudText Typo="Typo.caption" Style="color:#aaa;">
                                    @_selectedPoi.Latitude.ToString("F4"),
                                    @_selectedPoi.Longitude.ToString("F4")
                                </MudText>
                            </div>
                        </div>
                        <div class="poi-close-btn" @onclick="CloseSelectedPoi">
                            <MudIcon Icon="@Icons.Material.Filled.Close"
                                     Style="color:#bbb; font-size:1rem;" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <MudButton FullWidth="true"
                                   Style="background:linear-gradient(135deg,#0e6eb8,#1a9de8);
                                          color:white; border-radius:14px; font-weight:600;
                                          text-transform:none;"
                                   StartIcon="@Icons.Material.Filled.Info"
                                   OnClick="@(() => NavigationManager.NavigateTo($"/poi-details/{_selectedPoi.Id}"))">
                            @LanguageService.T("Details")
                        </MudButton>
                        <MudButton FullWidth="true"
                                   Style="border:1.5px solid #0e6eb8; color:#0e6eb8;
                                          border-radius:14px; font-weight:600;
                                          text-transform:none; background:rgba(14,110,184,0.04);"
                                   StartIcon="@Icons.Material.Filled.PlayCircle"
                                   OnClick="PlaySelectedPoi">
                            @LanguageService.T("Listen")
                        </MudButton>
                    </div>
                </div>
            }
        </div>
    </MudMainContent>

    <!-- ── Filter Bottom Sheet ── -->
    <MudDrawer @bind-Open="_filterOpen" Anchor="Anchor.Bottom" Elevation="25"
               Class="filter-sheet" OverlayAutoClose="true" Variant="DrawerVariant.Temporary"
               Overlay="true">
        <div class="filter-header">
            <MudText Typo="Typo.h6" Style="font-weight:800; color:#0a3050;">Bộ lọc nâng cao</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="@(() => _filterOpen = false)" Size="Size.Small" />
        </div>

        <div class="filter-body">
            <!-- Location Toggle -->
            <div class="d-flex align-center justify-space-between mb-4">
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" Style="color:#aaa;" />
                    <MudText Typo="Typo.body2">Tìm quanh vị trí của tôi</MudText>
                </div>
                <MudSwitch T="bool" @bind-Value="_filterByLocation" Color="Color.Primary" />
            </div>

            @if (_filterByLocation)
            {
                <div class="mb-5">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Khoảng cách tối đa</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Primary" Style="font-weight:600;">
                            @(_selectedRadius >= 1000 ? $"{_selectedRadius / 1000:F1} km" : $"{_selectedRadius:N0} m")
                        </MudText>
                    </div>
                    <MudSlider T="double" Value="_selectedRadius" ValueChanged="OnRadiusSliderChanged"
                               Min="50" Max="10000" Step="50" Color="Color.Primary" />
                    <div class="d-flex justify-space-between mt-n1">
                        <MudText Typo="Typo.caption" Style="color:#bbb;">50m</MudText>
                        <MudText Typo="Typo.caption" Style="color:#bbb;">10km</MudText>
                    </div>
                </div>
            }

            <!-- Status Toggles -->
            <MudText Typo="Typo.subtitle2" Class="mb-3" Style="font-weight:700;">Trạng thái điểm đến</MudText>
            <div class="d-flex flex-column gap-1 mb-2">
                <div class="d-flex align-center justify-space-between filter-row">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Style="color:#aaa;" />
                        <MudText Typo="Typo.body2">Đang mở cửa</MudText>
                    </div>
                    <MudSwitch T="bool" @bind-Value="_filterOpenNow" Color="Color.Primary" />
                </div>
                <div class="d-flex align-center justify-space-between filter-row">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Headset" Size="Size.Small" Style="color:#aaa;" />
                        <MudText Typo="Typo.body2">Có thuyết minh âm thanh</MudText>
                    </div>
                    <MudSwitch T="bool" @bind-Value="_filterHasAudio" Color="Color.Primary" />
                </div>
                <div class="d-flex align-center justify-space-between filter-row">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color:#aaa;" />
                        <MudText Typo="Typo.body2">Quán nổi bật</MudText>
                    </div>
                    <MudSwitch T="bool" @bind-Value="_filterIsFeatured" Color="Color.Primary" />
                </div>
            </div>
        </div>

        <div class="filter-actions">
            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default"
                       Style="border-radius:12px; height:48px;" OnClick="ResetFilters">
                Thiết lập lại
            </MudButton>
            <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                       Style="border-radius:12px; height:48px; background:#0e6eb8;" OnClick="ApplyFilters">
                Áp dụng
            </MudButton>
        </div>
    </MudDrawer>

    <!-- ── Bottom Navigation ── -->
    <BottomNavigation Active="map" />
</MudLayout>

<style>
    .map-wrapper {
        position: relative;
        width: 100%;
        height: calc(100dvh - 48px);
        box-sizing: border-box;
        overflow: hidden;
        background: #f0f7ff;
    }

    .mapboxgl-ctrl-top-right {
        top: 90px !important; 
        right: 10px !important;
        z-index: 300 !important;
    }

    .mapboxgl-ctrl-bottom-left,
    .mapboxgl-ctrl-bottom-right {
        bottom: 5px !important;
    }

    .map-icon-btn {
        width: 32px; height: 32px;
        border-radius: 10px;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
    }

    .map-overlay {
        position: absolute; inset: 0; z-index: 10;
        background: #f0f7ff;
        display: flex; align-items: center; justify-content: center;
    }

    .map-loading-card, .map-error-card {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(16px);
        border-radius: 24px;
        padding: 32px 28px;
        display: flex; flex-direction: column; align-items: center;
        border: 0.5px solid rgba(14,110,184,0.15);
        box-shadow: 0 8px 32px rgba(14,110,184,0.1);
        min-width: 220px;
    }

    .poi-card-wrapper {
        position: absolute; 
        top: 15px; 
        left: 15px; right: 15px; 
        z-index: 1200;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(20px);
        border-radius: 24px !important; 
        padding: 16px 16px 20px;
        border: 0.5px solid rgba(14,110,184,0.15);
        box-shadow: 0 12px 32px rgba(14,110,184,0.15); 
        animation: slideDown 0.35s cubic-bezier(0.34,1.56,0.64,1);
    }

    .poi-icon-badge {
        width: 46px; height: 46px; border-radius: 14px;
        background: linear-gradient(135deg,#0e6eb8,#1a9de8);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(14,110,184,0.35);
    }

    .poi-category-tag {
        background: rgba(14,110,184,0.1);
        color: #0e6eb8; font-size: 0.7rem;
        padding: 2px 8px; border-radius: 8px;
    }

    .poi-close-btn {
        width: 28px; height: 28px; border-radius: 8px;
        background: rgba(0,0,0,0.04);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
    }

    /* ── Custom Mapbox Popup (Unused) ── */
    .mapboxgl-popup { display: none; }

    /* ── Search Bar UI ── */
    .search-bar-container {
        display: flex; align-items: center; background: rgba(255,255,255,0.95); backdrop-filter: blur(15px);
        padding: 8px 14px; border-radius: 24px; border: 1px solid rgba(14,110,184,0.15);
        box-shadow: 0 6px 20px rgba(14,110,184,0.1); transition: all 0.3s;
    }
    .search-input {
        flex: 1; border: none; outline: none; font-size: 0.9rem; color: #0a3050; background: transparent; padding: 4px 0;
    }
    .search-input::placeholder { color: #aaa; }
    .search-icon { color: #0e6eb8; font-size: 1.2rem; margin-right: 10px; }
    .filter-action {
        border-left: 1px solid rgba(0,0,0,0.06); padding-left: 8px; margin-left: 8px; display: flex; align-items: center;
    }
    .filter-icon-btn { background: rgba(14,110,184,0.06) !important; color: #0e6eb8 !important; border-radius: 12px !important; }

    /* ── Filter sheet UI ── */
    .filter-sheet {
        border-top: 1px solid rgba(14,110,184,0.1) !important; border-radius: 24px 24px 0 0 !important;
        box-shadow: 0 -8px 24px rgba(0,0,0,0.05) !important; display: flex; flex-direction: column; max-height: 72vh !important; z-index: 2000 !important;
    }
    .filter-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 16px 8px; flex-shrink: 0; }
    .filter-body { flex: 1; overflow-y: auto; padding: 0 16px 8px; -webkit-overflow-scrolling: touch; }
    .filter-actions { display: flex; gap: 12px; padding: 12px 16px 20px; flex-shrink: 0; border-top: 0.5px solid rgba(14,110,184,0.08); background: white; }
    .filter-row { padding: 6px 0; }

    @@keyframes slideDown {
        from { transform: translateY(-50px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
</style>

@code {
    private DotNetObjectReference<MapView>? _dotNetRef;
    private PoiGeofenceDto? _selectedPoi;
    private int _selectedPoiId = 0;
    private bool _mapInitialized = false;
    private bool _mapError = false;
    private string _errorMessage = "";

    // Search Toggle
    private bool _isSearching = false;

    // Filters
    private bool _filterOpen = false;
    private string _searchQuery = "";
    private bool _filterByLocation = false;
    private double _selectedRadius = 1000;
    private bool _filterOpenNow = false;
    private bool _filterHasAudio = false;
    private bool _filterIsFeatured = false;

    private List<PoiGeofenceDto> _filteredPois = new();

    private void ToggleSearch() => _isSearching = !_isSearching;

    private void ToggleFilters() => _filterOpen = !_filterOpen;

    private void OnRadiusSliderChanged(double val) { _selectedRadius = val; }

    private void ResetFilters()
    {
        _filterByLocation = false; _selectedRadius = 1000;
        _filterOpenNow = false; _filterHasAudio = false; _filterIsFeatured = false;
        _searchQuery = "";
        FilterPois();
        _filterOpen = false;
    }

    private void ApplyFilters()
    {
        FilterPois();
        _filterOpen = false;
    }

    private void FilterPois()
    {
        var query = GeofenceService.AllPois.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var sq = _searchQuery.ToLowerInvariant();
            query = query.Where(p => p.Name.ToLowerInvariant().Contains(sq));
        }

        if (_filterHasAudio)
            query = query.Where(p => p.AudioFiles != null && p.AudioFiles.Any());

        if (_filterIsFeatured)
            query = query.Where(p => p.IsFeature);

        if (_filterOpenNow)
        {
            var now = DateTime.UtcNow.AddHours(7);
            var day = (int)now.DayOfWeek;
            var time = now.TimeOfDay;
            query = query.Where(p => p.OperatingHours != null && p.OperatingHours.Any(h => (int)h.DayOfWeek == day && time >= h.OpenTime && time <= h.CloseTime));
        }

        if (_filterByLocation && GeofenceService.LastKnownLatitude.HasValue && GeofenceService.LastKnownLongitude.HasValue)
        {
            var myLat = GeofenceService.LastKnownLatitude.Value;
            var myLng = GeofenceService.LastKnownLongitude.Value;
            query = query.Where(p => CalculateDistance(myLat, myLng, p.Latitude, p.Longitude) <= _selectedRadius);
        }

        _filteredPois = query.ToList();
        _ = UpdateMarkersWithSelected();
        _ = JS.InvokeVoidAsync("window.mapHelper.fitBoundsToPOIs");
    }

    private double CalculateDistance(double lat1, double lon1, double lat2, double lon2)
    {
        var R = 6371e3;
        var p1 = lat1 * Math.PI / 180;
        var p2 = lat2 * Math.PI / 180;
        var dp = (lat2 - lat1) * Math.PI / 180;
        var dl = (lon2 - lon1) * Math.PI / 180;
        var a = Math.Sin(dp / 2) * Math.Sin(dp / 2) + Math.Cos(p1) * Math.Cos(p2) * Math.Sin(dl / 2) * Math.Sin(dl / 2);
        return R * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    protected override void OnInitialized()
    {
        GeofenceService.BannerStateChanged += HandleStateChanged;
        LanguageService.OnLanguageChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(200);
            await InitializeMap();
        }
    }

    private async Task InitializeMap()
    {
        _mapError = false; _mapInitialized = false;
        await InvokeAsync(StateHasChanged);
        try
        {
            var config = await Http.GetFromJsonAsync<MapConfig>("api/pois/map-config");
            if (config == null || string.IsNullOrEmpty(config.GoogleMapsApiKey))
            {
                _errorMessage = LanguageService.T("TokenMissing");
                _mapError = true;
                await InvokeAsync(StateHasChanged);
                return;
            }

            _dotNetRef = DotNetObjectReference.Create(this);
            var lat = GeofenceService.LastKnownLatitude ?? 10.7769;
            var lng = GeofenceService.LastKnownLongitude ?? 106.7009;
            await JS.InvokeVoidAsync("window.mapHelper.initMap",
                config.GoogleMapsApiKey, lat, lng, 15, _dotNetRef);
            _mapInitialized = true;

            _filteredPois = GeofenceService.AllPois.ToList();
            await InvokeAsync(StateHasChanged);
            await UpdateMarkersWithSelected();
            await UpdateUserLocation();
            await JS.InvokeVoidAsync("window.mapHelper.fitBoundsToPOIs");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _mapError = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public void OnMarkerClick(int poiId)
    {
        _selectedPoi = GeofenceService.AllPois.FirstOrDefault(p => p.Id == poiId);
        _selectedPoiId = poiId;
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            await UpdateMarkersWithSelected();
        });
    }

    [JSInvokable]
    public void OnPlayClick(int poiId)
    {
        var poi = GeofenceService.AllPois.FirstOrDefault(p => p.Id == poiId);
        if (poi != null)
        {
            _selectedPoi = poi;
            _selectedPoiId = poiId;
            _ = InvokeAsync(async () =>
            {
                await PlaySelectedPoi();
                StateHasChanged();
            });
        }
    }

    private async void HandleStateChanged()
    {
        await InvokeAsync(async () =>
        {
            if (_mapInitialized)
            {
                await UpdateMarkersWithSelected();
                await UpdateUserLocation();
            }
            StateHasChanged();
        });
    }

    private async Task UpdateMarkersWithSelected()
    {
        if (!_mapInitialized) return;
        int closestId = _selectedPoiId != 0 ? 0 : (GeofenceService.CurrentPoi?.Id ?? 0);

        await JS.InvokeVoidAsync("window.mapHelper.updateMarkers",
            _filteredPois,
            closestId,
            _selectedPoiId);
    }

    private async Task UpdateUserLocation()
    {
        if (!_mapInitialized) return;
        if (GeofenceService.LastKnownLatitude.HasValue && GeofenceService.LastKnownLongitude.HasValue)
            await JS.InvokeVoidAsync("window.mapHelper.updateUserLocation",
                GeofenceService.LastKnownLatitude.Value,
                GeofenceService.LastKnownLongitude.Value);
    }

    private async Task CenterOnUser()
    {
        if (GeofenceService.LastKnownLatitude.HasValue && GeofenceService.LastKnownLongitude.HasValue)
            await JS.InvokeVoidAsync("window.mapHelper.flyTo",
                GeofenceService.LastKnownLatitude.Value,
                GeofenceService.LastKnownLongitude.Value, 16);
    }

    private async Task PlaySelectedPoi()
    {
        if (_selectedPoi == null) return;
        _selectedPoiId = _selectedPoi.Id;
        await GeofenceService.PlayManualAsync(_selectedPoi, LanguageService.SelectedLanguage);
        await UpdateMarkersWithSelected();
    }

    private async Task CloseSelectedPoi()
    {
        _selectedPoi = null;
        _selectedPoiId = 0;
        StateHasChanged();
        await UpdateMarkersWithSelected();
    }

    public void Dispose()
    {
        GeofenceService.BannerStateChanged -= HandleStateChanged;
        LanguageService.OnLanguageChanged -= StateHasChanged;
        _dotNetRef?.Dispose();
    }

    public class MapConfig
    {
        [JsonPropertyName("mapboxAccessToken")]
        public string MapboxAccessToken { get; set; } = string.Empty;

        [JsonPropertyName("googleMapsApiKey")]
        public string GoogleMapsApiKey { get; set; } = string.Empty;
    }
}
