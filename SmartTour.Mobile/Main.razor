@using Microsoft.AspNetCore.Components.Authorization
@using SmartTour.Mobile.Components.Pages
@using Microsoft.AspNetCore.Components.Routing

@using SmartTour.Mobile.Components.Shared
@inject LanguageService LanguageService

<MudThemeProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>
<MudPopoverProvider/>

<!-- Banner geofence toàn cục: hiển thị trên mọi trang khi audio đang phát -->
<GeofenceBanner />

<CascadingAuthenticationState>
    <ErrorBoundary @ref="_errorBoundary">
        <ChildContent>
            <Router AppAssembly="@typeof(Main).Assembly">
                <Found Context="routeData">
                    <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                        <NotAuthorized>
                            <Login />
                        </NotAuthorized>
                        <Authorizing>
                            <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100dvh; background:#f0f7ff;">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                                <MudText Typo="Typo.h6" Class="mt-5" Style="color:#0a3050; font-weight:600;">Đang xác thực bảo mật...</MudText>
                                <MudText Typo="Typo.body2" Class="mt-2" Style="color:#777;">Vui lòng chờ giây lát</MudText>
                            </div>
                        </Authorizing>
                    </AuthorizeRouteView>
                </Found>
                <NotFound>
                    <LayoutView Layout="@typeof(MainLayout)">
                        <MudText Typo="Typo.h5" Class="pa-4">@LanguageService.T("PageNotFound")</MudText>
                    </LayoutView>
                </NotFound>
            </Router>
        </ChildContent>
        <ErrorContent Context="ex">
            <div class="pa-4 d-flex flex-column align-center justify-center" style="height: 80vh">
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
                    @LanguageService.T("SystemError"): @ex.Message
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => _errorBoundary?.Recover()">
                    @LanguageService.T("Retry")
                </MudButton>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</CascadingAuthenticationState>

@code {
    private ErrorBoundary? _errorBoundary;

    protected override void OnParametersSet()
    {
        // Mỗi khi chuyển trang, reset lỗi để ErrorBoundary thử lại
        _errorBoundary?.Recover();
    }
}
