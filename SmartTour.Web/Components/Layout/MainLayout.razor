@using SmartTour.Web.Services
@inject UserSessionService UserSession
@inject AuthenticationStateProvider AuthStateProvider
@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h6">SmartTour Web</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudChip T="string" Icon="@Icons.Material.Filled.Person" Color="Color.Inherit">
                            @context.User.Identity?.Name
                        </MudChip>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Filled.Logout" Href="/account/logout">Đăng xuất</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit">Đăng nhập</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (AuthenticationStateTask != null)
        {
            var authState = await AuthenticationStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value 
                             ?? user.FindFirst("UserId")?.Value;

                // Lấy role tên (ADMIN/SELLER) - ưu tiên tên chữ, bỏ qua role dạng số (RoleId)
                var role = user.FindAll(System.Security.Claims.ClaimTypes.Role)
                               .Select(c => c.Value)
                               .FirstOrDefault(v => !int.TryParse(v, out _));

                UserSession.SetUser(userId, user.Identity.Name, role);
            }
            else
            {
                UserSession.SetUser(null, null, null);
            }
        }
        
        await base.OnParametersSetAsync();
    }
}
