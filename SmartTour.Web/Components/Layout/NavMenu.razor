@using Microsoft.AspNetCore.Components.Authorization

<MudNavMenu Bordered="false" Color="Color.Primary" Class="mud-width-full pt-4">
    <div class="px-6 pb-2">
        <MudText Typo="Typo.caption" Class="text-muted" Style="font-weight: 700; letter-spacing: 1px;">MENU CHÍNH</MudText>
    </div>
    
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SpaceDashboard">Tổng quan</MudNavLink>

    <AuthorizeView Roles="ADMIN">
        <Authorized>
            <div class="px-6 pt-4 pb-2">
                <MudText Typo="Typo.caption" Class="text-muted" Style="font-weight: 700; letter-spacing: 1px;">QUẢN TRỊ HỆ THỐNG</MudText>
            </div>
            <MudNavLink Href="/poi-management" Icon="@Icons.Material.Filled.Place">Biên tập POI</MudNavLink>
            <MudNavLink Href="/poi-requests" Icon="@Icons.Material.Filled.PendingActions">Yêu cầu duyệt POI</MudNavLink>
            <MudNavLink Href="/category-management" Icon="@Icons.Material.Filled.Category">Loại hình POI</MudNavLink>
            <MudNavLink Href="/service-package-management" Icon="@Icons.Material.Filled.CardMembership">Gói dịch vụ</MudNavLink>
            <MudNavLink Href="/language-management" Icon="@Icons.Material.Filled.Translate">Ngôn ngữ</MudNavLink>
            <MudNavLink Href="/users" Icon="@Icons.Material.Filled.PeopleAlt">Người dùng</MudNavLink>
            <MudNavLink Href="/revenue" Icon="@Icons.Material.Filled.InsertChartOutlined">Doanh thu</MudNavLink>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="SELLER">
        <Authorized>
            <div class="px-6 pt-4 pb-2">
                <MudText Typo="Typo.caption" Class="text-muted" Style="font-weight: 700; letter-spacing: 1px;">ĐỐI TÁC DU LỊCH</MudText>
            </div>
            <MudNavLink Href="/poi-management" Icon="@Icons.Material.Filled.Place">Quản lý POI</MudNavLink>
            <MudNavLink Href="/pricing" Icon="@Icons.Material.Filled.WorkspacePremium">Nâng cấp dịch vụ</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

<style>
    .text-muted { color: var(--mud-palette-text-secondary) !important; }
</style>
