@page "/pricing"
@using SmartTour.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Bảng giá dịch vụ - SmartTour</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <div class="text-center mb-10">
        <MudText Typo="Typo.h3" Align="Align.Center" Style="font-weight: 800; letter-spacing: -1.5px; color: var(--mud-palette-primary);">Lựa chọn gói dịch vụ</MudText>
        <MudText Typo="Typo.h6" Align="Align.Center" Class="mud-text-secondary mt-2" Style="font-weight: 400;">Nâng tầm trải nghiệm du lịch số của bạn với các tính năng chuyên nghiệp</MudText>
    </div>

    @if (_currentSubscription != null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-8 rounded-xl pa-4" Icon="@Icons.Material.Filled.WorkspacePremium">
            <div class="d-flex align-center justify-space-between flex-wrap">
                <div>
                    <MudText Typo="Typo.h6">Gói hiện tại: <b>@(_currentSubscription.ServicePackage?.Name ?? "N/A")</b></MudText>
                    <MudText Typo="Typo.body2">Ngày hết hạn: <b>@_currentSubscription.EndDate.ToString("dd/MM/yyyy HH:mm")</b></MudText>
                </div>
                <MudChip T="string" Color="Color.Surface" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Timer">
                    @GetRemainingDays(_currentSubscription.EndDate)
                </MudChip>
            </div>
        </MudAlert>
    }

    <MudGrid Justify="Justify.Center" Spacing="4">
        @if (_loading)
        {
            @for (int i = 0; i < 3; i++)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="0" Outlined="true" Class="rounded-xl pa-5">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="150px" />
                        <MudSkeleton Class="mt-4" Height="30px" />
                        <MudSkeleton Class="mt-2" Height="15px" Width="80%" />
                    </MudCard>
                </MudItem>
            }
        }
        else
        {
            @foreach (var package in _packages)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="0" Outlined="true" Class="@($"{GetCardClass(package.Code)} rounded-xl overflow-hidden hover-raised")">
                        <div class="pa-6 d-flex flex-column align-center text-center fill-height">
                            <MudAvatar Color="@GetAvatarColor(package.Code)" Size="Size.Medium" Variant="Variant.Filled" Class="mb-3">
                                <MudIcon Icon="@GetPackageIcon(package.Code)" Size="Size.Small" />
                            </MudAvatar>
                            
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@package.Name</MudText>
                            
                            <div class="d-flex align-end justify-center my-4">
                                <MudText Typo="Typo.h4" Style="font-weight: 900;">@package.Price.ToString("N0")</MudText>
                                <MudText Typo="Typo.body2" Class="ml-1 pb-1 mud-text-secondary">VND</MudText>
                            </div>
                            
                            <MudDivider DividerType="DividerType.Middle" Class="w-100 my-3" />
                            
                            <div class="flex-grow-1 w-100 mt-1">
                                <div class="d-flex align-center mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                    <MudText Typo="Typo.body2">Hiệu lực: <b>@package.DurationDays ngày</b></MudText>
                                </div>
                                <div class="d-flex align-center mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                    <MudText Typo="Typo.body2">Tối đa: <b>@package.MaxPoiAllowed POI</b></MudText>
                                </div>
                                <div class="d-flex align-start mb-2 text-left">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Class="mr-2 mt-1" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@package.Description</MudText>
                                </div>
                            </div>

                            <MudButton Variant="Variant.Filled" 
                                       Color="@GetButtonColor(package.Code)" 
                                       FullWidth="true" 
                                       Size="Size.Large" 
                                       Class="rounded-pill mt-8 py-3 font-bold"
                                       OnClick="@(() => Subscribe(package))">
                                @GetButtonText(package)
                            </MudButton>
                        </div>
                    </MudCard>
                </MudItem>
            }
        }
    </MudGrid>
    @if (_packages.Any(p => p.IsDefault))
    {
        <div class="d-flex justify-center mt-6">
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@ContinueWithDefault">
                Tiếp tục với gói mặc định
            </MudButton>
        </div>
    }
</MudContainer>

<style>
    .hover-raised {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-raised:hover {
        transform: translateY(-10px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.15) !important;
    }
    .card-pro {
        border: 2px solid var(--mud-palette-primary-lighten);
        background: linear-gradient(135deg, #ffffff 0%, #f0f4ff 100%);
    }
    .card-vip {
        border: 2px solid #FFD700;
        background: linear-gradient(135deg, #ffffff 0%, #fffdf0 100%);
    }
    .font-bold {
        font-weight: 700 !important;
    }
</style>

@code {
    private List<ServicePackage> _packages = new();
    private Subscription? _currentSubscription;
    private int? _currentUserId;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _packages = await Http.GetFromJsonAsync<List<ServicePackage>>("api/servicepackages") ?? new();
            
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userIdStr = user.FindFirst("UserId")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            
            if (int.TryParse(userIdStr, out int userId))
            {
                _currentUserId = userId;
                try 
                {
                    _currentSubscription = await Http.GetFromJsonAsync<Subscription>($"api/subscriptions/user/{userId}");
                    if (_currentSubscription?.ServicePackage != null)
                    {
                        var currentPrice = _currentSubscription.ServicePackage.Price;
                        _packages = _packages.Where(p => p.Price >= currentPrice).ToList();
                    }
                } 
                catch { /* Bỏ qua nếu chưa có gói hoặc lỗi tải */ }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Không thể tải danh sách gói: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetCardClass(string code) => code switch
    {
        "PRO_MONTH" => "card-pro",
        "VIP_YEAR" => "card-vip",
        _ => "card-basic"
    };

    private Color GetAvatarColor(string code) => code switch
    {
        "PRO_MONTH" => Color.Primary,
        "VIP_YEAR" => Color.Warning,
        _ => Color.Default
    };

    private Color GetButtonColor(string code) => code switch
    {
        "PRO_MONTH" => Color.Primary,
        "VIP_YEAR" => Color.Warning,
        _ => Color.Tertiary
    };

    private string GetPackageIcon(string code) => code switch
    {
        "FREE" => Icons.Material.Filled.Person,
        "PRO_MONTH" => Icons.Material.Filled.Star,
        "VIP_YEAR" => Icons.Material.Filled.WorkspacePremium,
        _ => Icons.Material.Filled.CardMembership
    };

    private string GetButtonText(ServicePackage package)
    {
        if (_currentSubscription?.ServicePackage != null)
        {
            if (package.Code == _currentSubscription.ServicePackage.Code)
                return "Gia hạn thêm";
            
            if (package.Price > _currentSubscription.ServicePackage.Price)
                return "Quy đổi nâng cấp";
        }
        
        return package.Price == 0 ? "Bắt đầu miễn phí" : "Đăng ký ngay";
    }

    private decimal CalculateUpgradePrice(ServicePackage package)
    {
        if (_currentSubscription?.ServicePackage == null || _currentSubscription.EndDate <= DateTime.UtcNow)
            return package.Price;

        double remainingDays = (_currentSubscription.EndDate - DateTime.UtcNow).TotalDays;
        if (remainingDays <= 0) return package.Price;

        // Công thức Prorated Charge: 
        // Phí nâng cấp = (Đơn giá ngày gói mới - Đơn giá ngày gói cũ) * Số ngày còn lại
        decimal oldDailyRate = _currentSubscription.PriceAtPurchase / _currentSubscription.ServicePackage.DurationDays;
        decimal newDailyRate = package.Price / package.DurationDays;

        if (newDailyRate <= oldDailyRate) return package.Price;

        decimal upgradeAmount = (decimal)remainingDays * (newDailyRate - oldDailyRate);
        
        // Làm tròn và đảm bảo tối thiểu (ví dụ 2000đ cho PayOS)
        return Math.Max(2000, Math.Round(upgradeAmount, 0));
    }

    private async Task Subscribe(ServicePackage package)
    {
        if (package.Price == 0 || package.IsDefault)
        {
            try
            {
                _loading = true;
                StateHasChanged();
                if (_currentUserId == null) return;
                
                var request = new { UserId = _currentUserId.Value };
                var res = await Http.PostAsJsonAsync("api/subscriptions/subscribe-default", request);
                if (res.IsSuccessStatusCode)
                {
                    Snackbar.Add($"Đã đăng ký gói {package.Name} thành công!", Severity.Success);
                    Navigation.NavigateTo("/", forceLoad: true); // Force reload to update roles
                }
                else
                {
                    Snackbar.Add("Lỗi khi đăng ký gói miễn phí.", Severity.Error);
                }
            }
            finally
            {
                _loading = false;
                StateHasChanged();
            }
            return;
        }

        bool isUpgrade = _currentSubscription != null && package.Price > _currentSubscription.ServicePackage?.Price;
        decimal displayPrice = isUpgrade ? CalculateUpgradePrice(package) : package.Price;
        string type = isUpgrade ? "Upgrade" : "New";

        string message = isUpgrade 
            ? $"Bạn muốn nâng cấp lên gói <b>{package.Name}</b>?<br/>Phí quy đổi cho <b>{GetRemainingDays(_currentSubscription!.EndDate)}</b> còn lại là: <b>{displayPrice:N0} VND</b>.<br/><small>(Thời hạn gói vẫn giữ nguyên đến {(_currentSubscription.EndDate).ToString("dd/MM/yyyy")})</small>"
            : $"Bạn muốn đăng ký gói <b>{package.Name}</b> với giá <b>{package.Price:N0} VND</b>?";

        bool? confirm = await DialogService.ShowMessageBox(
            isUpgrade ? "Xác nhận nâng cấp chuyên nghiệp" : "Xác nhận đăng ký", 
            (MarkupString)message, 
            yesText: "Xác nhận", cancelText: "Hủy");

        if (confirm == true)
        {
            try 
            {
                _loading = true;
                StateHasChanged();

                if (_currentUserId == null)
                {
                    Snackbar.Add("Không tìm thấy thông tin người dùng. Vui lòng đăng nhập lại.", Severity.Error);
                    return;
                }

                var request = new { UserId = _currentUserId.Value, PackageCode = package.Code, Type = type };
                var response = await Http.PostAsJsonAsync("api/payments/create-payment", request);
                
                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<PaymentRedirectResponse>();
                    if (result != null && !string.IsNullOrEmpty(result.PaymentUrl))
                    {
                        // Chuyển hướng sang trang thanh toán PayOS
                        Navigation.NavigateTo(result.PaymentUrl);
                    }
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Lỗi: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add("Lỗi kết nối: " + ex.Message, Severity.Error);
            }
            finally
            {
                _loading = false;
                StateHasChanged();
            }
        }
    }

    private string GetRemainingDays(DateTime endDate)
    {
        var remaining = endDate - DateTime.UtcNow;
        if (remaining.TotalSeconds <= 0) return "Đã hết hạn";
        if (remaining.TotalDays >= 1) return $"Còn {(int)remaining.TotalDays} ngày";
        return $"Còn {(int)remaining.TotalHours} giờ";
    }

    private async Task ContinueWithDefault()
    {
        var defaultPackage = _packages.FirstOrDefault(p => p.IsDefault);
        if (defaultPackage != null)
        {
            await Subscribe(defaultPackage);
        }
        else
        {
            Snackbar.Add("Không tìm thấy gói mặc định", Severity.Warning);
        }
    }

    public class PaymentRedirectResponse
    {
        public string PaymentUrl { get; set; } = "";
    }
}
