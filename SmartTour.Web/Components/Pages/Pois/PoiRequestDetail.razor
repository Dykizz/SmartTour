@page "/poi-requests/{RequestId:int}"
@using SmartTour.Shared.Models
@using SmartTour.Web.Services
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using System.Text.Json
@attribute [Authorize(Roles = "ADMIN")]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IMapService MapService
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Chi tiết yêu cầu #@RequestId</PageTitle>

@if (_loading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    </MudContainer>
}
else if (_request == null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
        <MudAlert Severity="Severity.Error">Không tìm thấy yêu cầu #@RequestId</MudAlert>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-20 animate-fade-in">

        <!-- ── Header ── -->
        <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl"
                  Style="background: linear-gradient(135deg, rgba(var(--mud-palette-primary-rgb),0.06) 0%, rgba(var(--mud-palette-primary-rgb),0.02) 100%); border: 1px solid rgba(var(--mud-palette-primary-rgb),0.12);">
            <div class="d-flex align-center justify-space-between flex-wrap gap-4">
                <div class="d-flex align-center">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack"
                                   Variant="Variant.Filled" Color="Color.Surface" Class="mr-4" />
                    <div>
                        <MudText Typo="Typo.h6" Class="mb-1">
                            Chi tiết yêu cầu #@_request.Id
                        </MudText>
                        <div class="d-flex align-center gap-2 flex-wrap">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_request.Type == RequestType.Create ? Color.Primary : Color.Info)"
                                     Variant="Variant.Filled">
                                @(_request.Type == RequestType.Create ? "Tạo mới" : "Cập nhật")
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="@StatusColor(_request.Status)" Variant="Variant.Filled">
                                @StatusText(_request.Status)
                            </MudChip>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Gửi bởi <b>@(_request.User?.FullName ?? "—")</b> lúc @_request.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                        </div>
                    </div>
                </div>

                @if (_request.Status == RequestStatus.Pending)
                {
                    <div class="d-flex gap-2">
                        <MudTooltip Text="Từ chối yêu cầu">
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error"
                                           Size="Size.Medium" OnClick="OpenRejectDialog" />
                        </MudTooltip>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="ApproveRequest" Disabled="_actioning">
                            @if (_actioning) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" /> }
                            else { <span>Duyệt</span> }
                        </MudButton>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_request.AdminNote))
                {
                    <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border: 1px dashed var(--mud-palette-divider); max-width:320px;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Ghi chú Admin</MudText>
                        <MudText Typo="Typo.body2">@_request.AdminNote</MudText>
                    </MudPaper>
                }
            </div>
        </MudPaper>

        <MudExpansionPanels MultiExpansion="true" Elevation="0">

            <!-- ── Section 1: Thông tin cơ bản ── -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                <MudExpansionPanel Expanded="true" Style="background:white;">
                    <TitleContent>
                        <div class="d-flex align-center py-1">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" />
                            </MudAvatar>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.subtitle1" Class="mb-0">Cấu hình cơ bản</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Thông tin chính của điểm đến</MudText>
                            </div>
                            <MudChip T="string" Color="@(_poi.IsActive ? Color.Success : Color.Error)"
                                     Size="Size.Small" Variant="Variant.Filled" Class="mr-2">
                                @(_poi.IsActive ? "Đang hoạt động" : "Tạm ẩn")
                            </MudChip>
                            @if (_poi.IsFeature)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Medium" Class="mr-2" />
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Tên điểm đến</MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight:600;">@_poi.Name</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Loại hình</MudText>
                                    <MudText Typo="Typo.body1">@(_poi.Category?.Name ?? GetCategoryName(_poi.CategoryId))</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Bán kính geofence</MudText>
                                    <MudText Typo="Typo.body1">@_poi.GeofenceRadius m</MudText>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Mã QR định danh</MudText>
                                    <MudText Typo="Typo.body2" Style="font-family:monospace; background:#f5f5f5; padding:6px 10px; border-radius:6px; display:inline-block;">
                                        @(_poi.QrValue ?? "—")
                                    </MudText>
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Trạng thái</MudText>
                                    <MudChip T="string" Color="@(_poi.IsActive ? Color.Success : Color.Error)"
                                             Size="Size.Small" Variant="Variant.Filled">
                                        @(_poi.IsActive ? "Hoạt động" : "Tạm dừng")
                                    </MudChip>
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Nổi bật</MudText>
                                    <MudChip T="string" Color="@(_poi.IsFeature ? Color.Warning : Color.Default)"
                                             Size="Size.Small" Variant="Variant.Outlined">
                                        @(_poi.IsFeature ? "⭐ Nổi bật" : "Thường")
                                    </MudChip>
                                </MudItem>
                            </MudGrid>
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>

            <!-- ── Section 2: Vị trí & Bản đồ ── -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                <MudExpansionPanel Expanded="true" Style="background:white;">
                    <TitleContent>
                        <div class="d-flex align-center py-1">
                            <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Medium" />
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.subtitle1" Class="mb-0">Vị trí địa lý</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Toạ độ và vùng geofence</MudText>
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                            <MudGrid Spacing="3" Class="mb-4">
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Vĩ độ (Lat)</MudText>
                                    <MudText Typo="Typo.body1" Style="font-family:monospace;">@_poi.Latitude.ToString("F6")</MudText>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Kinh độ (Lng)</MudText>
                                    <MudText Typo="Typo.body1" Style="font-family:monospace;">@_poi.Longitude.ToString("F6")</MudText>
                                </MudItem>
                            </MudGrid>
                            <div id="detail-map" style="height:280px; width:100%; border-radius:12px; border:1px solid var(--mud-palette-divider);"></div>
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>

            <!-- ── Section 3: Hình ảnh ── -->
            @if (_poi.Images.Any())
            {
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                    <MudExpansionPanel Expanded="true" Style="background:white;">
                        <TitleContent>
                            <div class="d-flex align-center py-1">
                                <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Medium" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">Bộ sưu tập hình ảnh</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_poi.Images.Count ảnh đính kèm</MudText>
                                </div>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                                <MudGrid Spacing="2">
                                    @foreach (var img in _poi.Images.OrderBy(x => x.SortOrder))
                                    {
                                        <MudItem xs="6" md="4" lg="3">
                                            <MudCard Outlined="true" Class="rounded-lg" Style="overflow:hidden; position:relative;">
                                                <div style="height:140px; overflow:hidden; position:relative;">
                                                    @if (!string.IsNullOrEmpty(img.ImageUrl))
                                                    {
                                                        <MudImage Src="@img.ImageUrl" Style="height:100%; width:100%;" ObjectFit="ObjectFit.Cover" />
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex align-center justify-center" style="height:100%; background:#f0f0f0;">
                                                            <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Color="Color.Default" />
                                                        </div>
                                                    }
                                                    @if (img.IsThumbnail)
                                                    {
                                                        <div style="position:absolute; top:6px; right:6px; background:rgba(255,193,7,0.9); border-radius:4px; padding:2px 8px;">
                                                            <MudText Typo="Typo.caption" Style="color:white; font-weight:700;">CHÍNH</MudText>
                                                        </div>
                                                    }
                                                </div>
                                            </MudCard>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudPaper>
            }

            <!-- ── Section 4: Mô tả đa ngôn ngữ ── -->
            @if (_poi.Contents.Any())
            {
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                    <MudExpansionPanel Expanded="true" Style="background:white;">
                        <TitleContent>
                            <div class="d-flex align-center py-1">
                                <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Medium" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">Chi tiết & Mô tả đa ngôn ngữ</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_poi.Contents.Count ngôn ngữ</MudText>
                                </div>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
                                         Border="true" PanelClass="pa-4" MinimumTabWidth="80px">
                                    @foreach (var content in _poi.Contents)
                                    {
                                        <MudTabPanel Text="@content.LanguageCode.ToUpper()">
                                            @if (string.IsNullOrWhiteSpace(content.Description))
                                            {
                                                <MudAlert Severity="Severity.Info" Dense="true">Chưa có nội dung.</MudAlert>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Style="white-space:pre-wrap; line-height:1.8;">@content.Description</MudText>
                                            }
                                        </MudTabPanel>
                                    }
                                </MudTabs>
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudPaper>
            }

            <!-- ── Section 5: Giờ mở cửa ── -->
            @if (_poi.OperatingHours.Any())
            {
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                    <MudExpansionPanel Expanded="false" Style="background:white;">
                        <TitleContent>
                            <div class="d-flex align-center py-1">
                                <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Medium" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">Giờ mở cửa hàng tuần</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Lịch hoạt động theo ngày</MudText>
                                </div>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                                @foreach (var day in _poi.OperatingHours.OrderBy(x => x.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)x.DayOfWeek))
                                {
                                    <div class="d-flex align-center py-3" style="border-bottom:1px solid var(--mud-palette-divider);">
                                        <div style="width:110px;" class="d-flex align-center gap-2">
                                            <MudIcon Icon="@(day.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RemoveCircle)"
                                                     Color="@(day.IsActive ? Color.Success : Color.Default)"
                                                     Size="Size.Small" />
                                            <MudText Typo="Typo.body2" Style="@(!day.IsActive ? "color:var(--mud-palette-text-disabled)" : "")">
                                                @TranslateDay(day.DayOfWeek)
                                            </MudText>
                                        </div>
                                        @if (day.IsActive)
                                        {
                                            <MudText Typo="Typo.body2" Style="font-family:monospace; font-weight:600;">
                                                @(day.OpenTime?.ToString(@"hh\:mm") ?? "—") — @(day.CloseTime?.ToString(@"hh\:mm") ?? "—")
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Default">Đóng cửa</MudText>
                                        }
                                    </div>
                                }
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudPaper>
            }

        </MudExpansionPanels>

        <!-- ── Sticky footer action bar ── -->
        @if (_request.Status == RequestStatus.Pending)
        {
            <div style="position:fixed; bottom:0; left:0; right:0; background:rgba(255,255,255,0.95); backdrop-filter:blur(8px); border-top:1px solid var(--mud-palette-divider); z-index:100;"
                 class="py-3 d-flex justify-center gap-4 px-6">
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Cancel"
                           OnClick="OpenRejectDialog">Từ chối</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="ApproveRequest" Disabled="_actioning">
                    @if (_actioning) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" /> }
                    else { <span>Duyệt yêu cầu</span> }
                </MudButton>
            </div>
        }

    </MudContainer>
}

<style>
    .animate-fade-in { animation: fadeIn 0.5s cubic-bezier(0.4,0,0.2,1); }
    @@keyframes fadeIn { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
    .stagger-item { animation: staggerFadeIn 0.4s cubic-bezier(0.4,0,0.2,1) backwards; }
    .stagger-item:nth-child(1) { animation-delay: 0.04s; }
    .stagger-item:nth-child(2) { animation-delay: 0.08s; }
    .stagger-item:nth-child(3) { animation-delay: 0.12s; }
    .stagger-item:nth-child(4) { animation-delay: 0.16s; }
    .stagger-item:nth-child(5) { animation-delay: 0.20s; }
    @@keyframes staggerFadeIn { from { opacity:0; transform:translateX(-8px); } to { opacity:1; transform:translateX(0); } }
    .mud-expansion-panel { border-radius:12px !important; transition:all 0.3s ease; }
    .mud-expansion-panel:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08) !important; }
</style>

@code {
    [Parameter] public int RequestId { get; set; }

    private PoiRequest? _request;
    private Poi _poi = new();
    private List<Category> _categories = new();
    private bool _loading = true;
    private bool _actioning = false;
    private bool _mapInitialized = false;
    private DotNetObjectReference<PoiRequestDetail>? _objRef;

    private static readonly JsonSerializerOptions _jsonOpts = new()
    {
        PropertyNameCaseInsensitive = true,
        ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles
    };

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _categories = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
            _request = await Http.GetFromJsonAsync<PoiRequest>($"api/poi-requests/{RequestId}");

            if (_request != null && !string.IsNullOrEmpty(_request.RequestData))
            {
                _poi = JsonSerializer.Deserialize<Poi>(_request.RequestData, _jsonOpts) ?? new();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải dữ liệu: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_mapInitialized && _poi.Latitude != 0)
        {
            await Task.Delay(400);
            _objRef = DotNetObjectReference.Create(this);
            await MapService.InitMapAsync(_poi.Latitude, _poi.Longitude, "detail-map", _objRef);
            _mapInitialized = true;
        }
    }

    private async Task ApproveRequest()
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận duyệt",
            $"Duyệt yêu cầu #{_request?.Id} của {_request?.User?.FullName}? Hành động này sẽ tạo/cập nhật POI thực sự.",
            yesText: "Duyệt", cancelText: "Hủy");
        if (confirm != true) return;

        _actioning = true;
        try
        {
            var response = await Http.PostAsJsonAsync(
                $"api/poi-requests/{RequestId}/approve",
                new { Note = (string?)null });

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Đã duyệt yêu cầu! POI đã được tạo/cập nhật.", Severity.Success);
                NavigationManager.NavigateTo("/poi-requests");
            }
            else
            {
                Snackbar.Add("Lỗi: " + await response.Content.ReadAsStringAsync(), Severity.Error);
            }
        }
        finally
        {
            _actioning = false;
        }
    }

    private async Task OpenRejectDialog()
    {
        if (_request == null) return;
        var parameters = new DialogParameters<RejectReasonDialog>
        {
            { x => x.RequestId, _request.Id },
            { x => x.RequesterName, _request.User?.FullName ?? "Seller" }
        };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<RejectReasonDialog>("Từ chối yêu cầu", parameters, opts);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            NavigationManager.NavigateTo("/poi-requests");
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/poi-requests");

    [JSInvokable]
    public void UpdateCoordinates(double lat, double lng) { /* read-only */ }

    public void Dispose() => _objRef?.Dispose();

    private string GetCategoryName(int id) =>
        _categories.FirstOrDefault(c => c.Id == id)?.Name ?? $"ID:{id}";

    private Color StatusColor(RequestStatus s) => s switch
    {
        RequestStatus.Pending  => Color.Warning,
        RequestStatus.Approved => Color.Success,
        RequestStatus.Rejected => Color.Error,
        _ => Color.Default
    };

    private string StatusText(RequestStatus s) => s switch
    {
        RequestStatus.Pending  => "⏳ Đang chờ",
        RequestStatus.Approved => "✅ Đã duyệt",
        RequestStatus.Rejected => "❌ Đã từ chối",
        _ => s.ToString()
    };

    private string TranslateDay(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday    => "Thứ Hai",
        DayOfWeek.Tuesday   => "Thứ Ba",
        DayOfWeek.Wednesday => "Thứ Tư",
        DayOfWeek.Thursday  => "Thứ Năm",
        DayOfWeek.Friday    => "Thứ Sáu",
        DayOfWeek.Saturday  => "Thứ Bảy",
        DayOfWeek.Sunday    => "Chủ Nhật",
        _ => day.ToString()
    };
}
