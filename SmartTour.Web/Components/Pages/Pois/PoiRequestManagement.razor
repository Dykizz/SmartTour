@page "/poi-requests"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@using System.Text.Json
@attribute [Authorize(Roles = "ADMIN")]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Danh sách yêu cầu POI</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mb-1">Danh sách yêu cầu POI</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">Xem xét và phê duyệt các yêu cầu tạo/sửa điểm đến của Seller.</MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

        <!-- TAB 1: Đang chờ xử lý -->
        <MudTabPanel Text="Đang chờ" Icon="@Icons.Material.Filled.HourglassEmpty"
                     BadgeData="@(_pending.Count > 0 ? _pending.Count.ToString() : null)"
                     BadgeColor="Color.Warning">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
            }
            else if (!_pending.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">Không có yêu cầu nào đang chờ xử lý.</MudAlert>
            }
            else
            {
                <MudTable Items="_pending" Hover="true" Elevation="0" Class="mt-2">
                    <HeaderContent>
                        <MudTh>#</MudTh>
                        <MudTh>Người gửi</MudTh>
                        <MudTh>Tên POI đề xuất</MudTh>
                        <MudTh>Loại</MudTh>
                        <MudTh>Gửi lúc</MudTh>
                        <MudTh Style="text-align:right">Thao tác</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="req">
                        <MudTd>#@req.Id</MudTd>
                        <MudTd>@(req.User?.FullName ?? req.UserId.ToString())</MudTd>
                        <MudTd><MudText Typo="Typo.body2" Style="font-weight:600;">@GetPoiName(req)</MudText></MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(req.Type == RequestType.Create ? Color.Primary : Color.Info)"
                                     Variant="Variant.Filled">
                                @(req.Type == RequestType.Create ? "Tạo mới" : "Cập nhật")
                            </MudChip>
                        </MudTd>
                        <MudTd>@req.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                        <MudTd Style="text-align:right">
                            <MudTooltip Text="Xem chi tiết">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenViewDetail(req))" />
                            </MudTooltip>
                            <MudTooltip Text="Duyệt nhanh">
                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" OnClick="@(() => ApproveRequest(req))" />
                            </MudTooltip>
                            <MudTooltip Text="Từ chối">
                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" OnClick="@(() => RejectRequest(req))" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <!-- TAB 2: Đã duyệt -->
        <MudTabPanel Text="Đã duyệt" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
            @if (!_approved.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">Chưa có yêu cầu nào được duyệt.</MudAlert>
            }
            else
            {
                <MudTable Items="_approved" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>#</MudTh>
                        <MudTh>Người gửi</MudTh>
                        <MudTh>Tên POI</MudTh>
                        <MudTh>Ghi chú Admin</MudTh>
                        <MudTh>Cập nhật lúc</MudTh>
                        <MudTh Style="text-align:right">Chi tiết</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="req">
                        <MudTd>#@req.Id</MudTd>
                        <MudTd>@(req.User?.FullName ?? req.UserId.ToString())</MudTd>
                        <MudTd><MudText Typo="Typo.body2" Style="font-weight:600;">@GetPoiName(req)</MudText></MudTd>
                        <MudTd>@(req.AdminNote ?? "—")</MudTd>
                        <MudTd>@(req.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</MudTd>
                        <MudTd Style="text-align:right">
                            <MudTooltip Text="Xem chi tiết">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenViewDetail(req))" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <!-- TAB 3: Đã từ chối -->
        <MudTabPanel Text="Đã từ chối" Icon="@Icons.Material.Filled.Cancel" IconColor="Color.Error">
            @if (!_rejected.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">Chưa có yêu cầu nào bị từ chối.</MudAlert>
            }
            else
            {
                <MudTable Items="_rejected" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>#</MudTh>
                        <MudTh>Người gửi</MudTh>
                        <MudTh>Tên POI</MudTh>
                        <MudTh>Lý do từ chối</MudTh>
                        <MudTh>Cập nhật lúc</MudTh>
                        <MudTh Style="text-align:right">Chi tiết</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="req">
                        <MudTd>#@req.Id</MudTd>
                        <MudTd>@(req.User?.FullName ?? req.UserId.ToString())</MudTd>
                        <MudTd><MudText Typo="Typo.body2" Style="font-weight:600;">@GetPoiName(req)</MudText></MudTd>
                        <MudTd>@(req.AdminNote ?? "—")</MudTd>
                        <MudTd>@(req.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</MudTd>
                        <MudTd Style="text-align:right">
                            <MudTooltip Text="Xem chi tiết">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenViewDetail(req))" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private List<PoiRequest> _all = new();
    private List<PoiRequest> _pending = new();
    private List<PoiRequest> _approved = new();
    private List<PoiRequest> _rejected = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadRequests();

    private async Task LoadRequests()
    {
        _loading = true;
        try
        {
            _all      = await Http.GetFromJsonAsync<List<PoiRequest>>("api/poi-requests") ?? new();
            _pending  = _all.Where(r => r.Status == RequestStatus.Pending).ToList();
            _approved = _all.Where(r => r.Status == RequestStatus.Approved).ToList();
            _rejected = _all.Where(r => r.Status == RequestStatus.Rejected).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải yêu cầu: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenViewDetail(PoiRequest req)
        => NavigationManager.NavigateTo($"/poi-requests/{req.Id}");

    private static readonly JsonSerializerOptions _jsonOpts = new() { PropertyNameCaseInsensitive = true };

    private string GetPoiName(PoiRequest req)
    {
        try
        {
            var poi = JsonSerializer.Deserialize<Poi>(req.RequestData, _jsonOpts);
            return poi?.Name ?? "—";
        }
        catch { return "—"; }
    }

    private async Task ApproveRequest(PoiRequest req)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận duyệt",
            $"Duyệt yêu cầu #{req.Id} của {req.User?.FullName ?? "Seller"}?",
            yesText: "Duyệt", cancelText: "Hủy");

        if (confirm == true)
        {
            var response = await Http.PostAsJsonAsync($"api/poi-requests/{req.Id}/approve", new { Note = "Đã duyệt" });
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Đã duyệt yêu cầu thành công!", Severity.Success);
                await LoadRequests();
            }
            else
            {
                Snackbar.Add("Lỗi khi duyệt: " + await response.Content.ReadAsStringAsync(), Severity.Error);
            }
        }
    }

    private async Task RejectRequest(PoiRequest req)
    {
        var parameters = new DialogParameters<RejectReasonDialog>
        {
            { x => x.RequestId, req.Id },
            { x => x.RequesterName, req.User?.FullName ?? "Seller" }
        };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<RejectReasonDialog>("Từ chối yêu cầu", parameters, opts);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadRequests();
        }
    }
}
