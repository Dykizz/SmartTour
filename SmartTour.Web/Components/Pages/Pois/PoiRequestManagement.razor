@page "/poi-requests"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@using System.Text.Json
@attribute [Authorize(Roles = "ADMIN")]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Quản lý Yêu cầu POI</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mb-1">Quản lý Yêu cầu POI</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">Xem xét và phê duyệt các yêu cầu tạo/sửa điểm đến của Seller.</MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

        <!-- TAB 1: Đang chờ xử lý -->
        <MudTabPanel Text="Chờ duyệt" Icon="@Icons.Material.Filled.HourglassEmpty" IconColor="Color.Warning"
                     BadgeData="@(_pendingCount > 0 ? _pendingCount.ToString() : null)"
                     BadgeColor="Color.Warning">
            <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<PoiRequest>>>((state, token) => ReloadRequests(state, RequestStatus.Pending)))" 
                      Hover="true" Elevation="0" Class="mt-2" Breakpoint="Breakpoint.Sm" @ref="_tablePending">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Người gửi</MudTh>
                    <MudTh>Tên POI đề xuất</MudTh>
                    <MudTh>Loại</MudTh>
                    <MudTh>Gửi lúc</MudTh>
                    <MudTh Style="width:120px">Thao tác</MudTh>
                </HeaderContent>
                <RowTemplate Context="req">
                    <MudTd DataLabel="ID">@req.Id</MudTd>
                    <MudTd DataLabel="Người gửi">@(req.User?.FullName ?? req.UserId.ToString())</MudTd>
                    <MudTd DataLabel="Tên POI"><MudText Typo="Typo.body2" Style="font-weight:600;">@GetPoiName(req)</MudText></MudTd>
                    <MudTd DataLabel="Loại">
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(req.Type == RequestType.Create ? Color.Primary : Color.Info)"
                                 Variant="Variant.Filled">
                            @(req.Type == RequestType.Create ? "Tạo mới" : "Cập nhật")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Gửi lúc">@req.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Thao tác">
                        <div class="d-flex">
                            <MudTooltip Text="Xem chi tiết">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenViewDetail(req))" />
                            </MudTooltip>
                            <MudTooltip Text="Duyệt nhanh">
                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" OnClick="@(() => ApproveRequest(req))" />
                            </MudTooltip>
                            <MudTooltip Text="Từ chối">
                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" OnClick="@(() => RejectRequest(req))" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager RowsPerPageString="Số dòng mỗi trang:" InfoFormat="{first_item}-{last_item} của {all_items}" />
                </PagerContent>
                <NoRecordsContent>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">Không có yêu cầu nào đang chờ xử lý.</MudAlert>
                </NoRecordsContent>
            </MudTable>
        </MudTabPanel>

        <!-- TAB 2: Đã duyệt -->
        <MudTabPanel Text="Đã duyệt" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success"
                     BadgeData="@(_approvedCount > 0 ? _approvedCount.ToString() : null)"
                     BadgeColor="Color.Success">
            <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<PoiRequest>>>((state, token) => ReloadRequests(state, RequestStatus.Approved)))" 
                      Hover="true" Elevation="0" Breakpoint="Breakpoint.Sm" @ref="_tableApproved">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Người gửi</MudTh>
                    <MudTh>Tên POI</MudTh>
                    <MudTh>Ghi chú Admin</MudTh>
                    <MudTh>Cập nhật lúc</MudTh>
                    <MudTh Style="width:120px">Thao tác</MudTh>
                </HeaderContent>
                <RowTemplate Context="req">
                    <MudTd DataLabel="ID">@req.Id</MudTd>
                    <MudTd DataLabel="Người gửi">@(req.User?.FullName ?? req.UserId.ToString())</MudTd>
                    <MudTd DataLabel="Tên POI"><MudText Typo="Typo.body2" Style="font-weight:600;">@GetPoiName(req)</MudText></MudTd>
                    <MudTd DataLabel="Ghi chú">@(req.AdminNote ?? "—")</MudTd>
                    <MudTd DataLabel="Cập nhật lúc">@(req.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</MudTd>
                    <MudTd DataLabel="Thao tác">
                        <div class="d-flex">
                            <MudTooltip Text="Xem chi tiết">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenViewDetail(req))" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager RowsPerPageString="Số dòng mỗi trang:" InfoFormat="{first_item}-{last_item} của {all_items}" />
                </PagerContent>
                <NoRecordsContent>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">Chưa có yêu cầu nào được duyệt.</MudAlert>
                </NoRecordsContent>
            </MudTable>
        </MudTabPanel>

        <!-- TAB 3: Đã từ chối -->
        <MudTabPanel Text="Bị từ chối" Icon="@Icons.Material.Filled.Cancel" IconColor="Color.Error"
                     BadgeData="@(_rejectedCount > 0 ? _rejectedCount.ToString() : null)"
                     BadgeColor="Color.Error">
            <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<PoiRequest>>>((state, token) => ReloadRequests(state, RequestStatus.Rejected)))" 
                      Hover="true" Elevation="0" Breakpoint="Breakpoint.Sm" @ref="_tableRejected">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Người gửi</MudTh>
                    <MudTh>Tên POI</MudTh>
                    <MudTh>Lý do từ chối</MudTh>
                    <MudTh>Cập nhật lúc</MudTh>
                    <MudTh Style="width:120px">Thao tác</MudTh>
                </HeaderContent>
                <RowTemplate Context="req">
                    <MudTd DataLabel="ID">@req.Id</MudTd>
                    <MudTd DataLabel="Người gửi">@(req.User?.FullName ?? req.UserId.ToString())</MudTd>
                    <MudTd DataLabel="Tên POI"><MudText Typo="Typo.body2" Style="font-weight:600;">@GetPoiName(req)</MudText></MudTd>
                    <MudTd DataLabel="Lý do">@(req.AdminNote ?? "—")</MudTd>
                    <MudTd DataLabel="Cập nhật lúc">@(req.UpdatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</MudTd>
                    <MudTd DataLabel="Thao tác">
                        <div class="d-flex">
                            <MudTooltip Text="Xem chi tiết">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenViewDetail(req))" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager RowsPerPageString="Số dòng mỗi trang:" InfoFormat="{first_item}-{last_item} của {all_items}" />
                </PagerContent>
                <NoRecordsContent>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">Chưa có yêu cầu nào bị từ chối.</MudAlert>
                </NoRecordsContent>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private int _pendingCount, _approvedCount, _rejectedCount;
    private bool _loading = true;
    private MudTable<PoiRequest> _tablePending, _tableApproved, _tableRejected;

    protected override async Task OnInitializedAsync() => await LoadCounts();

    private async Task LoadCounts()
    {
        // Tải số lượng badge (có thể tối ưu bằng API riêng, nhưng tạm thời dùng API paged pageSize=1)
        try 
        {
            var t = DateTime.UtcNow.Ticks;
            var p = await Http.GetFromJsonAsync<PagedResponse<PoiRequest>>($"api/poi-requests?status=Pending&pageSize=1&t={t}");
            var a = await Http.GetFromJsonAsync<PagedResponse<PoiRequest>>($"api/poi-requests?status=Approved&pageSize=1&t={t}");
            var r = await Http.GetFromJsonAsync<PagedResponse<PoiRequest>>($"api/poi-requests?status=Rejected&pageSize=1&t={t}");
            _pendingCount = p?.TotalCount ?? 0;
            _approvedCount = a?.TotalCount ?? 0;
            _rejectedCount = r?.TotalCount ?? 0;
            _loading = false;
            StateHasChanged();
        }
        catch { }
    }

    private async Task<TableData<PoiRequest>> ReloadRequests(TableState state, RequestStatus status)
    {
        try
        {
            var url = $"api/poi-requests?status={status}&pageNumber={state.Page + 1}&pageSize={state.PageSize}&t={DateTime.UtcNow.Ticks}";
            var response = await Http.GetFromJsonAsync<PagedResponse<PoiRequest>>(url);
            if (response != null)
            {
                // Cập nhật lại badge count khi load dữ liệu mới
                if (status == RequestStatus.Pending) _pendingCount = response.TotalCount;
                else if (status == RequestStatus.Approved) _approvedCount = response.TotalCount;
                else if (status == RequestStatus.Rejected) _rejectedCount = response.TotalCount;
                
                StateHasChanged();
                return new TableData<PoiRequest> { TotalItems = response.TotalCount, Items = response.Items };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải yêu cầu: " + ex.Message, Severity.Error);
        }
        return new TableData<PoiRequest> { TotalItems = 0, Items = Enumerable.Empty<PoiRequest>() };
    }

    private async Task RefreshAll()
    {
        if (_tablePending != null) await _tablePending.ReloadServerData();
        if (_tableApproved != null) await _tableApproved.ReloadServerData();
        if (_tableRejected != null) await _tableRejected.ReloadServerData();
        await LoadCounts();
    }

    private void OpenViewDetail(PoiRequest req)
        => NavigationManager.NavigateTo($"/poi-requests/{req.Id}");

    private static readonly JsonSerializerOptions _jsonOpts = new() { PropertyNameCaseInsensitive = true };

    private string GetPoiName(PoiRequest req)
    {
        try
        {
            var poi = JsonSerializer.Deserialize<Poi>(req.RequestData, _jsonOpts);
            return poi?.Name ?? "—";
        }
        catch { return "—"; }
    }

    private async Task ApproveRequest(PoiRequest req)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận duyệt",
            $"Duyệt yêu cầu #{req.Id} của {req.User?.FullName ?? "Seller"}?",
            yesText: "Duyệt", cancelText: "Hủy");

        if (confirm == true)
        {
            var response = await Http.PostAsJsonAsync($"api/poi-requests/{req.Id}/approve", new { Note = "Đã duyệt" });
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Đã duyệt yêu cầu thành công!", Severity.Success);
                await RefreshAll();
            }
            else
            {
                Snackbar.Add("Lỗi khi duyệt: " + await response.Content.ReadAsStringAsync(), Severity.Error);
            }
        }
    }

    private async Task RejectRequest(PoiRequest req)
    {
        var parameters = new DialogParameters<RejectReasonDialog>
        {
            { x => x.RequestId, req.Id },
            { x => x.RequesterName, req.User?.FullName ?? "Seller" }
        };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<RejectReasonDialog>("Từ chối yêu cầu", parameters, opts);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await RefreshAll();
        }
    }
}
}
