@page "/poi-management"
@using Microsoft.AspNetCore.Components.Authorization
@using SmartTour.Shared.Models
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Quản lý POI</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">

    @if (_isAdmin)
    {
        <!-- ============ ADMIN VIEW ============ -->
        <div class="d-flex align-center justify-space-between mb-6">
            <div class="d-flex align-center gap-3">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                    <MudIcon Icon="@Icons.Material.Filled.Map" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h5" Style="font-weight:700; letter-spacing:-0.5px;">Quản lý toàn bộ POI</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Theo dõi và quản lý dữ liệu điểm đến trên hệ thống.</MudText>
                </div>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="NavigateToCreate">Thêm điểm mới</MudButton>
        </div>

        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4 rounded-xl bg-gray-50">
            <div class="d-flex flex-wrap align-center gap-4">
                <MudTextField T="string" Value="@_searchString" ValueChanged="OnSearchDebounced"
                              Placeholder="Tìm theo tên hoặc danh mục..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Immediate="true" DebounceInterval="500" 
                              Clearable="true" OnClearButtonClick="ResetFilters"
                              Style="background-color: white; min-width: 250px; max-width: 350px;" />

                <MudSelect T="int?" Value="@_filterCategoryId" ValueChanged="@(async v => await OnCategoryChanged(v))"
                           Placeholder="Tất cả danh mục" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Clearable="true" Style="background-color: white; min-width: 180px;">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem T="int?" Value="@cat.Id">@cat.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="bool?" Value="@_filterOnlyActive" ValueChanged="@(async v => await OnStatusChanged(v))"
                           Placeholder="Tất cả trạng thái" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Clearable="true" Style="background-color: white; min-width: 180px;">
                    <MudSelectItem T="bool?" Value="true">Đang hoạt động</MudSelectItem>
                    <MudSelectItem T="bool?" Value="false">Ngừng hoạt động</MudSelectItem>
                </MudSelect>

                <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FilterListOff" OnClick="ResetFilters">Bỏ lọc</MudButton>
            </div>
        </MudPaper>

        <MudTabs ActivePanelIndex="@_adminActiveTab" ActivePanelIndexChanged="OnAdminTabChanged" Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" KeepPanelsAlive="true" Style="border: 1px solid var(--mud-palette-divider);">
            <MudTabPanel Text="Danh sách POI" Icon="@Icons.Material.Filled.List" IconColor="Color.Primary"
                         Style="padding-right: 28px;"
                         BadgeData="@(_adminPoisCount > 0 ? _adminPoisCount.ToString() : null)"
                         BadgeColor="Color.Primary">
                <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<Poi>>>(ReloadAdminPois))" 
                          Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Outlined="true" Class="rounded-xl" @ref="_adminTable">
                    <HeaderContent>
                        <MudTh>ID</MudTh>
                        <MudTh>Tên điểm đến</MudTh>
                        <MudTh>Loại hình</MudTh>
                        <MudTh>Tọa độ</MudTh>
                        <MudTh>Bán kính</MudTh>
                        <MudTh>Trạng thái</MudTh>
                        <MudTh Style="width:120px">Thao tác</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="poi">
                        <MudTd DataLabel="ID">@poi.Id</MudTd>
                        <MudTd DataLabel="Tên">@poi.Name</MudTd>
                        <MudTd DataLabel="Loại">@(poi.Category?.Name ?? "N/A")</MudTd>
                        <MudTd DataLabel="Tọa độ">@poi.Latitude.ToString("F4"), @poi.Longitude.ToString("F4")</MudTd>
                        <MudTd DataLabel="Bán kính">@poi.GeofenceRadius m</MudTd>
                        <MudTd DataLabel="Trạng thái">
                            <MudChip T="string" Color="@(poi.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                                @(poi.IsActive ? "Hoạt động" : "Tạm dừng")
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            <div class="d-flex">
                                <MudTooltip Text="Chỉnh sửa">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                   Size="Size.Small" OnClick="@(() => NavigateToEdit(poi.Id))" />
                                </MudTooltip>
                                <MudTooltip Text="Xóa">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                   Size="Size.Small" OnClick="@(() => DeletePoi(poi))" />
                                </MudTooltip>
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager RowsPerPageString="Số dòng mỗi trang:" InfoFormat="{first_item}-{last_item} của {all_items}" />
                    </PagerContent>
                    <NoRecordsContent>
                        <MudText Class="pa-4">Chưa có điểm POI nào.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudTabPanel>

            <MudTabPanel Text="Bản đồ Tổng quan" Icon="@Icons.Material.Filled.Map" IconColor="Color.Secondary">
                <div style="height: 60vh; width: 100%; border-radius: 8px; overflow: hidden; border: 1px solid var(--mud-palette-divider);">
                    <div id="admin-overview-map" style="width: 100%; height: 100%;"></div>
                </div>
            </MudTabPanel>
        </MudTabs>
    }
    else
    {
        <!-- ============ SELLER VIEW ============ -->
        <div class="d-flex align-center justify-space-between mb-6">
             <div class="d-flex align-center gap-3">
                <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium">
                    <MudIcon Icon="@Icons.Material.Filled.Place" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h5" Style="font-weight:700; letter-spacing:-0.5px;">POI của tôi</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Quản lý và đề xuất điểm đến của bạn.</MudText>
                </div>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Disabled="@( !_isAdmin && _maxPoiAllowed > 0 && (_myPoisCount + _pendingRequestsCount) >= _maxPoiAllowed )"
                       OnClick="NavigateToCreate">Gửi yêu cầu tạo mới</MudButton>
        </div>

        @if (!_isAdmin && _maxPoiAllowed > 0 && (_myPoisCount + _pendingRequestsCount) >= _maxPoiAllowed)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4 rounded-xl border-warning" Style="align-items: center;">
                <div class="d-flex align-center flex-wrap">
                    <span class="mr-2">Bạn đã sử dụng tối đa <b>@_maxPoiAllowed</b> Điểm đến (POI) của gói dịch vụ hiện tại.</span>
                    <MudButton Variant="Variant.Text" Color="Color.Warning" Class="font-bold py-1 px-2" OnClick="@(() => NavigationManager.NavigateTo("/pricing"))">Nâng cấp gói ngay</MudButton>
                </div>
            </MudAlert>
        }

        @if (_sellerActiveTab == 0 || _sellerActiveTab == 3)
        {
            <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4 rounded-xl bg-gray-50">
                <div class="d-flex flex-wrap align-center gap-4">
                    <MudTextField T="string" Value="@_searchString" ValueChanged="OnSearchDebounced"
                                  Placeholder="Tìm theo tên hoặc danh mục..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Immediate="true" DebounceInterval="500" 
                                  Clearable="true" OnClearButtonClick="ResetFilters"
                                  Style="background-color: white; min-width: 250px; max-width: 350px;" />

                    <MudSelect T="int?" Value="@_filterCategoryId" ValueChanged="@(async v => await OnCategoryChanged(v))"
                               Placeholder="Tất cả danh mục" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Clearable="true" Style="background-color: white; min-width: 180px;">
                        @foreach (var cat in _categories)
                        {
                            <MudSelectItem T="int?" Value="@cat.Id">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="bool?" Value="@_filterOnlyActive" ValueChanged="@(async v => await OnStatusChanged(v))"
                               Placeholder="Tất cả trạng thái" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Clearable="true" Style="background-color: white; min-width: 180px;">
                        <MudSelectItem T="bool?" Value="true">Đang hoạt động</MudSelectItem>
                        <MudSelectItem T="bool?" Value="false">Ngừng hoạt động</MudSelectItem>
                    </MudSelect>

                    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FilterListOff" OnClick="ResetFilters">Bỏ lọc</MudButton>
                </div>
            </MudPaper>
        }

        <MudTabs ActivePanelIndex="@_sellerActiveTab" ActivePanelIndexChanged="OnSellerTabChanged" Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4" KeepPanelsAlive="true" Style="border: 1px solid var(--mud-palette-divider);">

            <!-- Tab 1: Đã duyệt → hiển thị POI thực tế -->
            <MudTabPanel Text="Đã duyệt" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success"
                         Style="padding-right: 28px;"
                         BadgeData="@(_myPoisCount > 0 ? _myPoisCount.ToString() : null)"
                         BadgeColor="Color.Success">
                    <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<Poi>>>(ReloadSellerPois))" 
                              Hover="true" Elevation="0" Outlined="true" Class="rounded-xl" Breakpoint="Breakpoint.Sm" @ref="_sellerPoisTable">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Tên điểm đến</MudTh>
                            <MudTh>Loại hình</MudTh>
                            <MudTh>Bán kính</MudTh>
                            <MudTh>Trạng thái</MudTh>
                            <MudTh Style="width:120px">Thao tác</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="poi">
                            <MudTd DataLabel="ID">@poi.Id</MudTd>
                            <MudTd DataLabel="Tên">@poi.Name</MudTd>
                            <MudTd DataLabel="Loại">@(poi.Category?.Name ?? "N/A")</MudTd>
                            <MudTd DataLabel="Bán kính">@poi.GeofenceRadius m</MudTd>
                            <MudTd DataLabel="Trạng thái">
                                <MudChip T="string" Color="@(poi.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                                    @(poi.IsActive ? "Hoạt động" : "Tạm dừng")
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <div class="d-flex">
                                    <MudTooltip Text="Gửi yêu cầu chỉnh sửa">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                       Size="Size.Small" OnClick="@(() => NavigateToEdit(poi.Id))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Xóa POI">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                       Size="Size.Small" OnClick="@(() => DeletePoi(poi))" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager RowsPerPageString="Số dòng mỗi trang:" InfoFormat="{first_item}-{last_item} của {all_items}" />
                        </PagerContent>
                        <NoRecordsContent>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">Bạn chưa có POI nào được duyệt.</MudAlert>
                        </NoRecordsContent>
                    </MudTable>
            </MudTabPanel>

            <!-- Tab 2: Chờ duyệt -->
            <MudTabPanel Text="Chờ duyệt" Icon="@Icons.Material.Filled.HourglassEmpty" IconColor="Color.Warning"
                         Style="padding-right: 28px;"
                         BadgeData="@(_pendingRequestsCount > 0 ? _pendingRequestsCount.ToString() : null)"
                         BadgeColor="Color.Warning">
                    <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<PoiRequest>>>((state, token) => ReloadSellerRequests(state, RequestStatus.Pending)))" 
                              Hover="true" Elevation="0" Outlined="true" Class="rounded-xl" Breakpoint="Breakpoint.Sm" @ref="_pendingTable">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Tên POI đề xuất</MudTh>
                            <MudTh>Loại yêu cầu</MudTh>
                            <MudTh>Ngày gửi</MudTh>
                            <MudTh Style="width:120px">Thao tác</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="req">
                            <MudTd DataLabel="ID">@req.Id</MudTd>
                            <MudTd DataLabel="Tên">@GetPoiNameFromRequest(req)</MudTd>
                            <MudTd DataLabel="Loại">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(req.Type == RequestType.Create ? Color.Primary : Color.Info)">
                                     @(req.Type == RequestType.Create ? "Tạo mới" : "Cập nhật")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Gửi lúc">@req.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                            <MudTd DataLabel="Thao tác">
                                <div class="d-flex">
                                    <MudTooltip Text="Chỉnh sửa yêu cầu">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" 
                                                       Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/poi/editor?editingRequestId={req.Id}"))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Hủy yêu cầu">
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" 
                                                       Size="Size.Small" OnClick="@(() => CancelRequest(req))" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager RowsPerPageString="Số dòng mỗi trang:" InfoFormat="{first_item}-{last_item} của {all_items}" />
                        </PagerContent>
                        <NoRecordsContent>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">Không có yêu cầu nào đang chờ duyệt.</MudAlert>
                        </NoRecordsContent>
                    </MudTable>
            </MudTabPanel>

            <!-- Tab 3: Bị từ chối → có nút Gửi lại -->
            <MudTabPanel Text="Bị từ chối" Icon="@Icons.Material.Filled.Cancel" IconColor="Color.Error"
                         Style="padding-right: 28px;"
                         BadgeData="@(_rejectedRequestsCount > 0 ? _rejectedRequestsCount.ToString() : null)"
                         BadgeColor="Color.Error">
                    <MudTable ServerData="@(new Func<TableState, CancellationToken, Task<TableData<PoiRequest>>>((state, token) => ReloadSellerRequests(state, RequestStatus.Rejected)))" 
                              Hover="true" Elevation="0" Outlined="true" Class="rounded-xl" Breakpoint="Breakpoint.Sm" @ref="_rejectedTable">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Tên POI đề xuất</MudTh>
                            <MudTh>Loại yêu cầu</MudTh>
                            <MudTh>Lý do từ chối</MudTh>
                            <MudTh>Ngày gửi</MudTh>
                            <MudTh Style="width:120px">Thao tác</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="req">
                            <MudTd DataLabel="ID">@req.Id</MudTd>
                            <MudTd DataLabel="Tên">@GetPoiNameFromRequest(req)</MudTd>
                            <MudTd DataLabel="Loại">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(req.Type == RequestType.Create ? Color.Primary : Color.Info)">
                                    @(req.Type == RequestType.Create ? "Tạo mới" : "Cập nhật")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Lý do">@(req.AdminNote ?? "—")</MudTd>
                            <MudTd DataLabel="Gửi lúc">@req.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                            <MudTd DataLabel="Thao tác">
                                <div class="d-flex">
                                    <MudTooltip Text="Chỉnh sửa & Gửi lại">
                                        <MudIconButton Icon="@Icons.Material.Filled.EditNote" Color="Color.Warning"
                                                       Size="Size.Small"
                                                       OnClick="@(() => NavigationManager.NavigateTo($"/poi/editor?editingRequestId={req.Id}"))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Xóa yêu cầu">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                       Size="Size.Small" OnClick="@(() => CancelRequest(req))" />
                                    </MudTooltip>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager RowsPerPageString="Số dòng mỗi trang:" InfoFormat="{first_item}-{last_item} của {all_items}" />
                        </PagerContent>
                        <NoRecordsContent>
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">Không có yêu cầu nào bị từ chối.</MudAlert>
                        </NoRecordsContent>
                    </MudTable>
            </MudTabPanel>

            <MudTabPanel Text="Bản đồ của tôi" Icon="@Icons.Material.Filled.Map" IconColor="Color.Secondary">
                <div style="height: 60vh; width: 100%; border-radius: 8px; overflow: hidden; border: 1px solid var(--mud-palette-divider);">
                    <div id="seller-overview-map" style="width: 100%; height: 100%;"></div>
                </div>
            </MudTabPanel>

        </MudTabs>
    }

</MudContainer>

<style>
    .mud-tabs .mud-tab {
        overflow: visible !important;
    }
    .border-warning {
        border: 2px solid var(--mud-palette-warning) !important;
    }
    .font-bold {
        font-weight: 700 !important;
    }
</style>

@code {
    private int _myUserId = 0;
    private bool _isAdmin = false;
    private int _adminPoisCount, _myPoisCount, _pendingRequestsCount, _rejectedRequestsCount;
    private int _maxPoiAllowed = 0;

    private int _adminActiveTab = 0;
    private int _sellerActiveTab = 0;
    
    // Filters
    private string _searchString = string.Empty;
    private int? _filterCategoryId = null;
    private bool? _filterOnlyActive = null;
    
    private IEnumerable<Category> _categories = new List<Category>();

    private MudTable<Poi> _adminTable, _sellerPoisTable;
    private MudTable<PoiRequest> _pendingTable, _rejectedTable;

    private static readonly JsonSerializerOptions _jsonOpts = new() { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = auth.User.IsInRole("ADMIN");

        if (!_isAdmin)
        {
            var userIdStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            int.TryParse(userIdStr, out _myUserId);
        }

        try {
            _categories = await Http.GetFromJsonAsync<IEnumerable<Category>>("api/categories") ?? new List<Category>();
        } catch { }

        await LoadCounts();
    }

    private async Task LoadCounts()
    {
        try
        {
            var t = DateTime.UtcNow.Ticks;
            if (_isAdmin)
            {
                _adminPoisCount = await Http.GetFromJsonAsync<int>($"api/pois/count?t={t}");
            }
            else
            {
                if (_myUserId > 0)
                {
                    _myPoisCount = await Http.GetFromJsonAsync<int>($"api/pois/count?createdById={_myUserId}&t={t}");
                    try 
                    {
                        var sub = await Http.GetFromJsonAsync<Subscription>($"api/subscriptions/user/{_myUserId}?t={t}");
                        _maxPoiAllowed = sub?.ServicePackage?.MaxPoiAllowed ?? 0;
                    } 
                    catch { }
                }

                var counts = await Http.GetFromJsonAsync<Dictionary<string, int>>($"api/poi-requests/counts?t={t}");
                if (counts != null)
                {
                    _pendingRequestsCount = counts.GetValueOrDefault("Pending", 0);
                    _rejectedRequestsCount = counts.GetValueOrDefault("Rejected", 0);
                }
            }
            StateHasChanged();
        }
        catch { }
    }

    private async Task<TableData<Poi>> ReloadAdminPois(TableState state, CancellationToken token)
    {
        try
        {
            var url = $"api/pois?onlyActive=false&pageNumber={state.Page + 1}&pageSize={state.PageSize}";
            if (!string.IsNullOrWhiteSpace(_searchString)) url += $"&searchTerm={Uri.EscapeDataString(_searchString)}";
            if (_filterCategoryId.HasValue) url += $"&categoryId={_filterCategoryId.Value}";
            if (_filterOnlyActive.HasValue) url += $"&isActive={_filterOnlyActive.Value.ToString().ToLower()}";

            var response = await Http.GetFromJsonAsync<PagedResponse<Poi>>(url);
            if (response != null)
            {
                _adminPoisCount = response.TotalCount;
                StateHasChanged();
                await LoadMapDataAndRender();
                return new TableData<Poi> { TotalItems = response.TotalCount, Items = response.Items };
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi tải POI: " + ex.Message, Severity.Error); }
        return new TableData<Poi> { TotalItems = 0, Items = Enumerable.Empty<Poi>() };
    }

    private async Task<TableData<Poi>> ReloadSellerPois(TableState state, CancellationToken token)
    {
        if (_myUserId <= 0) return new TableData<Poi> { TotalItems = 0, Items = Enumerable.Empty<Poi>() };
        try
        {
            var url = $"api/pois?createdById={_myUserId}&onlyActive=false&pageNumber={state.Page + 1}&pageSize={state.PageSize}";
            if (!string.IsNullOrWhiteSpace(_searchString)) url += $"&searchTerm={Uri.EscapeDataString(_searchString)}";
            if (_filterCategoryId.HasValue) url += $"&categoryId={_filterCategoryId.Value}";
            if (_filterOnlyActive.HasValue) url += $"&isActive={_filterOnlyActive.Value.ToString().ToLower()}";

            var response = await Http.GetFromJsonAsync<PagedResponse<Poi>>(url);
            if (response != null)
            {
                _myPoisCount = response.TotalCount;
                StateHasChanged();
                await LoadMapDataAndRender();
                return new TableData<Poi> { TotalItems = response.TotalCount, Items = response.Items };
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi tải POI: " + ex.Message, Severity.Error); }
        return new TableData<Poi> { TotalItems = 0, Items = Enumerable.Empty<Poi>() };
    }

    private async Task<TableData<PoiRequest>> ReloadSellerRequests(TableState state, RequestStatus status)
    {
        try
        {
            var url = $"api/poi-requests?status={status}&pageNumber={state.Page + 1}&pageSize={state.PageSize}";
            var response = await Http.GetFromJsonAsync<PagedResponse<PoiRequest>>(url);
            if (response != null)
            {
                if (status == RequestStatus.Pending) _pendingRequestsCount = response.TotalCount;
                else if (status == RequestStatus.Rejected) _rejectedRequestsCount = response.TotalCount;
                StateHasChanged();
                return new TableData<PoiRequest> { TotalItems = response.TotalCount, Items = response.Items };
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi tải yêu cầu: " + ex.Message, Severity.Error); }
        return new TableData<PoiRequest> { TotalItems = 0, Items = Enumerable.Empty<PoiRequest>() };
    }

    private async Task RefreshAll()
    {
        if (_adminTable != null) await _adminTable.ReloadServerData();
        if (_sellerPoisTable != null) await _sellerPoisTable.ReloadServerData();
        if (_pendingTable != null) await _pendingTable.ReloadServerData();
        if (_rejectedTable != null) await _rejectedTable.ReloadServerData();
        await LoadCounts();
        if (_adminActiveTab == 1 || _sellerActiveTab == 3) {
            await LoadMapDataAndRender();
        }
    }

    private async Task OnSearchDebounced(string text)
    {
        _searchString = text;
        await InvokeFiltersChanged();
    }

    private async Task OnCategoryChanged(int? categoryId)
    {
        _filterCategoryId = categoryId;
        await InvokeFiltersChanged();
    }

    private async Task OnStatusChanged(bool? status)
    {
        _filterOnlyActive = status;
        await InvokeFiltersChanged();
    }

    private async Task InvokeFiltersChanged()
    {
        if (_adminTable != null) await _adminTable.ReloadServerData();
        if (_sellerPoisTable != null) await _sellerPoisTable.ReloadServerData();
        if (_adminActiveTab == 1 || _sellerActiveTab == 3) {
            await LoadMapDataAndRender();
        }
    }
    
    private async Task OnAdminTabChanged(int index)
    {
        _adminActiveTab = index;
        if (index == 1) 
        {
            StateHasChanged();
            await LoadMapDataAndRender();
        }
    }

    private async Task OnSellerTabChanged(int index)
    {
        _sellerActiveTab = index;
        if (index == 3) 
        {
            StateHasChanged();
            await LoadMapDataAndRender();
        }
    }
    
    private async Task ResetFilters()
    {
        _searchString = string.Empty;
        _filterCategoryId = null;
        _filterOnlyActive = null;
        await InvokeFiltersChanged();
    }

    private async Task LoadMapDataAndRender()
    {
        try
        {
            string url = _isAdmin 
                ? $"api/pois?onlyActive=false&pageNumber=1&pageSize=10000" 
                : $"api/pois?createdById={_myUserId}&onlyActive=false&pageNumber=1&pageSize=10000";
            
            if (!string.IsNullOrWhiteSpace(_searchString)) url += $"&searchTerm={Uri.EscapeDataString(_searchString)}";
            if (_filterCategoryId.HasValue) url += $"&categoryId={_filterCategoryId.Value}";
            if (_filterOnlyActive.HasValue) url += $"&isActive={_filterOnlyActive.Value.ToString().ToLower()}";

            var response = await Http.GetFromJsonAsync<PagedResponse<Poi>>(url);
            if (response?.Items != null)
            {
                var mappedData = response.Items.Select(p => new
                {
                    id = p.Id,
                    name = p.Name ?? "Chưa có tên",
                    lat = p.Latitude,
                    lng = p.Longitude,
                    isActive = p.IsActive,
                    radius = p.GeofenceRadius
                }).ToList();

                var mapConfig = await Http.GetFromJsonAsync<MapConfigResult>("api/pois/map-config");
                string provider = string.IsNullOrEmpty(mapConfig?.MapboxAccessToken) ? "Vietmap" : "Mapbox";

                string containerId = _isAdmin ? "admin-overview-map" : "seller-overview-map";

                if (provider == "Mapbox")
                {
                    await JSRuntime.InvokeVoidAsync("mapInterop.showOverviewMap", containerId, mappedData, null, mapConfig?.MapboxAccessToken ?? "");
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("vietmapInterop.showOverviewMap", containerId, mappedData, null, mapConfig?.MapboxAccessToken ?? "");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading map metadata: {ex.Message}");
        }
    }

    private void NavigateToCreate() => NavigationManager.NavigateTo("/poi/editor");
    private void NavigateToEdit(int id) => NavigationManager.NavigateTo($"/poi/editor/{id}");

    private async Task DeletePoi(Poi poi)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận xóa",
            $"Bạn có chắc muốn xóa POI \"{poi.Name}\" không?",
            yesText: "Xóa", cancelText: "Hủy");
        if (confirm != true) return;

        var response = await Http.DeleteAsync($"api/pois/{poi.Id}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã xóa POI thành công", Severity.Success);
            await RefreshAll();
        }
        else
        {
            Snackbar.Add(response.StatusCode == System.Net.HttpStatusCode.Unauthorized
                ? "Phiên đăng nhập hết hạn."
                : "Lỗi khi xóa POI.", Severity.Error);
        }
    }

    private async Task CancelRequest(PoiRequest req)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận hủy",
            $"Bạn có chắc muốn hủy yêu cầu \"{GetPoiNameFromRequest(req)}\" không? Hành động này sẽ xóa vĩnh viễn yêu cầu này.",
            yesText: "Hủy yêu cầu", cancelText: "Quay lại");
        if (confirm != true) return;

        var response = await Http.DeleteAsync($"api/poi-requests/{req.Id}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã hủy yêu cầu thành công", Severity.Success);
            await RefreshAll();
        }
        else
        {
            Snackbar.Add("Lỗi khi hủy yêu cầu.", Severity.Error);
        }
    }

    private string GetPoiNameFromRequest(PoiRequest req)
    {
        try 
        { 
            var poi = (Poi?)JsonSerializer.Deserialize(req.RequestData, typeof(Poi), _jsonOpts);
            return poi?.Name ?? "—"; 
        }
        catch { return "—"; }
    }

    private class MapConfigResult 
    { 
        [System.Text.Json.Serialization.JsonPropertyName("mapboxAccessToken")]
        public string MapboxAccessToken { get; set; } = string.Empty; 
    }
}
