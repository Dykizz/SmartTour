@using SmartTour.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Class="mr-2"/>
            <MudText Typo="Typo.h6" Style="font-weight: 700;">Từ chối yêu cầu</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Nhập lý do từ chối yêu cầu của <b style="color:var(--mud-palette-text-primary);">@RequesterName</b>. Lý do sẽ được gửi cho tác giả.
        </MudText>
        <MudTextField @bind-Value="_note" Label="Lý do chi tiết" Lines="3"
                      Variant="Variant.Outlined" Required="true"
                      Placeholder="Vd: Tên điểm đến chưa rõ ràng, ảnh mờ..."
                      RequiredError="Vui lòng nhập lý do" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Default" Class="px-6 rounded-lg">Hủy</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="SubmitReject"
                   Disabled="string.IsNullOrWhiteSpace(_note)" Class="px-6 rounded-lg ml-2" DropShadow="false">Từ chối</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int RequestId { get; set; }
    [Parameter] public string RequesterName { get; set; } = "";

    private string _note = "";

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitReject()
    {
        var response = await Http.PostAsJsonAsync($"api/poi-requests/{RequestId}/reject", new { Note = _note });
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã từ chối yêu cầu.", Severity.Warning);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add("Lỗi: " + await response.Content.ReadAsStringAsync(), Severity.Error);
        }
    }
}
