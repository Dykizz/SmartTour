@page "/poi/editor"
@page "/poi/editor/{Id:int}"
@using SmartTour.Shared.Models
@using SmartTour.Web.Services
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IMapService MapService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<PageTitle>@(IsEdit ? "Chỉnh sửa POI" : "Thêm mới POI")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-20 animate-fade-in">
    <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-lg" Style="background: linear-gradient(135deg, rgba(var(--mud-palette-primary-rgb), 0.05) 0%, rgba(var(--mud-palette-primary-rgb), 0.02) 100%); border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.1);">
        <div class="d-flex align-center justify-space-between">
            <div class="d-flex align-center">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" Variant="Variant.Filled" Color="Color.Surface" Class="mr-4" />
                <div>
                    <MudText Typo="Typo.h6" Class="mb-1">
                        @(IsEdit ? "Cập nhật Điểm đến" : "Thêm Điểm đến mới")
                    </MudText>
                    <MudText Typo="Typo.body2" Color="@Color.Secondary">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                        ID: @(Id?.ToString() ?? "N/A") • Cấu hình thông tin chi tiết và nội dung đa ngôn ngữ
                    </MudText>
                </div>
            </div>
            <div class="d-none d-sm-flex gap-3">
                <MudButton Variant="Variant.Outlined" OnClick="GoBack" Size="Size.Medium" Class="px-8">Hủy</MudButton>
                <MudButton Variant="Variant.Filled" Color="@Color.Primary" OnClick="SavePoi" Size="Size.Medium" Class="px-10" StartIcon="@(_isAdmin ? Icons.Material.Filled.Save : Icons.Material.Filled.Send)">
                    @if (_saving) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" /> }
                    else { <span>@(_isAdmin ? "Lưu thay đổi" : "Gửi yêu cầu")</span> }
                </MudButton>
            </div>
        </div>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Color="@Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else
    {
        @if (!string.IsNullOrEmpty(_adminNote))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-6 rounded-lg shadow-sm" Style="border: 1px solid rgba(255,152,0,0.3);">
                <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Ghi chú từ quản trị viên:</MudText>
                <MudText Typo="Typo.body2">@_adminNote</MudText>
            </MudAlert>
        }

        <MudExpansionPanels MultiExpansion="true" Elevation="0" Class="rounded-xl">
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border: 1px solid rgba(0,0,0,0.08);">
            <MudExpansionPanel Expanded="true" Style="background: white;">
                <TitleContent>
                    <div class="d-flex align-center py-1">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" />
                        </MudAvatar>
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.subtitle1" Class="mb-0">Cấu hình cơ bản</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Thiết lập thông tin chính của điểm đến</MudText>
                        </div>
                        <MudChip T="string" Color="@(_model.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Filled" Class="mr-2">@(_model.IsActive ? "Đang hoạt động" : "Tạm ẩn")</MudChip>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudDivider />
                    <div class="pa-6" Style="background: rgba(0,0,0,0.01);">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Name" Label="Tên điểm đến" Variant="Variant.Outlined" 
                                         Placeholder="Nhập tên điểm đến..." Margin="Margin.Dense" Required="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect T="int" @bind-Value="_model.CategoryId" Label="Loại hình" Variant="Variant.Outlined" Required="true" Margin="Margin.Dense">
                                @foreach (var cat in _categories) { <MudSelectItem Value="@cat.Id">@cat.Name</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudNumericField @bind-Value="_model.GeofenceRadius" Label="Bán kính" Min="1" Variant="Variant.Outlined" Required="true" Adornment="Adornment.End" AdornmentText="m" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.QrValue" Label="Mã QR định danh" Variant="Variant.Outlined" 
                                         Placeholder="ID duy nhất..." Margin="Margin.Dense"
                                         Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Autorenew" OnAdornmentClick="GenerateRandomQr" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudCheckBox @bind-Value="_model.IsActive" Label="Hoạt động" Color="@Color.Primary" Dense="true" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudCheckBox @bind-Value="_model.IsFeature" Label="Nổi bật" Color="@Color.Warning" Dense="true" />
                        </MudItem>
                    </MudGrid>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
            </MudPaper>

            <!-- Section 2: Location & Map -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border: 1px solid rgba(0,0,0,0.08);">
            <MudExpansionPanel Expanded="true" Style="background: white;">
                <TitleContent>
                    <div class="d-flex align-center py-1">
                        <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Medium" />
                        </MudAvatar>
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.subtitle1" Class="mb-0">Vị trí địa lý & Bản đồ</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Xác định toạ độ và vùng geofence</MudText>
                        </div>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudDivider />
                    <div class="pa-6" Style="background: rgba(0,0,0,0.01);">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudAutocomplete T="MapPrediction" 
                                                 Value="_selectedMapPrediction" 
                                                 Label="Tìm địa chỉ" 
                                                 Variant="Variant.Outlined" 
                                                 Class="mb-2"
                                                 SearchFunc="SearchMapPredictions"
                                                 ToStringFunc="@(p => p?.description)"
                                                 ValueChanged="OnMapPredictionSelected"
                                                 Adornment="Adornment.End" 
                                                 AdornmentIcon="@Icons.Material.Filled.Search" 
                                                 Placeholder="Nhập tên địa điểm..." 
                                                 Margin="Margin.Dense" 
                                                 Clearable="true" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField @bind-Value="_model.Latitude" Label="Vĩ độ" Format="F6" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="6" md="3">
                                <MudNumericField @bind-Value="_model.Longitude" Label="Kinh độ" Format="F6" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12">
                                <div id="editor-map" style="height: 300px; width: 100%; border-radius: 12px; border: 1px solid var(--mud-palette-divider);"></div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
            </MudPaper>

                <!-- Section 3: Images -->
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border: 1px solid rgba(0,0,0,0.08);">
                <MudExpansionPanel Style="background: white;">
                    <TitleContent>
                        <div class="d-flex align-center py-1">
                            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Medium" />
                            </MudAvatar>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.subtitle1" Class="mb-0">Bộ sưu tập hình ảnh</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Quản lý hình ảnh và thumbnail của điểm đến</MudText>
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-6" Style="background: rgba(0,0,0,0.01);">
                        <div class="mb-4">
                            <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="UploadNewImages" Accept=".jpg,.jpeg,.png,.webp">
                                <ActivatorContent>
                                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="@Color.Primary" Size="Size.Small" DropShadow="false">Thêm ảnh</MudButton>
                                </ActivatorContent>
                            </MudFileUpload>
                        </div>
                        <MudGrid Spacing="2">
                            @foreach (var img in _model.Images.OrderBy(x => x.SortOrder))
                            {
                                <MudItem xs="6" md="4" lg="3">
                                    <MudCard Outlined="true" Class="poi-image-card relative rounded-lg shadow-none">
                                        <div style="height: 120px; overflow: hidden; position: relative;" class="d-flex align-center justify-center bg-gray-100 rounded-t-lg">
                                            @if (!string.IsNullOrEmpty(img.ImageUrl)) {
                                                <MudImage Src="@img.ImageUrl" Style="height:100%; width:100%" ObjectFit="ObjectFit.Cover" />
                                            } else {
                                                <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Default" Size="Size.Large" />
                                            }
                                            
                                            @* Loading overlay *@
                                            @if (_uploadingImages.ContainsKey(img) && _uploadingImages[img])
                                            {
                                                <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center;">
                                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
                                                </div>
                                            }
                                        </div>
                                        <div class="pa-2 d-flex align-center justify-space-between">
                                            <MudFileUpload T="IBrowserFile" OnFilesChanged="@((e) => UploadImage(e, img))" Accept=".jpg,.jpeg,.png,.webp" Disabled="@(_uploadingImages.ContainsKey(img) && _uploadingImages[img])">
                                                <ActivatorContent>
                                                    <MudIconButton Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Color="Color.Info" Disabled="@(_uploadingImages.ContainsKey(img) && _uploadingImages[img])" />
                                                </ActivatorContent>
                                            </MudFileUpload>
                                            <div class="d-flex">
                                                <MudIconButton Icon="@(img.IsThumbnail ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" 
                                                               Color="@(img.IsThumbnail ? Color.Warning : Color.Default)" 
                                                               Size="Size.Small" 
                                                               OnClick="@(() => img.IsThumbnail = !img.IsThumbnail)"
                                                               Disabled="@(_uploadingImages.ContainsKey(img) && _uploadingImages[img])" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                               Size="Size.Small" 
                                                               Color="@Color.Error" 
                                                               OnClick="@(() => _model.Images.Remove(img))"
                                                               Disabled="@(_uploadingImages.ContainsKey(img) && _uploadingImages[img])" />
                                            </div>
                                        </div>
                                        @if (img.IsThumbnail) {
                                            <div style="position:absolute; top:4px; right:4px; background: rgba(255,193,7,0.9); border-radius:4px; padding:2px 6px;">
                                                <MudText Typo="Typo.caption" Style="color:white; font-weight:700;">CHÍNH</MudText>
                                            </div>
                                        }
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                        </div>
                </ChildContent>
            </MudExpansionPanel>
            </MudPaper>

            <!-- Section 4: Details & Descriptions -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border: 1px solid rgba(0,0,0,0.08);">
            <MudExpansionPanel Style="background: white;">
                <TitleContent>
                    <div class="d-flex align-center py-1">
                        <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Medium" />
                        </MudAvatar>
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.subtitle1" Class="mb-0">Chi tiết & Mô tả đa ngôn ngữ</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Nội dung giới thiệu và bản dịch tự động</MudText>
                        </div>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudDivider />
                    <div class="pa-6" Style="background: rgba(0,0,0,0.01);">
                        @{
                            var defaultLang = _languages.FirstOrDefault(x => x.IsDefault) ?? new Language { Code = "vi", Name = "Tiếng Việt" };
                            var mainContent = _model.Contents.FirstOrDefault(t => t.LanguageCode == defaultLang.Code) 
                                           ?? new PoiContent { LanguageCode = defaultLang.Code };
                            if (!_model.Contents.Any(t => t.LanguageCode == defaultLang.Code)) _model.Contents.Add(mainContent);
                        }
                        
                        <!-- Mô tả gốc -->
                        <div class="mb-6">
                            <div class="d-flex align-center justify-space-between mb-3">
                                <MudText Typo="Typo.subtitle2">Mô tả gốc (@defaultLang.Name)</MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Translate" 
                                           OnClick="TranslateAllContents" Size="Size.Small"
                                           Disabled="@(_translatingAllDesc)">
                                    @if (_translatingAllDesc) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" /> }
                                    else { <MudText>Dịch tự động</MudText> }
                                </MudButton>
                            </div>
                            <MudTextField @bind-Value="mainContent.Description" 
                                         Label="Mô tả chi tiết" 
                                         Lines="8" 
                                         Variant="Variant.Outlined" 
                                         Placeholder="Nhập mô tả chi tiết bằng Tiếng Việt..." />
                        </div>

                        <!-- Bản dịch các ngôn ngữ khác -->
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="mb-3">Bản dịch các ngôn ngữ khác</MudText>
                            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Border="true" PanelClass="pa-4" MinimumTabWidth="100px">
                                @foreach (var lang in _languages.Where(x => x.IsActive && !x.IsDefault))
                                {
                                    <MudTabPanel Text="@lang.Code.ToUpper()">
                                        @{
                                            var currentLangCode = lang.Code;
                                            var content = _model.Contents.FirstOrDefault(t => t.LanguageCode == currentLangCode) 
                                                ?? new PoiContent { LanguageCode = currentLangCode };
                                            
                                            if (!_model.Contents.Any(t => t.LanguageCode == currentLangCode))
                                                _model.Contents.Add(content);
                                        }
                                        <MudTextField @bind-Value="content.Description" 
                                                     Label="@($"Mô tả ({lang.Name})")" 
                                                     Lines="8" 
                                                     Variant="Variant.Outlined" 
                                                     Placeholder="Bản dịch sẽ hiện ở đây..." />
                                    </MudTabPanel>
                                }
                            </MudTabs>
                        </div>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
            </MudPaper>

            <!-- Section 5: Audio Guide Automation -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border: 1px solid rgba(0,0,0,0.08);">
            <MudExpansionPanel Style="background: white;">
                <TitleContent>
                    <div class="d-flex align-center py-1">
                        <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.VolumeUp" Size="Size.Medium" />
                        </MudAvatar>
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.subtitle1" Class="mb-0">Trình tạo thuyết minh AI</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Tự động dịch và chuyển đổi thành giọng nói</MudText>
                        </div>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudDivider />
                    <div class="pa-6" Style="background: rgba(0,0,0,0.01);">
                        <!-- Kịch bản gốc -->
                        <div class="mb-6">
                            <div class="d-flex align-center justify-space-between mb-3">
                                <MudText Typo="Typo.subtitle2">Kịch bản gốc (Tiếng Việt)</MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AutoFixHigh" 
                                           OnClick="GenerateAutoAudioChain" Size="Size.Small"
                                           Disabled="@(_generatingAllAudio)">
                                    @if (_generatingAllAudio) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" /> }
                                    else { <MudText>Tạo tự động</MudText> }
                                </MudButton>
                            </div>
                            <MudStack Spacing="1">
                                @{
                                    var defaultLangCode = _languages.FirstOrDefault(l => l.IsDefault)?.Code ?? "vi";
                                    var sourceAudios = _model.AudioFiles.Where(a => a.LanguageCode == defaultLangCode).OrderBy(a => a.SortOrder).ToList();
                                }
                                @foreach (var audio in sourceAudios)
                                {
                                    <div class="d-flex gap-2 pa-2 mb-2" Style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
                                        <div class="d-flex flex-column">
                                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" OnClick="@(() => MoveAudio(audio, -1))" Disabled="@(audio == sourceAudios.First())" Class="pa-0"/>
                                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" OnClick="@(() => MoveAudio(audio, 1))" Disabled="@(audio == sourceAudios.Last())" Class="pa-0"/>
                                        </div>
                                        <MudTextField @bind-Value="audio.TtsScript" 
                                                     Label="@($"Đoạn {audio.SortOrder + 1}")"
                                                     Placeholder="Nhập nội dung thuyết minh..." 
                                                     Lines="3"
                                                     Variant="Variant.Outlined" 
                                                     Margin="Margin.Dense" 
                                                     Class="flex-grow-1" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveAudio(audio))" />
                                    </div>
                                }
                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => AddTtsAudio(defaultLangCode))" Class="mt-2">Thêm đoạn thuyết minh</MudButton>
                            </MudStack>
                        </div>

                        <!-- Kết quả Audio -->
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="mb-3">Kết quả Audio</MudText>
                            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Border="true" PanelClass="pa-4" MinimumTabWidth="100px">
                                @foreach (var lang in _languages.Where(x => x.IsActive))
                                {
                                    <MudTabPanel Text="@lang.Code.ToUpper()">
                                        <MudStack Spacing="1" Style="max-height: 400px; overflow-y: auto;">
                                            @foreach (var audio in _model.AudioFiles.Where(a => a.LanguageCode == lang.Code).OrderBy(a => a.SortOrder))
                                            {
                                                <div class="d-flex align-center gap-2 pa-1 border-b">
                                                    <MudText Typo="Typo.caption" Style="width: 20px;">@(audio.SortOrder + 1).</MudText>
                                                    <div class="flex-grow-1">
                                                        @if (!string.IsNullOrEmpty(audio.FileUrl))
                                                        {
                                                            <audio controls src="@audio.FileUrl" style="width: 100%; height: 30px;"></audio>
                                                        } else {
                                                            <MudText Typo="Typo.caption" Color="Color.Default">Chưa có audio</MudText>
                                                        }
                                                    </div>
                                                    <MudFileUpload T="IBrowserFile" OnFilesChanged="@((e) => UploadAudioFile(e, audio))" Accept="audio/*">
                                                        <ActivatorContent>
                                                            @if (_uploadingAudio.ContainsKey(audio) && _uploadingAudio[audio])
                                                            {
                                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
                                                            }
                                                            else
                                                            {
                                                                <MudIconButton Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Color="Color.Info" Title="Tải âm thanh từ máy" />
                                                            }
                                                        </ActivatorContent>
                                                    </MudFileUpload>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveAudio(audio))" Title="Xoá audio" />
                                                </div>
                                            }
                                            <div class="mt-2">
                                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="@(() => AddTtsAudio(lang.Code))">Thêm Audio thủ công</MudButton>
                                            </div>
                                        </MudStack>
                                    </MudTabPanel>
                                }
                            </MudTabs>
                        </div>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
            </MudPaper>

            <!-- Section 6: Operating Hours -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border: 1px solid rgba(0,0,0,0.08);">
            <MudExpansionPanel Style="background: white;">
                <TitleContent>
                    <div class="d-flex align-center py-1">
                        <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Medium" />
                        </MudAvatar>
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.subtitle1" Class="mb-0">Giờ mở cửa hàng tuần</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Thiết lập lịch hoạt động theo ngày</MudText>
                        </div>
                    </div>
                </TitleContent>
                <ChildContent>
                    <MudDivider />
                    <div class="pa-6" Style="background: rgba(0,0,0,0.01);">
                    <div class="d-flex justify-end mb-2">
                        <MudButton StartIcon="@Icons.Material.Filled.ContentCopy" Size="@Size.Small" OnClick="ApplyMondayToAll" Variant="@Variant.Text" Color="@Color.Info" Disabled="@(!_model.OperatingHours.Any())">Sao chép Thứ 2 cho cả tuần</MudButton>
                    </div>
                    @foreach (var day in _model.OperatingHours.OrderBy(x => x.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)x.DayOfWeek))
                    {
                        <div class="d-flex align-center gap-4 py-2">
                            <div style="width: 120px;" class="d-flex align-center gap-2">
                                <MudSwitch T="bool" @bind-Value="day.IsActive" Color="@Color.Success" />
                                <MudText Typo="Typo.body2">@TranslateDay(day.DayOfWeek)</MudText>
                            </div>
                            <MudTimePicker @bind-Time="day.OpenTime" Variant="@Variant.Outlined" Margin="Margin.Dense" Disabled="@(!day.IsActive)" AmPm="false" />
                            <MudText Typo="@Typo.caption">—</MudText>
                            <MudTimePicker @bind-Time="day.CloseTime" Variant="@Variant.Outlined" Margin="Margin.Dense" Disabled="@(!day.IsActive)" AmPm="false" />
                        </div>
                        <MudDivider />
                    }
                    @if (!_model.OperatingHours.Any())
                    {
                        <div class="py-4 text-center">
                            <MudButton OnClick="InitializeDefaultOperatingHours" StartIcon="@Icons.Material.Filled.Refresh" Color="@Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Khởi tạo dữ liệu giờ mở cửa</MudButton>
                        </div>
                    }
                    </div>
                </ChildContent>
            </MudExpansionPanel>
            </MudPaper>
        </MudExpansionPanels>
    }
</MudContainer>

