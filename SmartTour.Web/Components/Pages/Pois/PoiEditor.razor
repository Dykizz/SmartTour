@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromQuery] public int? FromRequestId { get; set; }
    [SupplyParameterFromQuery] public int? EditingRequestId { get; set; }

    private bool IsEdit => Id.HasValue && Id.Value > 0;
    private bool IsEditingRequest => EditingRequestId.HasValue && EditingRequestId.Value > 0;
    private Poi _model = new() { GeofenceRadius = 50, IsActive = true };
    private bool _loading = true;
    private bool _saving = false;
    private bool _generatingAllAudio = false;
    private bool _translatingAllDesc = false;
    private Dictionary<string, bool> _translatingDesc = new();
    private Dictionary<PoiImage, bool> _uploadingImages = new();
    private Dictionary<PoiAudioFile, bool> _uploadingAudio = new();
    private bool _isAdmin = false;
    private List<Category> _categories = new();
    private List<Language> _languages = new();
    private string? _adminNote;
    private RequestStatus? _requestStatus;
    
    private MapPrediction? _selectedMapPrediction;
    private bool _mapInitialized = false;
    private DotNetObjectReference<PoiEditor>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = auth.User.IsInRole("ADMIN");
        try 
        {
            _categories = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
            _languages = await Http.GetFromJsonAsync<List<Language>>("api/languages") ?? new();
            
            if (IsEdit)
            {
                var poi = await Http.GetFromJsonAsync<Poi>($"api/pois/{Id}");
                if (poi != null)
                {
                    _model = poi;
                    EnsureAllDaysPresent();
                }
                else
                {
                    Snackbar.Add("Không tìm thấy POI", Severity.Error);
                    NavigationManager.NavigateTo("/poi-management");
                }
            }
            else if (IsEditingRequest)
            {
                var req = await Http.GetFromJsonAsync<PoiRequest>($"api/poi-requests/{EditingRequestId}");
                if (req?.RequestData != null)
                {
                    var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                    _model = JsonSerializer.Deserialize<Poi>(req.RequestData, opts) ?? new();
                    _adminNote = req.AdminNote;
                    _requestStatus = req.Status;
                    EnsureAllDaysPresent();
                }
            }
            else if (FromRequestId.HasValue)
            {
                try
                {
                    var rejectedReq = await Http.GetFromJsonAsync<PoiRequest>($"api/poi-requests/{FromRequestId.Value}");
                    if (rejectedReq?.RequestData != null)
                    {
                        var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                        _model = JsonSerializer.Deserialize<Poi>(rejectedReq.RequestData, opts)
                                 ?? new Poi { GeofenceRadius = 50, IsActive = true };
                        // Reset ID để tạo request mới
                        _model.Id = 0;
                        EnsureAllDaysPresent();
                        _adminNote = rejectedReq.AdminNote;
                        Snackbar.Add("Đã nạp lại dữ liệu từ yêu cầu bị từ chối. Vui lòng chỉnh sửa và gửi lại.", Severity.Info);
                    }
                }
                catch { /* Bỏ qua */ }
            }
            else
            {
                if (_categories.Any()) _model.CategoryId = _categories.First().Id;
                _model.Latitude = 10.762622;
                _model.Longitude = 106.660172;
                InitializeDefaultOperatingHours();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải dữ liệu: " + ex.Message, Severity.Error);
        }
        finally 
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_mapInitialized)
        {
            await Task.Delay(500); 
            _objRef = DotNetObjectReference.Create(this);
            await MapService.InitMapAsync(_model.Latitude, _model.Longitude, "editor-map", _objRef);
            _mapInitialized = true;
        }
    }

    private async Task SavePoi()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            Snackbar.Add("Tên điểm đến không được để trống", Severity.Warning);
            return;
        }

        _saving = true;
        try 
        {
            // Clear navigation properties to avoid circular reference
            foreach (var hour in _model.OperatingHours) hour.Poi = null;
            foreach (var img in _model.Images) img.Poi = null;
            foreach (var content in _model.Contents) content.Poi = null;
            foreach (var audio in _model.AudioFiles) audio.Poi = null;
            _model.Category = null;

            if (_isAdmin)
            {
                // Admin: Lưu thẳng vào DB
                HttpResponseMessage response;
                if (IsEdit) response = await Http.PutAsJsonAsync($"api/pois/{Id}", _model);
                else response = await Http.PostAsJsonAsync("api/pois", _model);

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Đã lưu thông tin POI thành công", Severity.Success);
                    NavigationManager.NavigateTo("/poi-management");
                }
                else
                {
                    await HandleErrorResponse(response);
                }
            }
            else
            {
                // Seller: Gửi yêu cầu chờ Admin duyệt
                var jsonOptions = new JsonSerializerOptions { ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles };
                var requestData = JsonSerializer.Serialize(_model, jsonOptions);

                HttpResponseMessage response;
                if (IsEditingRequest)
                {
                    // Cập nhật yêu cầu hiện có
                    var updateReq = new PoiRequest { RequestData = requestData };
                    response = await Http.PutAsJsonAsync($"api/poi-requests/{EditingRequestId}", updateReq);
                }
                else
                {
                    // Tạo yêu cầu mới
                    var request = new PoiRequest
                    {
                        Type = IsEdit ? RequestType.Update : RequestType.Create,
                        POIId = IsEdit ? Id : null,
                        RequestData = requestData
                    };
                    response = await Http.PostAsJsonAsync("api/poi-requests", request);
                }

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add(IsEditingRequest ? "Đã cập nhật yêu cầu thành công!" : "Yêu cầu đã được gửi! Admin sẽ xem xét và phê duyệt sớm.", Severity.Success);
                    NavigationManager.NavigateTo("/poi-management");
                }
                else
                {
                    await HandleErrorResponse(response);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi khi lưu: " + ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task HandleErrorResponse(HttpResponseMessage response)
    {
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Snackbar.Add("Lỗi xác thực: Bạn chưa đăng nhập hoặc phiên đã hết hạn.", Severity.Error);
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            if (string.IsNullOrWhiteSpace(errorContent)) errorContent = $"Mã lỗi {response.StatusCode}";
            if (errorContent.Length > 200) errorContent = errorContent[..200] + "...";
            Snackbar.Add($"Lỗi: {errorContent}", Severity.Error);
        }
    }

    private void InitializeDefaultOperatingHours()
    {
        _model.OperatingHours.Clear();
        EnsureAllDaysPresent();
    }

    private void EnsureAllDaysPresent()
    {
        var days = new[] { 
            DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, 
            DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday 
        };
        
        foreach (var day in days)
        {
            if (!_model.OperatingHours.Any(x => x.DayOfWeek == day))
            {
                _model.OperatingHours.Add(new OperatingHours 
                { 
                    DayOfWeek = day, 
                    OpenTime = new TimeSpan(8, 0, 0), 
                    CloseTime = new TimeSpan(21, 0, 0),
                    IsActive = true
                });
            }
        }
    }

    private void ApplyMondayToAll()
    {
        var monday = _model.OperatingHours.FirstOrDefault(x => x.DayOfWeek == DayOfWeek.Monday);
        if (monday == null) return;

        foreach (var day in _model.OperatingHours.Where(x => x.DayOfWeek != DayOfWeek.Monday))
        {
            day.OpenTime = monday.OpenTime;
            day.CloseTime = monday.CloseTime;
        }
        Snackbar.Add("Đã áp dụng giờ của Thứ 2 cho toàn bộ các ngày", Severity.Info);
    }

    private async Task UploadNewImages(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();
        foreach (var file in files)
        {
            var img = new PoiImage { SortOrder = _model.Images.Count };
            _model.Images.Add(img);
            _uploadingImages[img] = true;
            StateHasChanged();
            
            try
            {
                var content = new MultipartFormDataContent();
                var fileStream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 10);
                var fileContent = new StreamContent(fileStream);
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "file", file.Name);

                var response = await Http.PostAsync("api/uploads/image", content);
                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<UploadResponse>();
                    if (result != null)
                    {
                        img.ImageUrl = result.Url;
                        Snackbar.Add("Tải ảnh lên thành công", Severity.Success);
                    }
                }
            }
            catch (Exception ex) { Snackbar.Add("Lỗi upload: " + ex.Message, Severity.Error); }
            finally { 
                _uploadingImages[img] = false; 
                StateHasChanged();
            }
        }
    }

    private string TranslateDay(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Thứ Hai",
        DayOfWeek.Tuesday => "Thứ Ba",
        DayOfWeek.Wednesday => "Thứ Tư",
        DayOfWeek.Thursday => "Thứ Năm",
        DayOfWeek.Friday => "Thứ Sáu",
        DayOfWeek.Saturday => "Thứ Bảy",
        DayOfWeek.Sunday => "Chủ Nhật",
        _ => day.ToString()
    };

    private async Task UploadImage(InputFileChangeEventArgs e, PoiImage img)
    {
        var file = e.File;
        if (file == null) return;
        _uploadingImages[img] = true;
        try
        {
            var content = new MultipartFormDataContent();
            var fileStream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 10);
            var fileContent = new StreamContent(fileStream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/uploads/image", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResponse>();
                if (result != null)
                {
                    img.ImageUrl = result.Url;
                    Snackbar.Add("Tải ảnh lên thành công", Severity.Success);
                }
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi upload: " + ex.Message, Severity.Error); }
        finally { _uploadingImages[img] = false; }
    }

    private async Task UploadAudioFile(InputFileChangeEventArgs e, PoiAudioFile audio)
    {
        var file = e.File;
        if (file == null) return;
        _uploadingAudio[audio] = true;
        StateHasChanged();
        try
        {
            var content = new MultipartFormDataContent();
            var fileStream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 1024); // Tối đa dung lượng ~1GB
            var fileContent = new StreamContent(fileStream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/uploads/audio", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResponse>();
                if (result != null)
                {
                    audio.FileUrl = result.Url;
                    audio.IsTts = false; // Đánh dấu là audio tự upload
                    Snackbar.Add("Tải âm thanh lên thành công", Severity.Success);
                }
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Lỗi tải file: {err}", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add("Lỗi upload: " + ex.Message, Severity.Error); }
        finally { 
            _uploadingAudio[audio] = false; 
            StateHasChanged();
        }
    }

    private async Task GenerateAutoAudioChain()
    {
        var defaultLang = _languages.FirstOrDefault(l => l.IsDefault) ?? _languages.FirstOrDefault();
        if (defaultLang == null) return;
        
        var sourceLangCode = defaultLang.Code;
        var sourceAudios = _model.AudioFiles
            .Where(a => a.LanguageCode == sourceLangCode && a.IsTts && !string.IsNullOrWhiteSpace(a.TtsScript))
            .OrderBy(a => a.SortOrder)
            .ToList();

        if (!sourceAudios.Any()) {
            Snackbar.Add("Vui lòng nhập kịch bản Tiếng Việt trước khi tạo Audio", Severity.Warning);
            return;
        }

        _generatingAllAudio = true;
        try {
            var targetLangs = _languages.Where(x => x.IsActive).ToList();
            Console.WriteLine($"[AudioChain] Starting for {targetLangs.Count} active languages. Source: {sourceLangCode}");
            
            foreach (var lang in targetLangs) {
                Console.WriteLine($"[AudioChain] Processing language: {lang.Code} (IsDefault: {lang.IsDefault})");
                var existing = _model.AudioFiles.Where(a => a.LanguageCode == lang.Code && a.IsTts).ToList();
                foreach (var e in existing) _model.AudioFiles.Remove(e);

                foreach (var src in sourceAudios) {
                    var scriptToUse = src.TtsScript;

                    if (lang.Code != sourceLangCode) {
                        Console.WriteLine($"[AudioChain] Translating segment from {sourceLangCode} to {lang.Code}...");
                        var resp = await Http.PostAsJsonAsync("api/Translate", new { Text = src.TtsScript, TargetLanguage = lang.Code });
                        if (resp.IsSuccessStatusCode) {
                            var res = await resp.Content.ReadFromJsonAsync<TranslateResponse>();
                            if (res != null) {
                                scriptToUse = System.Net.WebUtility.HtmlDecode(res.TranslatedText);
                                Console.WriteLine($"[AudioChain] Translation success. Result: {scriptToUse.Substring(0, Math.Min(20, scriptToUse.Length))}...");
                            }
                        } else {
                            var err = await resp.Content.ReadAsStringAsync();
                            Console.WriteLine($"[AudioChain] Translation FAILED for {lang.Code}: {err}");
                            Snackbar.Add($"Lỗi dịch sang {lang.Name}: {err}", Severity.Error);
                        }
                    }

                    var newAudio = new PoiAudioFile {
                        LanguageCode = lang.Code,
                        IsTts = true,
                        SortOrder = src.SortOrder,
                        TtsScript = scriptToUse
                    };

                    if (!string.IsNullOrWhiteSpace(scriptToUse))
                    {
                        Console.WriteLine($"[AudioChain] Generating TTS for {lang.Code}...");
                        var ttsResp = await Http.PostAsJsonAsync("api/tts/generate", new { Text = scriptToUse, LanguageCode = lang.Code });
                        if (ttsResp.IsSuccessStatusCode) {
                            var ttsResult = await ttsResp.Content.ReadFromJsonAsync<TtsResponse>();
                            if (ttsResult != null) {
                                newAudio.FileUrl = ttsResult.Url;
                                Console.WriteLine($"[AudioChain] TTS Success: {ttsResult.Url}");
                            }
                        } else {
                            Console.WriteLine($"[AudioChain] TTS FAILED for {lang.Code}");
                        }
                    }
                    _model.AudioFiles.Add(newAudio);
                }
            }
            Snackbar.Add("Đã tạo xong bộ Audio Guide đa ngôn ngữ", Severity.Success);
        }
        catch (Exception ex) { 
            Console.WriteLine($"[AudioChain] FATAL ERROR: {ex.Message}");
            Snackbar.Add("Lỗi tạo Audio: " + ex.Message, Severity.Error); 
        }
        finally { _generatingAllAudio = false; StateHasChanged(); }
    }

    private async Task TranslateAllContents()
    {
        var defaultLang = _languages.FirstOrDefault(x => x.IsDefault);
        if (defaultLang == null) return;
        var sourceContent = _model.Contents.FirstOrDefault(x => x.LanguageCode == defaultLang.Code);
        if (sourceContent == null || string.IsNullOrWhiteSpace(sourceContent.Description)) return;

        _translatingAllDesc = true;
        try {
            var tasks = _languages.Where(l => !l.IsDefault && l.IsActive).Select(async lang => {
                var content = _model.Contents.FirstOrDefault(t => t.LanguageCode == lang.Code);
                if (content == null) {
                    content = new PoiContent { LanguageCode = lang.Code };
                    _model.Contents.Add(content);
                }
                await TranslateContent(content, sourceContent);
            });
            await Task.WhenAll(tasks);
            Snackbar.Add("Đã dịch xong tất cả ngôn ngữ", Severity.Success);
        } catch (Exception ex) {
            Snackbar.Add("Lỗi dịch tổng thể: " + ex.Message, Severity.Error);
        } finally {
            _translatingAllDesc = false;
            StateHasChanged();
        }
    }

    private async Task TranslateContent(PoiContent targetContent, PoiContent sourceContent)
    {
        if (string.IsNullOrEmpty(targetContent.LanguageCode)) return;
        if (string.IsNullOrWhiteSpace(sourceContent.Description)) {
            Snackbar.Add("Vui lòng nhập mô tả Tiếng Việt trước khi dịch", Severity.Warning);
            return;
        }
        
        _translatingDesc[targetContent.LanguageCode] = true;
        try {
            var response = await Http.PostAsJsonAsync("api/Translate", new { Text = sourceContent.Description, TargetLanguage = targetContent.LanguageCode });
            if (response.IsSuccessStatusCode) {
                var result = await response.Content.ReadFromJsonAsync<TranslateResponse>();
                if (result != null) targetContent.Description = System.Net.WebUtility.HtmlDecode(result.TranslatedText);
            }
            
            Snackbar.Add($"Đã dịch mô tả sang {targetContent.LanguageCode}", Severity.Success);
        } catch (Exception ex) { 
            Snackbar.Add("Lỗi dịch: " + ex.Message, Severity.Error); 
        }
        finally { _translatingDesc[targetContent.LanguageCode] = false; }
    }

    private void AddTtsAudio(string langCode)
    {
        var count = _model.AudioFiles.Count(a => a.LanguageCode == langCode);
        _model.AudioFiles.Add(new PoiAudioFile { LanguageCode = langCode, IsTts = true, SortOrder = count });
    }

    private void RemoveAudio(PoiAudioFile audio)
    {
        _model.AudioFiles.Remove(audio);
        ReorderAudios(audio.LanguageCode);
    }

    private void MoveAudio(PoiAudioFile audio, int direction)
    {
        var audios = _model.AudioFiles.Where(a => a.LanguageCode == audio.LanguageCode).OrderBy(a => a.SortOrder).ToList();
        var idx = audios.IndexOf(audio);
        var targetIdx = idx + direction;
        if (targetIdx >= 0 && targetIdx < audios.Count) {
            var target = audios[targetIdx];
            (audio.SortOrder, target.SortOrder) = (target.SortOrder, audio.SortOrder);
        }
    }

    private void ReorderAudios(string langCode)
    {
        var audios = _model.AudioFiles.Where(a => a.LanguageCode == langCode).OrderBy(a => a.SortOrder).ToList();
        for (int i = 0; i < audios.Count; i++) audios[i].SortOrder = i;
    }

    private void GoBack() => NavigationManager.NavigateTo("/poi-management");

    [JSInvokable]
    public void UpdateCoordinates(double lat, double lng)
    {
        _model.Latitude = lat;
        _model.Longitude = lng;
        StateHasChanged();
    }

    private async Task<IEnumerable<MapPrediction>> SearchMapPredictions(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return new List<MapPrediction>();

        try
        {
            return await MapService.GetPredictionsAsync(value, token);
        }
        catch
        {
            return new List<MapPrediction>();
        }
    }

    private async Task OnMapPredictionSelected(MapPrediction value)
    {
        _selectedMapPrediction = value;
        if (value != null)
        {
            var details = await MapService.GetPlaceDetailsAsync(value.place_id);
            if (details != null)
            {
                _model.Latitude = details.lat;
                _model.Longitude = details.lng;
                await MapService.SetMarkerAsync(_model.Latitude, _model.Longitude, "editor-map");
                StateHasChanged();
            }
        }
    }

    private void GenerateRandomQr() => _model.QrValue = "POI_" + Guid.NewGuid().ToString("N").Substring(0, 8).ToUpper();

