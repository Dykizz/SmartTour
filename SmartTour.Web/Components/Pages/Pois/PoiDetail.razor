    private string GetCategoryName(int id) => _categories.FirstOrDefault(c => c.Id == id)?.Name ?? $"Undefined ({id})";
    private string GetLanguageName(string code) => _languages.FirstOrDefault(l => l.Code == code)?.Name ?? code.ToUpper();

    private string TranslateDay(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday    => "Thứ Hai",
        DayOfWeek.Tuesday   => "Thứ Ba",
        DayOfWeek.Wednesday => "Thứ Tư",
        DayOfWeek.Thursday  => "Thứ Năm",
        DayOfWeek.Friday    => "Thứ Sáu",
        DayOfWeek.Saturday  => "Thứ Bảy",
        DayOfWeek.Sunday    => "Chủ Nhật",
        _ => day.ToString()
    };

    private async Task DownloadQrCard()
    {
        if (_poi == null || string.IsNullOrWhiteSpace(_poi.QrValue)) return;
        var qrBase64 = GetQrCodeBase64(_poi.QrValue);
        var script = @"
            (function(name, qrBase64, filename) {
                var canvas = document.createElement('canvas');
                // Khởi tạo Canvas độ phân giải cao để tem nét căng
                canvas.width = 800;
                canvas.height = 960;
                var ctx = canvas.getContext('2d');

                // Màu nền trắng
                ctx.fillStyle = '#fff';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Viền đứt khúc
                ctx.strokeStyle = '#1976d2';
                ctx.lineWidth = 10;
                ctx.setLineDash([20, 20]);
                ctx.strokeRect(40, 40, canvas.width - 80, canvas.height - 80);

                // Tên quán
                ctx.fillStyle = '#000';
                ctx.font = 'bold 48px sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                // Vẽ chữ tự scale ngang nếu dài quá
                ctx.fillText(name.toUpperCase(), canvas.width / 2, 140, canvas.width - 120);

                var img = new Image();
                img.onload = function() {
                    // Vẽ QR Code
                    ctx.drawImage(img, (canvas.width - 600) / 2, 210, 600, 600);

                    // Vẽ Slogan đỏ
                    ctx.fillStyle = '#d32f2f';
                    ctx.font = 'bold 36px sans-serif';
                    ctx.fillText('QUÉT MÃ ĐỂ TÌM HIỂU THÊM', canvas.width / 2, 870);

                    // Tự động Download PNG
                    var link = document.createElement('a');
                    link.download = filename;
                    link.href = canvas.toDataURL('image/png');
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                };
                img.src = qrBase64;
            })
        ";

        var safeName = System.Text.Json.JsonSerializer.Serialize(_poi.Name ?? "Chưa có tên");
        var safeQr = System.Text.Json.JsonSerializer.Serialize(qrBase64);
        var safeFilename = System.Text.Json.JsonSerializer.Serialize($"TEM_QR_{_poi.Name ?? _poi.QrValue}.png");

        await JSRuntime.InvokeVoidAsync("eval", $"{script}({safeName}, {safeQr}, {safeFilename});");
    }

    private string GetQrCodeBase64(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "";
        try
        {
            string url = NavigationManager.BaseUri + "poi/" + value;
            using var qrGenerator = new QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(url, QRCodeGenerator.ECCLevel.Q);
            using var qrCode = new PngByteQRCode(qrCodeData);
            var qrCodeImage = qrCode.GetGraphic(5);
            return $"data:image/png;base64,{Convert.ToBase64String(qrCodeImage)}";
        }
        catch { return ""; }
    }
    
