@page "/poi/detail/{Id:int}"
@using SmartTour.Shared.Models
@using SmartTour.Web.Services
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using QRCoder
@attribute [Authorize(Roles = "ADMIN,SELLER")]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IMapService MapService
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Chi tiết Điểm đến #@Id</PageTitle>

@if (_loading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    </MudContainer>
}
else if (_poi == null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
        <MudAlert Severity="Severity.Error">Không tìm thấy POI #@Id</MudAlert>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6 mb-20 animate-fade-in">
        <!-- Header -->
        <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl"
                  Style="background: linear-gradient(135deg, rgba(var(--mud-palette-info-rgb),0.06) 0%, rgba(var(--mud-palette-info-rgb),0.02) 100%); border: 1px solid rgba(var(--mud-palette-info-rgb),0.12);">
            <div class="d-flex align-center justify-space-between flex-wrap gap-4">
                <div class="d-flex align-center">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack"
                                   Variant="Variant.Filled" Color="Color.Surface" Class="mr-4" />
                    <div>
                        <MudText Typo="Typo.h6" Class="mb-1" Style="font-weight:700; letter-spacing:-0.5px;">
                            Chi tiết Điểm đến #@_poi.Id
                        </MudText>
                        <div class="d-flex align-center gap-2 flex-wrap">
                            <MudChip T="string" Size="Size.Small" Color="@(_poi.IsActive ? Color.Success : Color.Error)" Variant="Variant.Filled">
                                @(_poi.IsActive ? "Đang hoạt động" : "Tạm dừng")
                            </MudChip>
                            @if (_poi.IsFeature)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Star">Nổi bật</MudChip>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Người tạo: <b>@(_poi.CreatedBy?.FullName ?? "Hệ thống")</b> lúc @_poi.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</MudText>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => NavigateToEdit(_poi.Id))">
                        Chỉnh sửa 
                    </MudButton>
                </div>
            </div>
        </MudPaper>

        <MudExpansionPanels MultiExpansion="true" Elevation="0">

            <!-- Section 1: Thông tin cơ bản -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                <MudExpansionPanel Expanded="true" Style="background:white;">
                    <TitleContent>
                        <div class="d-flex align-center py-1">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" />
                            </MudAvatar>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.subtitle1" Class="mb-0">Cấu hình cơ bản</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Thiết lập thông tin chính của điểm đến</MudText>
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Tên điểm đến</MudText>
                                    <MudText Typo="Typo.h6" Style="font-weight:600; color: var(--mud-palette-primary);">@_poi.Name</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Loại hình</MudText>
                                    <MudText Typo="Typo.body1">@(_poi.Category?.Name ?? GetCategoryName(_poi.CategoryId))</MudText>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Bán kính Geofence</MudText>
                                    <MudText Typo="Typo.body1"><b>@_poi.GeofenceRadius</b> mét</MudText>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Mã QR (SmartTour Link)</MudText>
                                    <div class="d-flex align-center gap-3 mt-1">
                                        <MudText Typo="Typo.body2" Style="font-family:monospace; background:#f5f5f5; padding:6px 10px; border-radius:6px; display:inline-block; margin-bottom:0;">
                                            @(_poi.QrValue ?? "—")
                                        </MudText>
                                        @if (!string.IsNullOrWhiteSpace(_poi.QrValue))
                                        {
                                            <div class="qr-container" style="position: relative; border-radius: 8px; border: 1px solid var(--mud-palette-divider); overflow: hidden; width: 72px; height: 72px; cursor: pointer;" title="Nhấn để tải Tem ảnh HD" @onclick="DownloadQrCard">
                                                <img src="@GetQrCodeBase64(_poi.QrValue)" style="width: 100%; height: 100%; display: block; background: white;" alt="QR Code" />
                                                <div class="qr-overlay d-flex justify-center align-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.Download" Size="Size.Small" Style="color: white; font-weight: 700;" />
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </MudItem>
                            </MudGrid>
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>

            <!-- Section 2: Vị trí & Bản đồ -->
            <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                <MudExpansionPanel Expanded="true" Style="background:white;">
                    <TitleContent>
                        <div class="d-flex align-center py-1">
                            <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Medium" />
                            </MudAvatar>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.subtitle1" Class="mb-0">Vị trí địa lý & Bản đồ</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Xác định toạ độ và vùng geofence</MudText>
                            </div>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudDivider />
                        <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                            <MudGrid Spacing="3" Class="mb-4">
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Vĩ độ (Lat)</MudText>
                                    <MudText Typo="Typo.body1" Style="font-family:monospace;">@_poi.Latitude.ToString("F6")</MudText>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Kinh độ (Lng)</MudText>
                                    <MudText Typo="Typo.body1" Style="font-family:monospace;">@_poi.Longitude.ToString("F6")</MudText>
                                </MudItem>
                            </MudGrid>
                            <div id="detail-map" style="height:500px; width:100%; border-radius:12px; border:1px solid var(--mud-palette-divider);"></div>
                        </div>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>

            <!-- Section 3: Hình ảnh -->
            @if (_poi.Images.Any())
            {
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                    <MudExpansionPanel Expanded="true" Style="background:white;">
                        <TitleContent>
                            <div class="d-flex align-center py-1">
                                <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Medium" />
                                </MudAvatar>
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">Bộ sưu tập hình ảnh</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Quản lý hình ảnh và thumbnail của điểm đến</MudText>
                                </div>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                                <MudGrid Spacing="2">
                                    @foreach (var img in _poi.Images.OrderBy(x => x.SortOrder))
                                    {
                                        <MudItem xs="6" md="4" lg="3">
                                            <MudCard Outlined="true" Class="rounded-lg shadow-sm poi-image-preview" Style="overflow:hidden; position:relative; cursor: pointer;" @onclick="@(() => OpenImagePreview(img.ImageUrl))">
                                                <div style="height:150px; overflow:hidden; position:relative;">
                                                    @if (!string.IsNullOrEmpty(img.ImageUrl))
                                                    {
                                                        <MudImage Src="@img.ImageUrl" Style="height:100%; width:100%;" ObjectFit="ObjectFit.Cover" />
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex align-center justify-center" style="height:100%; background:#f0f0f0;">
                                                            <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Color="Color.Default" />
                                                        </div>
                                                    }
                                                    @if (img.IsThumbnail)
                                                    {
                                                        <div style="position:absolute; top:8px; right:8px; background:rgba(255,193,7,0.9); border-radius:4px; padding:2px 8px; font-weight: bold; color: white;">
                                                            <MudText Typo="Typo.caption">CHÍNH</MudText>
                                                        </div>
                                                    }
                                                    <div class="hover-overlay">
                                                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Style="color: white; font-size: 2rem;" />
                                                    </div>
                                                </div>
                                            </MudCard>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudPaper>
            }

            <!-- Section 4: Mô tả đa ngôn ngữ -->
            @if (_poi.Contents.Any())
            {
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                    <MudExpansionPanel Expanded="true" Style="background:white;">
                        <TitleContent>
                            <div class="d-flex align-center py-1">
                                <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Medium" />
                                </MudAvatar>
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">Chi tiết & Mô tả đa ngôn ngữ</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Nội dung giới thiệu và bản dịch tự động</MudText>
                                </div>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
                                         Border="true" PanelClass="pa-4" MinimumTabWidth="80px">
                                    @foreach (var content in _poi.Contents)
                                    {
                                        <MudTabPanel Text="@GetLanguageName(content.LanguageCode)">
                                            @if (string.IsNullOrWhiteSpace(content.Description))
                                            {
                                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">Chưa có nội dung mô tả.</MudAlert>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Style="white-space:pre-wrap; line-height:1.8;" Class="mt-2">@content.Description</MudText>
                                            }
                                        </MudTabPanel>
                                    }
                                </MudTabs>
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudPaper>
            }

            <!-- Section 5: Thuyết minh Audio -->
            @if (_poi.AudioFiles.Any())
            {
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                    <MudExpansionPanel Expanded="true" Style="background:white;">
                        <TitleContent>
                            <div class="d-flex align-center py-1">
                                <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.VolumeUp" Size="Size.Medium" />
                                </MudAvatar>
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">Trình tạo thuyết minh AI</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Tự động dịch và chuyển đổi thành giọng nói</MudText>
                                </div>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
                                         Border="true" PanelClass="pa-4" MinimumTabWidth="80px">
                                    @foreach (var group in _poi.AudioFiles.GroupBy(a => a.LanguageCode))
                                    {
                                        <MudTabPanel Text="@GetLanguageName(group.Key)">
                                            <MudStack Spacing="3" Class="mt-2">
                                                @{
                                                    var audio = group.FirstOrDefault();
                                                }
                                                @if (audio != null)
                                                {
                                                    <MudPaper Elevation="0" Class="pa-4" Style="border:1px solid var(--mud-palette-divider); border-radius: 8px;">
                                                        <div class="d-flex flex-column gap-3">
                                                            <div class="d-flex justify-space-between align-center">
                                                                <MudChip T="string" Color="@(audio.IsTts ? Color.Primary : Color.Info)" Size="Size.Small" Variant="Variant.Filled" Icon="@(audio.IsTts ? Icons.Material.Filled.AutoFixHigh : Icons.Material.Filled.CloudUpload)">
                                                                    @(audio.IsTts ? "Sinh bằng AI" : "Tự tải lên")
                                                                </MudChip>
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(audio.TtsScript))
                                                            {
                                                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-style: italic;">"@audio.TtsScript"</MudText>
                                                            }
                                                            @if (!string.IsNullOrEmpty(audio.FileUrl))
                                                            {
                                                                <audio controls src="@audio.FileUrl" style="width: 100%; height: 40px; border-radius: 8px;"></audio>
                                                            }
                                                            else
                                                            {
                                                                <MudAlert Severity="Severity.Warning" Dense="true">Không có file âm thanh gốc.</MudAlert>
                                                            }
                                                        </div>
                                                    </MudPaper>
                                                }
                                            </MudStack>
                                        </MudTabPanel>
                                    }
                                </MudTabs>
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudPaper>
            }

            <!-- Section 6: Giờ mở cửa -->
            @if (_poi.OperatingHours.Any())
            {
                <MudPaper Elevation="2" Class="mb-4 rounded-xl overflow-hidden stagger-item" Style="border:1px solid rgba(0,0,0,0.08);">
                    <MudExpansionPanel Expanded="false" Style="background:white;">
                        <TitleContent>
                            <div class="d-flex align-center py-1">
                                <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Medium" />
                                </MudAvatar>
                                <div class="flex-grow-1">
                                    <MudText Typo="Typo.subtitle1" Class="mb-0">Giờ mở cửa hàng tuần</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Thiết lập lịch hoạt động theo ngày</MudText>
                                </div>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-6" style="background:rgba(0,0,0,0.01);">
                                @foreach (var day in _poi.OperatingHours.OrderBy(x => x.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)x.DayOfWeek))
                                {
                                    <div class="d-flex align-center py-3" style="border-bottom:1px solid var(--mud-palette-divider);">
                                        <div style="width:120px;" class="d-flex align-center gap-3">
                                            <MudIcon Icon="@(day.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                                     Color="@(day.IsActive ? Color.Success : Color.Default)"
                                                     Size="Size.Small" />
                                            <MudText Typo="Typo.subtitle2" Style="@(!day.IsActive ? "color:var(--mud-palette-text-disabled);" : "")">
                                                @TranslateDay(day.DayOfWeek)
                                            </MudText>
                                        </div>
                                        @if (day.IsActive)
                                        {
                                            <MudText Typo="Typo.body1" Style="font-family:monospace; font-weight:600;">
                                                @(day.OpenTime?.ToString(@"hh\:mm") ?? "—")  đến  @(day.CloseTime?.ToString(@"hh\:mm") ?? "—")
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Default" Class="fst-italic">Đóng cửa</MudText>
                                        }
                                    </div>
                                }
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudPaper>
            }

        </MudExpansionPanels>
    </MudContainer>
}

<style>
    .animate-fade-in { animation: fadeIn 0.5s cubic-bezier(0.4,0,0.2,1); }
    @@keyframes fadeIn { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
    .stagger-item { animation: staggerFadeIn 0.4s cubic-bezier(0.4,0,0.2,1) backwards; }
    .stagger-item:nth-child(1) { animation-delay: 0.04s; }
    .stagger-item:nth-child(2) { animation-delay: 0.08s; }
    .stagger-item:nth-child(3) { animation-delay: 0.12s; }
    .stagger-item:nth-child(4) { animation-delay: 0.16s; }
    .stagger-item:nth-child(5) { animation-delay: 0.20s; }
    @@keyframes staggerFadeIn { from { opacity:0; transform:translateX(-8px); } to { opacity:1; transform:translateX(0); } }
    .mud-expansion-panel { border-radius:12px !important; transition:all 0.3s ease; }
    .mud-expansion-panel:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08) !important; }
    
    /* Hiệu ứng trỏ chuột vào mã QR trong thẻ thông tin */
    .qr-container .qr-overlay {
        position: absolute; top:0; left:0; right:0; bottom:0;
        background: rgba(0,0,0,0.6); opacity: 0; transition: opacity 0.2s ease;
    }
    .qr-container:hover .qr-overlay { opacity: 1; }
    .poi-image-preview {
        transition: transform 0.2s ease;
    }
    .poi-image-preview:hover {
        transform: scale(1.02);
    }
    .hover-overlay {
        position: absolute; top:0; left:0; right:0; bottom:0;
        background: rgba(0,0,0,0.5);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: opacity 0.2s ease;
    }
    .poi-image-preview:hover .hover-overlay { opacity: 1; }
</style>

<MudOverlay Visible="@_previewVisible" DarkBackground="true" ZIndex="9999" OnClick="@(() => _previewVisible = false)">
    @if (!string.IsNullOrEmpty(_previewImageUrl))
    {
        <div style="position: relative; max-width: 90vw; max-height: 90vh;">
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" 
                           OnClick="@(() => _previewVisible = false)"
                           Style="position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.9); z-index: 10;" />
            <img src="@_previewImageUrl" style="max-width: 100%; max-height: 90vh; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.5); object-fit: contain;" />
        </div>
    }
</MudOverlay>

@code {
    [Parameter] public int Id { get; set; }

    private bool _previewVisible = false;
    private string? _previewImageUrl = null;

    private void OpenImagePreview(string? url)
    {
        if (!string.IsNullOrEmpty(url))
        {
            _previewImageUrl = url;
            _previewVisible = true;
        }
    }

    private Poi? _poi;
    private List<Category> _categories = new();
    private List<Language> _languages = new();
    private bool _loading = true;
    private bool _mapInitialized = false;
    private DotNetObjectReference<PoiDetail>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _categories = await Http.GetFromJsonAsync<List<Category>>("api/categories") ?? new();
            _languages = await Http.GetFromJsonAsync<List<Language>>("api/languages") ?? new();
            _poi = await Http.GetFromJsonAsync<Poi>($"api/pois/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi tải dữ liệu chi tiết POI: " + ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_mapInitialized && _poi != null && _poi.Latitude != 0)
        {
            await Task.Delay(400); // Đợi DOM expansion panel load xong
            _objRef = DotNetObjectReference.Create(this);
            await MapService.InitMapAsync(_poi.Latitude, _poi.Longitude, "detail-map", _objRef);
            
            // Render bán kính hiện tại
            var mappedData = new[] {
                new {
                    id = _poi.Id,
                    name = _poi.Name,
                    lat = _poi.Latitude,
                    lng = _poi.Longitude,
                    isActive = _poi.IsActive,
                    radius = _poi.GeofenceRadius
                }
            };
            
            // Hiển thị marker review nhỏ trên bản đồ phụ
            var mapConfig = await Http.GetFromJsonAsync<MapConfigResult>("api/pois/map-config");
            string apiKey = MapService.ProviderName == "Google" ? (mapConfig?.GoogleMapsApiKey ?? "") : (mapConfig?.MapboxAccessToken ?? "");
            
            string jsFunc = MapService.ProviderName switch
            {
                "Google" => "googleMapInterop.showOverviewMap",
                _ => "mapInterop.showOverviewMap"
            };
            await JSRuntime.InvokeVoidAsync(jsFunc, "detail-map", mappedData.ToList(), null, apiKey);
            
            _mapInitialized = true;
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/poi-management");
    private void NavigateToEdit(int id) => NavigationManager.NavigateTo($"/poi/editor/{id}");

    [JSInvokable]
    public void UpdateCoordinates(double lat, double lng) { /* read-only */ }
    
    [JSInvokable]
    public void NavigateToDetailFromMap(int id) { /* Cannot navigate to itself */ }

