# MAP PROVIDER (Mapbox or Vietmap)
MAP_PROVIDER=Mapbox

# API Keys
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here
VIETMAP_API_KEY=your_vietmap_api_key_here

# Google Auth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google Cloud Storage
GOOGLE_STORAGE_BUCKET=your_google_storage_bucket_name

# Azure Text-to-Speech
TEXT_TO_SPEECH_KEY=your_tts_api_key_here

# Connection Strings (If using .env for DB)
# ConnectionStrings__DefaultConnection="Server=localhost;Database=SmartTourDb;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True"
